{
  "name": "abrahamic-books",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "offline:data": "node scripts/download-offline-data.mjs",
    "build": "vite build --base=./ && node scripts/prepare-sites-build.mjs",
    "dev": "vite --host 0.0.0.0",
    "android:add": "cap add android",
    "android:sync": "npm run build && node scripts/prepare-mobile-build.mjs && cap sync android",
    "android:apk": "npm run android:sync && cd android && ./gradlew assembleDebug"
  },
  "devDependencies": {
    "vite": "^6.4.3"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/filesystem": "^6.0.4",
    "@capacitor/share": "^6.0.4",
    "@tabler/icons-webfont": "^3.34.1",
    "firebase": "^11.10.0"
  }
}
