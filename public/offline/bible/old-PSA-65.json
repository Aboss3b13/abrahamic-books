{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":65,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. A Psalm by David. A song."]},{"type":"verse","number":1,"content":[{"text":"Praise waits for you, God, in Zion.","poem":1},{"text":"Vows shall be performed to you.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"You who hear prayer,","poem":1},{"text":"all men will come to you.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Sins overwhelmed me,","poem":1},{"text":"but you atoned for our transgressions.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Blessed is the one whom you choose and cause to come near,","poem":1},{"text":"that he may live in your courts.","poem":2},{"lineBreak":true},{"text":"We will be filled with the goodness of your house,","poem":2},{"lineBreak":true},{"text":"your holy temple.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"By awesome deeds of righteousness, you answer us,","poem":1},{"text":"God of our salvation.","poem":2},{"text":"You who are the hope of all the ends of the earth,","poem":1},{"text":"of those who are far away on the sea.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"By your power, you form the mountains,","poem":1},{"text":"having armed yourself with strength.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"You still the roaring of the seas,","poem":1},{"text":"the roaring of their waves,","poem":2},{"lineBreak":true},{"text":"and the turmoil of the nations.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"They also who dwell in faraway places are afraid at your wonders.","poem":1},{"text":"You call the morning’s dawn and the evening with songs of joy.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"You visit the earth, and water it.","poem":1},{"text":"You greatly enrich it.","poem":2},{"text":"The river of God is full of water.","poem":1},{"text":"You provide them grain, for so you have ordained it.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"You drench its furrows.","poem":1},{"text":"You level its ridges.","poem":2},{"lineBreak":true},{"text":"You soften it with showers.","poem":2},{"lineBreak":true},{"text":"You bless it with a crop.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"You crown the year with your bounty.","poem":1},{"text":"Your carts overflow with abundance.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"The wilderness grasslands overflow.","poem":1},{"text":"The hills are clothed with gladness.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"The pastures are covered with flocks.","poem":1},{"text":"The valleys also are clothed with grain.","poem":2},{"text":"They shout for joy!","poem":1},{"text":"They also sing.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/65.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":65},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/66.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":66},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/64.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":64},"previousChapterAudioLinks":{},"numberOfVerses":13},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":65,"content":[{"type":"verse","number":1,"content":["לַמְנַצֵּ֥חַ מִזְמ֗וֹר לְדָוִ֥ד שִֽׁיר׃"]},{"type":"verse","number":2,"content":["לְךָ֤ דֻֽמִיָּ֬ה תְהִלָּ֓ה אֱלֹ֘הִ֥ים בְּצִיּ֑וֹן וּ֝לְךָ֗ יְשֻׁלַּם־נֶֽדֶר׃"]},{"type":"verse","number":3,"content":["שֹׁמֵ֥עַ תְּפִלָּ֑ה עָ֝דֶ֗יךָ כָּל־בָּשָׂ֥ר יָבֹֽאוּ׃"]},{"type":"verse","number":4,"content":["דִּבְרֵ֣י עֲ֭וֺנֹת גָּ֣בְרוּ מֶ֑נִּי פְּ֝שָׁעֵ֗ינוּ אַתָּ֥ה תְכַפְּרֵֽם׃"]},{"type":"verse","number":5,"content":["אַשְׁרֵ֤י ׀ תִּֽבְחַ֣ר וּתְקָרֵב֮ יִשְׁכֹּ֪ן חֲצֵ֫רֶ֥יךָ נִ֭שְׂבְּעָה בְּט֣וּב בֵּיתֶ֑ךָ קְ֝דֹ֗שׁ הֵיכָלֶֽךָ׃"]},{"type":"verse","number":6,"content":["נ֤וֹרָא֨וֹת ׀ בְּצֶ֣דֶק תַּ֭עֲנֵנוּ אֱלֹהֵ֣י יִשְׁעֵ֑נוּ מִבְטָ֥ח כָּל־קַצְוֵי־אֶ֝֗רֶץ וְיָ֣ם רְחֹקִֽים׃"]},{"type":"verse","number":7,"content":["מֵכִ֣ין הָרִ֣ים בְּכֹח֑וֹ נֶ֝אְזָ֗ר בִּגְבוּרָֽה׃"]},{"type":"verse","number":8,"content":["מַשְׁבִּ֤יחַ ׀ שְׁא֣וֹן יַ֭מִּים שְׁא֥וֹן גַּלֵּיהֶ֗ם וַהֲמ֥וֹן לְאֻמִּֽים׃"]},{"type":"verse","number":9,"content":["וַיִּ֤ירְא֨וּ ׀ יֹשְׁבֵ֣י קְ֭צָוֺת מֵאוֹתֹתֶ֑יךָ מ֤וֹצָֽאֵי־בֹ֖קֶר וָעֶ֣רֶב תַּרְנִֽין׃"]},{"type":"verse","number":10,"content":["פָּקַ֥דְתָּ הָאָ֨רֶץ ׀ וַתְּשֹׁ֪קְקֶ֡הָ רַבַּ֬ת תַּעְשְׁרֶ֗נָּה פֶּ֣לֶג אֱ֭לֹהִים מָ֣לֵא מָ֑יִם תָּכִ֥ין דְּ֝גָנָ֗ם כִּי־כֵ֥ן תְּכִינֶֽהָ׃"]},{"type":"verse","number":11,"content":["תְּלָמֶ֣יהָ רַ֭וֵּה נַחֵ֣ת גְּדוּדֶ֑יהָ בִּרְבִיבִ֥ים תְּ֝מֹגְגֶ֗נָּה צִמְחָ֥הּ תְּבָרֵֽךְ׃"]},{"type":"verse","number":12,"content":["עִ֭טַּרְתָּ שְׁנַ֣ת טוֹבָתֶ֑ךָ וּ֝מַעְגָּלֶ֗יךָ יִרְעֲפ֥וּן דָּֽשֶׁן׃"]},{"type":"verse","number":13,"content":["יִ֭רְעֲפוּ נְא֣וֹת מִדְבָּ֑ר וְ֝גִ֗יל גְּבָע֥וֹת תַּחְגֹּֽרְנָה׃"]},{"type":"verse","number":14,"content":["לָבְשׁ֬וּ כָרִ֨ים ׀ הַצֹּ֗אן וַעֲמָקִ֥ים יַֽעַטְפוּ־בָ֑ר יִ֝תְרוֹעֲע֗וּ אַף־יָשִֽׁירוּ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/65.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":65},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/66.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":66},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/64.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":64},"prev