{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":3,"content":[{"type":"hebrew_subtitle","content":["A Psalm by David, when he fled from Absalom his son."]},{"type":"verse","number":1,"content":[{"text":"Yahweh, how my adversaries have increased!","poem":1},{"text":"Many are those who rise up against me.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Many there are who say of my soul,","poem":1},{"text":"“There is no help for him in God.”","poem":2},{"noteId":4},{"text":"Selah.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"But you, Yahweh, are a shield around me,","poem":1},{"text":"my glory, and the one who lifts up my head.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"I cry to Yahweh with my voice,","poem":1},{"text":"and he answers me out of his holy hill. Selah.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"I laid myself down and slept.","poem":1},{"text":"I awakened, for Yahweh sustains me.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"I will not be afraid of tens of thousands of people","poem":1},{"text":"who have set themselves against me on every side.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Arise, Yahweh!","poem":1},{"text":"Save me, my God!","poem":2},{"text":"For you have struck all of my enemies on the cheek bone.","poem":1},{"text":"You have broken the teeth of the wicked.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Salvation belongs to Yahweh.","poem":1},{"text":"May your blessing be on your people. Selah.","poem":2}]}],"footnotes":[{"noteId":4,"caller":"+","text":"The Hebrew word rendered “God” is “אֱלֹהִ֑ים” (Elohim).","reference":{"chapter":3,"verse":2}}]},"thisChapterLink":"/api/eng_web/PSA/3.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":3},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/4.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":4},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/2.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":2},"previousChapterAudioLinks":{},"numberOfVerses":8},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumbe