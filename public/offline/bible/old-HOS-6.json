{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"HOS","translationId":"eng_web","name":"Hosea","commonName":"Hosea","title":"The Book of Hosea","order":28,"numberOfChapters":14,"sha256":"bd5ebfbd1ddca5270a57240da3b90ae8c77eab8433e26c5c6f0cbca696ce8d28","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/HOS/1.json","firstChapterReference":{"translationId":"eng_web","book":"HOS","chapter":1},"lastChapterNumber":14,"lastChapterApiLink":"/api/eng_web/HOS/14.json","lastChapterReference":{"translationId":"eng_web","book":"HOS","chapter":14},"totalNumberOfVerses":197},"chapter":{"number":6,"content":[{"type":"verse","number":1,"content":["“Come! Let’s return to Yahweh;",{"text":"for he has torn us to pieces,","poem":2},{"lineBreak":true},{"text":"and he will heal us;","poem":2},{"text":"he has injured us,","poem":1},{"text":"and he will bind up our wounds.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"After two days he will revive us.","poem":1},{"text":"On the third day he will raise us up,","poem":2},{"lineBreak":true},{"text":"and we will live before him.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Let’s acknowledge Yahweh.","poem":1},{"text":"Let’s press on to know Yahweh.","poem":2},{"text":"As surely as the sun rises,","poem":1},{"text":"Yahweh will appear.","poem":2},{"text":"He will come to us like the rain,","poem":1},{"text":"like the spring rain that waters the earth.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"“Ephraim, what shall I do to you?","poem":1},{"text":"Judah, what shall I do to you?","poem":2},{"lineBreak":true},{"text":"For your love is like a morning cloud,","poem":2},{"lineBreak":true},{"text":"and like the dew that disappears early.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Therefore I have cut them to pieces with the prophets;","poem":1},{"text":"I killed them with the words of my mouth.","poem":2},{"lineBreak":true},{"text":"Your judgments are like a flash of lightning.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"For I desire mercy, and not sacrifice;","poem":1},{"text":"and the knowledge of God more than burnt offerings.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"But they, like Adam, have broken the covenant.","poem":1},{"text":"They were unfaithful to me there.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Gilead is a city of those who work iniquity;","poem":1},{"text":"it is stained with blood.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"As gangs of robbers wait to ambush a man,","poem":1},{"text":"so the company of priests murder on the path toward Shechem,","poem":2},{"lineBreak":true},{"text":"committing shameful crimes.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"In the house of Israel I have seen a horrible thing.","poem":1},{"text":"There is prostitution in Ephraim.","poem":2},{"lineBreak":true},{"text":"Israel is defiled.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"“Also, Judah, there is a harvest appointed for you,","poem":1},{"text":"when I restore the fortunes of my people.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/HOS/6.json","thisChapterReference":{"translationId":"eng_web","book":"HOS","chapter":6},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/HOS/7.json","nextChapterReference":{"translationId":"eng_web","book":"HOS","chapter":7},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/HOS/5.json","previousChapterReference":{"translationId":"eng_web","book":"HOS","chapter":5},"previousChapterAudioLinks":{},"numberOfVerses":11},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"HOS","translationId":"hbo_wlc","name":"הושע","commonName":"הושע","title":"הושע","order":28,"numberOfChapters":14,"sha256":"5c6104af107c18ea2cba7b0bef06ed4d33f336ae3adc86fbb67e15a4e5d42b3f","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/HOS/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"HOS","chapter":1},"lastChapterNumber":14,"lastChapterApiLink":"/api/hbo_wlc/HOS/14.json","lastChapterReference":{"translationId":"hbo_wlc","book":"HOS","chapter":14},"totalNumberOfVerses":197},"chapter":{"number":6,"content":[{"type":"verse","number":1,"content":["לְכוּ֙ וְנָשׁ֣וּבָה אֶל־יְהוָ֔ה כִּ֛י ה֥וּא טָרָ֖ף וְיִרְפָּאֵ֑נוּ יַ֖ךְ וְיַחְבְּשֵֽׁנוּ׃"]},{"type":"verse","number":2,"content":["יְחַיֵּ֖נוּ מִיֹּמָ֑יִם בַּיּוֹם֙ הַשְּׁלִישִׁ֔י יְקִמֵ֖נוּ וְנִחְיֶ֥ה לְפָנָֽיו׃"]},{"type":"verse","number":3,"content":["וְנֵדְעָ֣ה נִרְדְּפָ֗ה לָדַ֙עַת֙ אֶת־יְהוָ֔ה כְּשַׁ֖חַר נָכ֣וֹן מֽוֹצָא֑וֹ וְיָב֤וֹא כַגֶּ֙שֶׁם֙ לָ֔נוּ כְּמַלְק֖וֹשׁ י֥וֹרֶה אָֽרֶץ׃"]},{"type":"verse","number":4,"content":["מָ֤ה אֶֽעֱשֶׂה־לְּךָ֙ אֶפְרַ֔יִם מָ֥ה אֶעֱשֶׂה־לְּךָ֖ יְהוּדָ֑ה וְחַסְדְּכֶם֙ כַּֽעֲנַן־בֹּ֔קֶר וְכַטַּ֖ל מַשְׁכִּ֥ים הֹלֵֽךְ׃"]},{"type":"verse","number":5,"content":["עַל־כֵּ֗ן חָצַ֙בְתִּי֙ בַּנְּבִיאִ֔ים הֲרַגְתִּ֖ים בְּאִמְרֵי־פִ֑י וּמִשְׁפָּטֶ֖יךָ א֥וֹר יֵצֵֽא׃"]},{"type":"verse","number":6,"content":["כִּ֛י חֶ֥סֶד חָפַ֖צְתִּי וְלֹא־זָ֑בַח וְדַ֥עַת אֱלֹהִ֖ים מֵעֹלֽוֹת׃"]},{"type":"verse","number":7,"content":["וְהֵ֕מָּה כְּאָדָ֖ם עָבְר֣וּ בְרִ֑ית שָׁ֖ם בָּ֥גְדוּ בִֽי׃"]},{"type":"verse","number":8,"content":["גִּלְעָ֕ד קִרְיַ֖ת פֹּ֣עֲלֵי אָ֑וֶן עֲקֻבָּ֖ה מִדָּֽם׃"]},{"type":"verse","number":9,"content":["וּכְחַכֵּ֨י אִ֜ישׁ גְּדוּדִ֗ים חֶ֚בֶר כֹּֽהֲנִ֔ים דֶּ֖רֶךְ יְרַצְּחוּ־שֶׁ֑כְמָה כִּ֥י זִמָּ֖ה עָשֽׂוּ׃"]},{"type":"verse","number":10,"content":["בְּבֵית֙ יִשְׂרָאֵ֔ל רָאִ֖יתִי שעריריה שָׁ֚ם זְנ֣וּת לְאֶפְרַ֔יִם נִטְמָ֖א יִשְׂרָאֵֽל׃"]},{"type":"verse","number":11,"content":["גַּם־יְהוּדָ֕ה שָׁ֥ת קָצִ֖יר לָ֑ךְ בְּשׁוּבִ֖י שְׁב֥וּת עַמִּֽי׃ פ"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/HOS/6.json","thisChapterReference":{"translationId":"hbo_wlc","book":"HOS","chapter":6},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/HOS/7.json","nextChapterReference":{"translationId":"hbo_wlc","book":"HOS","chapter":7},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/HOS/5.json","previousChapterReference":{"translationId":"hbo_wlc","book":"HOS","chapter":5},"previousChapterAudioLinks":{},"numberOfVerses":11}}