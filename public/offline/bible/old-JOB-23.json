{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"JOB","translationId":"eng_web","name":"Job","commonName":"Job","title":"The Book of Job","order":18,"numberOfChapters":42,"sha256":"6dac796e2819a7919823cdaf78d98bff44300681f09e567bccbda12a2dac86c2","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/JOB/1.json","firstChapterReference":{"translationId":"eng_web","book":"JOB","chapter":1},"lastChapterNumber":42,"lastChapterApiLink":"/api/eng_web/JOB/42.json","lastChapterReference":{"translationId":"eng_web","book":"JOB","chapter":42},"totalNumberOfVerses":1070},"chapter":{"number":23,"content":[{"type":"verse","number":1,"content":["Then Job answered,"]},{"type":"verse","number":2,"content":[{"text":"“Even today my complaint is rebellious.","poem":1},{"text":"His hand is heavy in spite of my groaning.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Oh that I knew where I might find him!","poem":1},{"text":"That I might come even to his seat!","poem":2}]},{"type":"verse","number":4,"content":[{"text":"I would set my cause in order before him,","poem":1},{"text":"and fill my mouth with arguments.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"I would know the words which he would answer me,","poem":1},{"text":"and understand what he would tell me.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Would he contend with me in the greatness of his power?","poem":1},{"text":"No, but he would listen to me.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"There the upright might reason with him,","poem":1},{"text":"so I should be delivered forever from my judge.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"“If I go east, he is not there.","poem":1},{"text":"If I go west, I can’t find him.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"He works to the north, but I can’t see him.","poem":1},{"text":"He turns south, but I can’t catch a glimpse of him.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"But he knows the way that I take.","poem":1},{"text":"When he has tried me, I will come out like gold.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"My foot has held fast to his steps.","poem":1},{"text":"I have kept his way, and not turned away.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"I haven’t gone back from the commandment of his lips.","poem":1},{"text":"I have treasured up the words of his mouth more than my necessary food.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"But he stands alone, and who can oppose him?","poem":1},{"text":"What his soul desires, even that he does.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"For he performs that which is appointed for me.","poem":1},{"text":"Many such things are with him.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Therefore I am terrified at his presence.","poem":1},{"text":"When I consider, I am afraid of him.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"For God has made my heart faint.","poem":1},{"text":"The Almighty has terrified me.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"Because I was not cut off before the darkness,","poem":1},{"text":"neither did he cover the thick darkness from my face.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/eng_web/JOB/23.json","thisChapterReference":{"translationId":"eng_web","book":"JOB","chapter":23},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/JOB/24.json","nextChapterReference":{"translationId":"eng_web","book":"JOB","chapter":24},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/JOB/22.json","previousChapterReference":{"translationId":"eng_web","book":"JOB","chapter":22},"previousChapterAudioLinks":{},"numberOfVerses":17},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"JOB","translationId":"hbo_wlc","name":"איוב","commonName":"איוב","title":"איוב","order":18,"numberOfChapters":42,"sha256":"40714f6da0dbbbfa33e6e988fa228d1df6b53dc67303267a827d6a609985c62f","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/JOB/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"JOB","chapter":1},"lastChapterNumber":42,"lastChapterApiLink":"/api/hbo_wlc/JOB/42.json","lastChapterReference":{"translationId":"hbo_wlc","book":"JOB","chapter":42},"totalNumberOfVerses":1070},"chapter":{"number":23,"content":[{"type":"verse","number":1,"content":["וַיַּ֥עַן אִיּ֗וֹב וַיֹּאמַֽר׃"]},{"type":"verse","number":2,"content":["גַּם־הַ֭יּוֹם מְרִ֣י שִׂחִ֑י יָ֝דִ֗י כָּבְדָ֥ה עַל־אַנְחָתִֽי׃"]},{"type":"verse","number":3,"content":["מִֽי־יִתֵּ֣ן יָ֭דַעְתִּי וְאֶמְצָאֵ֑הוּ אָ֝ב֗וֹא עַד־תְּכוּנָתֽוֹ׃"]},{"type":"verse","number":4,"content":["אֶעֶרְכָ֣ה לְפָנָ֣יו מִשְׁפָּ֑ט וּ֝פִ֗י אֲמַלֵּ֥א תוֹכָחֽוֹת׃"]},{"type":"verse","number":5,"content":["אֵ֭דְעָה מִלִּ֣ים יַעֲנֵ֑נִי וְ֝אָבִ֗ינָה מַה־יֹּ֥אמַר לִֽי׃"]},{"type":"verse","number":6,"content":["הַבְּרָב־כֹּ֭חַ יָרִ֣יב עִמָּדִ֑י לֹ֥א אַךְ־ה֝֗וּא יָשִׂ֥ם בִּֽי׃"]},{"type":"verse","number":7,"content":["שָׁ֗ם יָ֭שָׁר נוֹכָ֣ח עִמּ֑וֹ וַאֲפַלְּטָ֥ה לָ֝נֶ֗צַח מִשֹּׁפְטִֽי׃"]},{"type":"verse","number":8,"content":["הֵ֤ן קֶ֣דֶם אֶהֱלֹ֣ךְ וְאֵינֶ֑נּוּ וְ֝אָח֗וֹר וְֽלֹא־אָבִ֥ין לֽוֹ׃"]},{"type":"verse","number":9,"content":["שְׂמֹ֣אול בַּעֲשֹׂת֣וֹ וְלֹא־אָ֑חַז יַעְטֹ֥ף יָ֝מִ֗ין וְלֹ֣א אֶרְאֶֽה׃"]},{"type":"verse","number":10,"content":["כִּֽי־יָ֭דַע דֶּ֣רֶךְ עִמָּדִ֑י בְּ֝חָנַ֗נִי כַּזָּהָ֥ב אֵצֵֽא׃"]},{"type":"verse","number":11,"content":["בַּ֭אֲשֻׁרוֹ אָחֲזָ֣ה רַגְלִ֑י דַּרְכּ֖וֹ שָׁמַ֣רְתִּי וְלֹא־אָֽט׃"]},{"type":"verse","number":12,"content":["מִצְוַ֣ת שְׂ֭פָתָיו וְלֹ֣א אָמִ֑ישׁ מֵ֝חֻקִּ֗י צָפַ֥נְתִּי אִמְרֵי־פִֽיו׃"]},{"type":"verse","number":13,"content":["וְה֣וּא בְ֭אֶחָד וּמִ֣י יְשִׁיבֶ֑נּוּ וְנַפְשׁ֖וֹ אִוְּתָ֣ה וַיָּֽעַשׂ׃"]},{"type":"verse","number":14,"content":["כִּ֭י יַשְׁלִ֣ים חֻקִּ֑י וְכָהֵ֖נָּה רַבּ֣וֹת עִמּֽוֹ׃"]},{"type":"verse","number":15,"content":["עַל־כֵּ֭ן מִפָּנָ֣יו אֶבָּהֵ֑ל אֶ֝תְבּוֹנֵ֗ן וְאֶפְחַ֥ד מִמֶּֽנּוּ׃"]},{"type":"verse","number":16,"content":["וְ֭אֵל הֵרַ֣ךְ לִבִּ֑י וְ֝שַׁדַּ֗י הִבְהִילָֽנִי׃"]},{"type":"verse","number":17,"content":["כִּֽי־לֹ֣א נִ֭צְמַתִּי מִפְּנֵי־חֹ֑שֶׁךְ וּ֝מִפָּנַ֗י כִּסָּה־אֹֽפֶל ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/JOB/23.json","thisChapterReference":{"translationId":"hbo_wlc","book":"JOB","chapter":23},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/JOB/24.json","nextChapterReference":{"translationId":"hbo_wlc","book":"JOB","chapter":24},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/JOB/22.json","previo