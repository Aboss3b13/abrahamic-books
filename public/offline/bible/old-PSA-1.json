{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":1,"content":[{"type":"verse","number":1,"content":[{"text":"Blessed is the man who doesn’t walk in the counsel of the wicked,","poem":1},{"text":"nor stand on the path of sinners,","poem":2},{"lineBreak":true},{"text":"nor sit in the seat of scoffers;","poem":2}]},{"type":"verse","number":2,"content":[{"text":"but his delight is in Yahweh’s","poem":1},{"noteId":0},{"text":"law.","poem":1},{"text":"On his law he meditates day and night.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"He will be like a tree planted by the streams of water,","poem":1},{"text":"that produces its fruit in its season,","poem":2},{"lineBreak":true},{"text":"whose leaf also does not wither.","poem":2},{"lineBreak":true},{"text":"Whatever he does shall prosper.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"The wicked are not so,","poem":1},{"text":"but are like the chaff which the wind drives away.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Therefore the wicked shall not stand in the judgment,","poem":1},{"text":"nor sinners in the congregation of the righteous.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"For Yahweh knows the way of the righteous,","poem":1},{"text":"but the way of the wicked shall perish.","poem":2}]}],"footnotes":[{"noteId":0,"caller":"+","text":"“Yahweh” is God’s proper Name, sometimes rendered “LORD” (all caps) in other translations.","reference":{"chapter":1,"verse":2}}]},"thisChapterLink":"/api/eng_web/PSA/1.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/2.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":2},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/JOB/42.json","previousChapterReference":{"translationId":"eng_web","book":"JOB","chapter":42},"previousChapterAudioLinks":{},"numberOfVerses":6},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":1,"content":[{"type":"verse","number":1,"content":["אַ֥שְֽׁרֵי־הָאִ֗ישׁ אֲשֶׁ֤ר ׀ לֹ֥א הָלַךְ֮ בַּעֲצַ֪ת רְשָׁ֫עִ֥ים וּבְדֶ֣רֶךְ חַ֭טָּאִים לֹ֥א עָמָ֑ד וּבְמוֹשַׁ֥ב לֵ֝צִ֗ים לֹ֣א יָשָֽׁב׃"]},{"type":"verse","number":2,"content":["כִּ֤י אִ֥ם בְּתוֹרַ֥ת יְהוָ֗ה חֶ֫פְצ֥וֹ וּֽבְתוֹרָת֥וֹ יֶהְגֶּ֗ה יוֹמָ֥ם וָלָֽיְלָה׃"]},{"type":"verse","number":3,"content":["וְֽהָיָ֗ה כְּעֵץ֮ שָׁת֪וּל עַֽל־פַּלְגֵ֫י מָ֥יִם אֲשֶׁ֤ר פִּרְי֨וֹ ׀ יִתֵּ֬ן בְּעִתּ֗וֹ וְעָלֵ֥הוּ לֹֽא־יִבּ֑וֹל וְכֹ֖ל אֲשֶׁר־יַעֲשֶׂ֣ה יַצְלִֽיחַ׃"]},{"type":"verse","number":4,"content":["לֹא־כֵ֥ן הָרְשָׁעִ֑ים כִּ֥י אִם־כַּ֝מֹּ֗ץ אֲֽשֶׁר־תִּדְּפֶ֥נּוּ רֽוּחַ׃"]},{"type":"verse","number":5,"content":["עַל־כֵּ֤ן ׀ לֹא־יָקֻ֣מוּ רְ֭שָׁעִים בַּמִּשְׁפָּ֑ט וְ֝חַטָּאִ֗ים בַּעֲדַ֥ת צַדִּיקִֽים׃"]},{"type":"verse","number":6,"content":["כִּֽי־יוֹדֵ֣עַ יְ֭הוָה דֶּ֣רֶךְ צַדִּיקִ֑ים וְדֶ֖רֶךְ רְשָׁעִ֣ים תֹּאבֵֽד׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/1.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/2.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":2},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/JOB/42.json","previousChapterReference":{"translationId":"hbo_wlc","book":"JOB","chapter":42},"previousChapterAudioLinks":{},"numberOfVerses":6}}