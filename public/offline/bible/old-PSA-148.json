ber":6,"content":["וַיַּעֲמִידֵ֣ם לָעַ֣ד לְעוֹלָ֑ם חָק־נָ֝תַ֗ן וְלֹ֣א יַעֲבֽוֹר׃"]},{"type":"verse","number":7,"content":["הַֽלְל֣וּ אֶת־יְ֭הוָה מִן־הָאָ֑רֶץ תַּ֝נִּינִ֗ים וְכָל־תְּהֹמֽוֹת ׃"]},{"type":"verse","number":8,"content":["אֵ֣שׁ וּ֭בָרָד שֶׁ֣לֶג וְקִיט֑וֹר ר֥וּחַ סְ֝עָרָ֗ה עֹשָׂ֥ה דְבָרֽוֹ׃"]},{"type":"verse","number":9,"content":["הֶהָרִ֥ים וְכָל־גְּבָע֑וֹת עֵ֥ץ פְּ֝רִ֗י וְכָל־אֲרָזִֽים׃"]},{"type":"verse","number":10,"content":["הַֽחַיָּ֥ה וְכָל־בְּהֵמָ֑ה רֶ֝֗מֶשׂ וְצִפּ֥וֹר כָּנָֽף׃"]},{"type":"verse","number":11,"content":["מַלְכֵי־אֶ֭רֶץ וְכָל־לְאֻמִּ֑ים שָׂ֝רִ֗ים וְכָל־שֹׁ֥פְטֵי אָֽרֶץ׃"]},{"type":"verse","number":12,"content":["בַּחוּרִ֥ים וְגַם־בְּתוּל֑וֹת זְ֝קֵנִ֗ים עִם־נְעָרִֽים׃"]},{"type":"verse","number":13,"content":["יְהַלְל֤וּ ׀ אֶת־שֵׁ֬ם יְהוָ֗ה כִּֽי־נִשְׂגָּ֣ב שְׁמ֣וֹ לְבַדּ֑וֹ ה֝וֹד֗וֹ עַל־אֶ֥רֶץ וְשָׁמָֽיִם׃"]},{"type":"verse","number":14,"content":["וַיָּ֤רֶם קֶ֨רֶן ׀ לְעַמּ֡וֹ תְּהִלָּ֤ה לְֽכָל־חֲסִידָ֗יו לִבְנֵ֣י יִ֭שְׂרָאֵל עַֽם־קְרֹב֗וֹ הַֽלְלוּ־יָֽהּ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/148.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":148},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/149.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":149},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/147.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":147},"previousChapterAudioLinks":{},"numberOfVerses":14}}