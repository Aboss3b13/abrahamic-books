t":"Let them praise Yahweh’s name,","poem":1},{"text":"for he commanded, and they were created.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"He has also established them forever and ever.","poem":1},{"text":"He has made a decree which will not pass away.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Praise Yahweh from the earth,","poem":1},{"text":"you great sea creatures, and all depths,","poem":2}]},{"type":"verse","number":8,"content":[{"text":"lightning and hail, snow and clouds,","poem":1},{"text":"stormy wind, fulfilling his word,","poem":2}]},{"type":"verse","number":9,"content":[{"text":"mountains and all hills,","poem":1},{"text":"fruit trees and all cedars,","poem":2}]},{"type":"verse","number":10,"content":[{"text":"wild animals and all livestock,","poem":1},{"text":"small creatures and flying birds,","poem":2}]},{"type":"verse","number":11,"content":[{"text":"kings of the earth and all peoples,","poem":1},{"text":"princes and all judges of the earth,","poem":2}]},{"type":"verse","number":12,"content":[{"text":"both young men and maidens,","poem":1},{"text":"old men and children.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Let them praise Yahweh’s name,","poem":1},{"text":"for his name alone is exalted.","poem":2},{"lineBreak":true},{"text":"His glory is above the earth and the heavens.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"He has lifted up the horn of his people,","poem":1},{"text":"the praise of all his saints,","poem":2},{"lineBreak":true},{"text":"even of the children of Israel, a people near to him.","poem":2},{"text":"Praise Yah!","poem":1}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/148.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":148},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/149.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":149},"nextChapterAudioLinks":{},"