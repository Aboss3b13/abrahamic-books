{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":4,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician; on stringed instruments. A Psalm by David."]},{"type":"verse","number":1,"content":[{"text":"Answer me when I call, God of my righteousness.","poem":1},{"text":"Give me relief from my distress.","poem":2},{"lineBreak":true},{"text":"Have mercy on me, and hear my prayer.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"You sons of men, how long shall my glory be turned into dishonor?","poem":1},{"text":"Will you love vanity and seek after falsehood? Selah.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"But know that Yahweh has set apart for himself him who is godly;","poem":1},{"text":"Yahweh will hear when I call to him.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Stand in awe, and don’t sin.","poem":1},{"text":"Search your own heart on your bed, and be still. Selah.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Offer the sacrifices of righteousness.","poem":1},{"text":"Put your trust in Yahweh.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Many say, “Who will show us any good?”","poem":1},{"text":"Yahweh, let the light of your face shine on us.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"You have put gladness in my heart,","poem":1},{"text":"more than when their grain and their new wine are increased.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"In peace I will both lay myself down and sleep,","poem":1},{"text":"for you alone, Yahweh, make me live in safety.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/4.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":4},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/5.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":5},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/3.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":3},"previousChapterAudioLinks":{},"numberOfVerses":8},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient H