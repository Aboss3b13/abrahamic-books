pe":"verse","number":1,"content":["הַדָּבָ֗ר אֲשֶׁ֤ר דִּבֶּר֙ יִרְמְיָ֣הוּ הַנָּבִ֔יא אֶל־בָּר֖וּךְ בֶּֽן־נֵֽרִיָּ֑ה בְּכָתְבוֹ֩ אֶת־הַדְּבָרִ֨ים הָאֵ֤לֶּה עַל־סֵ֙פֶר֙ מִפִּ֣י יִרְמְיָ֔הוּ בַּשָּׁנָה֙ הָֽרְבִעִ֔ית לִיהוֹיָקִ֧ים בֶּן־יֹאשִׁיָּ֛הוּ מֶ֥לֶךְ יְהוּדָ֖ה לֵאמֹֽר׃ ס"]},{"type":"verse","number":2,"content":["כֹּֽה־אָמַ֥ר יְהוָ֖ה אֱלֹהֵ֣י יִשְׂרָאֵ֑ל עָלֶ֖יךָ בָּרֽוּךְ׃"]},{"type":"verse","number":3,"content":["אָמַ֙רְתָּ֙ אֽוֹי־נָ֣א לִ֔י כִּֽי־יָסַ֧ף יְהוָ֛ה יָג֖וֹן עַל־מַכְאֹבִ֑י יָגַ֙עְתִּי֙ בְּאַנְחָתִ֔י וּמְנוּחָ֖ה לֹ֥א מָצָֽאתִי׃ ס"]},{"type":"verse","number":4,"content":["כֹּ֣ה ׀ תֹּאמַ֣ר אֵלָ֗יו כֹּ֚ה אָמַ֣ר יְהוָ֔ה הִנֵּ֤ה אֲשֶׁר־בָּנִ֙יתִי֙ אֲנִ֣י הֹרֵ֔ס וְאֵ֥ת אֲשֶׁר־נָטַ֖עְתִּי אֲנִ֣י נֹתֵ֑שׁ וְאֶת־כָּל־הָאָ֖רֶץ הִֽיא׃"]},{"type":"verse","number":5,"content":["וְאַתָּ֛ה תְּבַקֶּשׁ־לְךָ֥ גְדֹל֖וֹת אַל־תְּבַקֵּ֑שׁ כִּ֡י הִנְנִי֩ מֵבִ֨יא רָעָ֤ה עַל־כָּל־בָּשָׂר֙ נְאֻם־יְהוָ֔ה וְנָתַתִּ֨י לְךָ֤ אֶֽת־נַפְשְׁךָ֙ לְשָׁלָ֔ל עַ֥ל כָּל־הַמְּקֹמ֖וֹת אֲשֶׁ֥ר תֵּֽלֶךְ־שָֽׁם׃ ס"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/JER/45.json","thisChapterReference":{"translationId":"hbo_wlc","book":"JER","chapter":45},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/JER/46.json","nextChapterReference":{"translationId":"hbo_wlc","book":"JER","chapter":46},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/JER/44.json","previousChapterReference":{"translationId":"hbo_wlc","book":"JER","chapter":44},"previousChapterAudioLinks":{},"numberOfVerses":5}}