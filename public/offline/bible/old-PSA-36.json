{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":36,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. By David, the servant of Yahweh."]},{"type":"verse","number":1,"content":[{"text":"A revelation is within my heart about the disobedience of the wicked:","poem":1},{"text":"There is no fear of God before his eyes.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"For he flatters himself in his own eyes,","poem":1},{"text":"too much to detect and hate his sin.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"The words of his mouth are iniquity and deceit.","poem":1},{"text":"He has ceased to be wise and to do good.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"He plots iniquity on his bed.","poem":1},{"text":"He sets himself in a way that is not good.","poem":2},{"lineBreak":true},{"text":"He doesn’t abhor evil.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"Your loving kindness, Yahweh, is in the heavens.","poem":1},{"text":"Your faithfulness reaches to the skies.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Your righteousness is like the mountains of God.","poem":1},{"text":"Your judgments are like a great deep.","poem":2},{"lineBreak":true},{"text":"Yahweh, you preserve man and animal.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"How precious is your loving kindness, God!","poem":1},{"text":"The children of men take refuge under the shadow of your wings.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"They shall be abundantly satisfied with the abundance of your house.","poem":1},{"text":"You will make them drink of the river of your pleasures.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"For with you is the spring of life.","poem":1},{"text":"In your light we will see light.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Oh continue your loving kindness to those who know you,","poem":1},{"text":"your righteousness to the upright in heart.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Don’t let the foot of pride come against me.","poem":1},{"text":"Don’t let the hand of the wicked drive me away.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"There the workers of iniquity are fallen.","poem":1},{"text":"They are thrust down, and shall not be able to rise.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/36.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":36},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/37.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":37},"nextChapterAudioLinks":{},"previou