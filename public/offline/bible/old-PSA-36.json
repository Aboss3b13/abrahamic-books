"content":["יְ֭הוָה בְּהַשָּׁמַ֣יִם חַסְדֶּ֑ךָ אֱ֝מֽוּנָתְךָ֗ עַד־שְׁחָקִֽים׃"]},{"type":"verse","number":7,"content":["צִדְקָֽתְךָ֨ ׀ כְּֽהַרְרֵי־אֵ֗ל מִ֭שְׁפָּטֶךָ תְּה֣וֹם רַבָּ֑ה אָ֤דָֽם־וּבְהֵמָ֖ה תוֹשִׁ֣יעַ יְהוָֽה׃"]},{"type":"verse","number":8,"content":["מַה־יָּקָ֥ר חַסְדְּךָ֗ אֱלֹ֫הִ֥ים וּבְנֵ֥י אָדָ֑ם בְּצֵ֥ל כְּ֝נָפֶ֗יךָ יֶחֱסָיֽוּן׃"]},{"type":"verse","number":9,"content":["יִ֭רְוְיֻן מִדֶּ֣שֶׁן בֵּיתֶ֑ךָ וְנַ֖חַל עֲדָנֶ֣יךָ תַשְׁקֵֽם׃"]},{"type":"verse","number":10,"content":["כִּֽי־עִ֭מְּךָ מְק֣וֹר חַיִּ֑ים בְּ֝אוֹרְךָ֗ נִרְאֶה־אֽוֹר׃"]},{"type":"verse","number":11,"content":["מְשֹׁ֣ךְ חַ֭סְדְּךָ לְיֹדְעֶ֑יךָ וְ֝צִדְקָֽתְךָ֗ לְיִשְׁרֵי־לֵֽב׃"]},{"type":"verse","number":12,"content":["אַל־תְּ֭בוֹאֵנִי רֶ֣גֶל גַּאֲוָ֑ה וְיַד־רְ֝שָׁעִ֗ים אַל־תְּנִדֵֽנִי׃"]},{"type":"verse","number":13,"content":["שָׁ֣ם נָ֭פְלוּ פֹּ֣עֲלֵי אָ֑וֶן דֹּ֝ח֗וּ וְלֹא־יָ֥כְלוּ קֽוּם׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/36.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":36},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/37.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":37},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/35.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":35},"previousChapterAudioLinks":{},"numberOfVerses":13}}