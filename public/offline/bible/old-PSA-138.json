{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":138,"content":[{"type":"hebrew_subtitle","content":["By David."]},{"type":"verse","number":1,"content":[{"text":"I will give you thanks with my whole heart.","poem":1},{"text":"Before the gods,","poem":2},{"noteId":43},{"text":"I will sing praises to you.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"I will bow down toward your holy temple,","poem":1},{"text":"and give thanks to your Name for your loving kindness and for your truth;","poem":2},{"lineBreak":true},{"text":"for you have exalted your Name and your Word above all.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"In the day that I called, you answered me.","poem":1},{"text":"You encouraged me with strength in my soul.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"All the kings of the earth will give you thanks, Yahweh,","poem":1},{"text":"for they have heard the words of your mouth.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Yes, they will sing of the ways of Yahweh,","poem":1},{"text":"for Yahweh’s glory is great!","poem":2}]},{"type":"verse","number":6,"content":[{"text":"For though Yahweh is high, yet he looks after the lowly;","poem":1},{"text":"but he knows the proud from afar.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Though I walk in the middle of trouble, you will revive me.","poem":1},{"text":"You will stretch out your hand against the wrath of my enemies.","poem":2},{"lineBreak":true},{"text":"Your right hand will save me.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Yahweh will fulfill that which concerns me.","poem":1},{"text":"Your loving kindness, Yahweh, endures forever.","poem":2},{"lineBreak":true},{"text":"Don’t forsake the works of your own hands.","poem":2}]}],"footnotes":[{"noteId":43,"caller":"+","text":"The word elohim, used here, usually means “God” but can also mean “gods”, “princes”, or “angels”.","reference":{"chapter":138,"verse":1}}]},"thisChapterLink":"/api/eng_web/PSA/138.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":138},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/139.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":139},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/137.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":137},"previousChapterAudioLinks":{},"numberOfVerses":8},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leni