ל־תֶּֽרֶף׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/138.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":138},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/139.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":139},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/137.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":137},"previousChapterAudioLinks":{},"numberOfVerses":8}}