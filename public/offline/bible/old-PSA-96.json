ם אֱלִילִ֑ים וַֽ֝יהוָ֗ה שָׁמַ֥יִם עָשָֽׂה׃"]},{"type":"verse","number":6,"content":["הוֹד־וְהָדָ֥ר לְפָנָ֑יו עֹ֥ז וְ֝תִפְאֶ֗רֶת בְּמִקְדָּשֽׁוֹ׃"]},{"type":"verse","number":7,"content":["הָב֣וּ לַ֭יהוָה מִשְׁפְּח֣וֹת עַמִּ֑ים הָב֥וּ לַ֝יהוָ֗ה כָּב֥וֹד וָעֹֽז׃"]},{"type":"verse","number":8,"content":["הָב֣וּ לַ֭יהוָה כְּב֣וֹד שְׁמ֑וֹ שְׂאֽוּ־מִ֝נְחָ֗ה וּבֹ֥אוּ לְחַצְרוֹתָֽיו׃"]},{"type":"verse","number":9,"content":["הִשְׁתַּחֲו֣וּ לַ֭יהוָה בְּהַדְרַת־קֹ֑דֶשׁ חִ֥ילוּ מִ֝פָּנָ֗יו כָּל־הָאָֽרֶץ׃"]},{"type":"verse","number":10,"content":["אִמְר֤וּ בַגּוֹיִ֨ם ׀ יְה֘וָ֤ה מָלָ֗ךְ אַף־תִּכּ֣וֹן תֵּ֭בֵל בַּל־תִּמּ֑וֹט יָדִ֥ין עַ֝מִּ֗ים בְּמֵישָׁרִֽים׃"]},{"type":"verse","number":11,"content":["יִשְׂמְח֣וּ הַ֭שָּׁמַיִם וְתָגֵ֣ל הָאָ֑רֶץ יִֽרְעַ֥ם הַ֝יָּ֗ם וּמְלֹאֽוֹ׃"]},{"type":"verse","number":12,"content":["יַעֲלֹ֣ז שָׂ֭דַי וְכָל־אֲשֶׁר־בּ֑וֹ אָ֥ז יְ֝רַנְּנ֗וּ כָּל־עֲצֵי־יָֽעַר׃"]},{"type":"verse","number":13,"content":["לִפְנֵ֤י יְהוָ֨ה ׀ כִּ֬י בָ֗א כִּ֥י בָא֮ לִשְׁפֹּ֪ט הָ֫אָ֥רֶץ יִשְׁפֹּֽט־תֵּבֵ֥ל בְּצֶ֑דֶק וְ֝עַמִּ֗ים בֶּאֱמוּנָתֽוֹ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/96.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":96},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/97.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":97},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/95.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":95},"previousChapterAudioLinks":{},"numberOfVerses":13}}