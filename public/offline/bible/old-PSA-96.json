{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":96,"content":[{"type":"verse","number":1,"content":[{"text":"Sing to Yahweh a new song!","poem":1},{"text":"Sing to Yahweh, all the earth.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Sing to Yahweh!","poem":1},{"text":"Bless his name!","poem":2},{"lineBreak":true},{"text":"Proclaim his salvation from day to day!","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Declare his glory among the nations,","poem":1},{"text":"his marvelous works among all the peoples.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"For Yahweh is great, and greatly to be praised!","poem":1},{"text":"He is to be feared above all gods.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"For all the gods of the peoples are idols,","poem":1},{"text":"but Yahweh made the heavens.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Honor and majesty are before him.","poem":1},{"text":"Strength and beauty are in his sanctuary.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Ascribe to Yahweh, you families of nations,","poem":1},{"text":"ascribe to Yahweh glory and strength.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Ascribe to Yahweh the glory due to his name.","poem":1},{"text":"Bring an offering, and come into his courts.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Worship Yahweh in holy array.","poem":1},{"text":"Tremble before him, all the earth.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Say among the nations, “Yahweh reigns.”","poem":1},{"text":"The world is also established.","poem":2},{"lineBreak":true},{"text":"It can’t be moved.","poem":2},{"lineBreak":true},{"text":"He will judge the peoples with equity.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Let the heavens be glad, and let the earth rejoice.","poem":1},{"text":"Let the sea roar, and its fullness!","poem":2},{"lineBreak":true}]},{"type":"verse","number":12,"content":[{"text":"Let the field and all that is in it exult!","poem":2},{"lineBreak":true},{"text":"Then all the trees of the woods shall sing for joy","poem":2},{"lineBreak":true}]},{"type":"verse","number":13,"content":[{"text":"before Yahweh; for he comes,","poem":2},{"lineBreak":true},{"text":"for he comes to judge the earth.","poem":2},{"text":"He will judge the world with righteousness,","poem":1},{"text":"the peoples with his truth.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/96.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":96},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/97.json","nextChapterReference":{"translationId":"eng_web",