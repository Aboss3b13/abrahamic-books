{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":91,"content":[{"type":"verse","number":1,"content":[{"text":"He who dwells in the secret place of the Most High","poem":1},{"text":"will rest in the shadow of the Almighty.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"I will say of Yahweh, “He is my refuge and my fortress;","poem":1},{"text":"my God, in whom I trust.”","poem":2}]},{"type":"verse","number":3,"content":[{"text":"For he will deliver you from the snare of the fowler,","poem":1},{"text":"and from the deadly pestilence.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"He will cover you with his feathers.","poem":1},{"text":"Under his wings you will take refuge.","poem":2},{"lineBreak":true},{"text":"His faithfulness is your shield and rampart.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"You shall not be afraid of the terror by night,","poem":1},{"text":"nor of the arrow that flies by day,","poem":2},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"nor of the pestilence that walks in darkness,","poem":2},{"lineBreak":true},{"text":"nor of the destruction that wastes at noonday.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"A thousand may fall at your side,","poem":1},{"text":"and ten thousand at your right hand;","poem":2},{"lineBreak":true},{"text":"but it will not come near you.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"You will only look with your eyes,","poem":1},{"text":"and see the recompense of the wicked.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Because you have made Yahweh your refuge,","poem":1},{"text":"and the Most High your dwelling place,","poem":2}]},{"type":"verse","number":10,"content":[{"text":"no evil shall happen to you,","poem":1},{"text":"neither shall any plague come near your dwelling.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"For he will put his angels in charge of you,","poem":1},{"text":"to guard you in all your ways.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"They will bear you up in their hands,","poem":1},{"text":"so that you won’t dash your foot against a stone.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"You will tread on the lion and cobra.","poem":1},{"text":"You will trample the young lion and the serpent underfoot.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"“Because he has set his love on me, therefore I will deliver him.","poem":1},{"text":"I will set him on high, because he has known my name.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"He will call on me, and I will answer him.","poem":1},{"text":"I will be with him in trouble.","poem":2},{"lineBreak":true},{"text":"I will deliver him, and honor him.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"I will satisfy him with long life,","poem":1},{"text":"and show him my salvation.”","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/91.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":91},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/92.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":92},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/90.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":90},"previousChapterAudioLinks":{},"numberOfVerses":16},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":91,"content":[{"type":"verse","number":1,"content":["יֹ֭שֵׁב בְּסֵ֣תֶר עֶלְי֑וֹן בְּצֵ֥ל שַׁ֝דַּ֗י יִתְלוֹנָֽן׃"]},{"type":"verse","number":2,"content":["אֹמַ֗ר לַֽ֭יהוָה מַחְסִ֣י וּמְצוּדָתִ֑י אֱ֝לֹהַ֗י אֶבְטַח־בּֽוֹ׃"]},{"type":"verse","number":3,"content":["כִּ֤י ה֣וּא יַ֭צִּֽילְךָ מִפַּ֥ח יָק֗וּשׁ מִדֶּ֥בֶר הַוּֽוֹת׃"]},{"type":"verse","number":4,"content":["בְּאֶבְרָת֨וֹ ׀ יָ֣סֶךְ לָ֭ךְ וְתַֽחַת־כְּנָפָ֣יו תֶּחְסֶ֑ה צִנָּ֖ה וְֽסֹחֵרָ֣ה אֲמִתּֽוֹ׃"]},{"type":"verse","number":5,"content":["לֹא־תִ֭ירָא מִפַּ֣חַד לָ֑יְלָה מֵ֝חֵ֗ץ יָע֥וּף יוֹמָֽם׃"]},{"type":"verse","number":6,"content":["מִ֭דֶּבֶר בָּאֹ֣פֶל יַהֲלֹ֑ךְ מִ֝קֶּ֗טֶב יָשׁ֥וּד צָהֳרָֽיִם׃"]},{"type":"verse","number":7,"content":["יִפֹּ֤ל מִצִּדְּךָ֨ ׀ אֶ֗לֶף וּרְבָבָ֥ה מִימִינֶ֑ךָ אֵ֝לֶ֗יךָ לֹ֣א יִגָּֽשׁ׃"]},{"type":"verse","number":8,"content":["רַ֭ק בְּעֵינֶ֣יךָ תַבִּ֑יט וְשִׁלֻּמַ֖ת רְשָׁעִ֣ים תִּרְאֶֽה׃"]},{"type":"verse","number":9,"content":["כִּֽי־אַתָּ֣ה יְהוָ֣ה מַחְסִ֑י עֶ֝לְי֗וֹן שַׂ֣מְתָּ מְעוֹנֶֽךָ׃"]},{"type":"verse","number":10,"content":["לֹֽא־תְאֻנֶּ֣ה אֵלֶ֣יךָ רָעָ֑ה וְ֝נֶ֗גַע לֹא־יִקְרַ֥ב בְּאָהֳלֶֽךָ׃"]},{"type":"verse","number":11,"content":["כִּ֣י מַ֭לְאָכָיו יְצַוֶּה־לָּ֑ךְ לִ֝שְׁמָרְךָ֗ בְּכָל־דְּרָכֶֽיךָ׃"]},{"type":"verse","number":12,"content":["עַל־כַּפַּ֥יִם יִשָּׂא֑וּנְךָ פֶּן־תִּגֹּ֖ף בָּאֶ֣בֶן רַגְלֶֽךָ׃"]},{"type":"verse","number":13,"content":["עַל־שַׁ֣חַל וָפֶ֣תֶן תִּדְרֹ֑ךְ תִּרְמֹ֖ס כְּפִ֣יר וְתַנִּֽין׃"]},{"type":"verse","number":14,"content":["כִּ֤י בִ֣י חָ֭שַׁק וַאֲפַלְּטֵ֑הוּ אֲ֝שַׂגְּבֵ֗הוּ כִּֽי־יָדַ֥ע שְׁמִֽי׃"]},{"type":"verse","number":15,"content":["יִקְרָאֵ֨נִי ׀ וְֽאֶעֱנֵ֗הוּ עִמּֽוֹ־אָנֹכִ֥י בְצָרָ֑ה אֲ֝חַלְּצֵ֗הוּ וַֽאֲכַבְּדֵֽהוּ׃"]},{"type":"verse","number":16,"content":["אֹ֣רֶךְ יָ֭מִים אַשְׂבִּיעֵ֑הוּ וְ֝אַרְאֵ֗הוּ בִּֽישׁוּעָתִֽי׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/91.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":91},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/92.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":92},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/90.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":90},"previousChapterAudioLinks":{},"numberOfVerses":16}}