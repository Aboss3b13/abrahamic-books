{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":141,"content":[{"type":"hebrew_subtitle","content":["A Psalm by David."]},{"type":"verse","number":1,"content":[{"text":"Yahweh, I have called on you.","poem":1},{"text":"Come to me quickly!","poem":2},{"lineBreak":true},{"text":"Listen to my voice when I call to you.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Let my prayer be set before you like incense;","poem":1},{"text":"the lifting up of my hands like the evening sacrifice.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Set a watch, Yahweh, before my mouth.","poem":1},{"text":"Keep the door of my lips.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Don’t incline my heart to any evil thing,","poem":1},{"text":"to practice deeds of wickedness with men who work iniquity.","poem":2},{"lineBreak":true},{"text":"Don’t let me eat of their delicacies.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Let the righteous strike me, it is kindness;","poem":1},{"text":"let him reprove me, it is like oil on the head;","poem":2},{"lineBreak":true},{"text":"don’t let my head refuse it;","poem":2},{"lineBreak":true},{"text":"Yet my prayer is always against evil deeds.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Their judges are thrown down by the sides of the rock.","poem":1},{"text":"They will hear my words, for they are well spoken.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"“As when one plows and breaks up the earth,","poem":1},{"text":"our bones are scattered at the mouth of Sheol.”","poem":2},{"noteId":45}]},{"type":"verse","number":8,"content":[{"text":"For my eyes are on you, Yahweh, the Lord.","poem":1},{"text":"I take refuge in you.","poem":2},{"lineBreak":true},{"text":"Don’t leave my soul destitute.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Keep me from the snare which they have laid for me,","poem":1},{"text":"from the traps of the workers of iniquity.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Let the wicked fall together into their own nets","poem":1},{"text":"while I pass by.","poem":2}]}],"footnotes":[{"noteId":45,"caller":"+","text":"Sheol is the place of the dead.","reference":{"chapter":141,"verse":7}}]},"thisChapterLink":"/api/eng_web/PSA/141.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":141},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/142.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":142},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/140.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":140},"previousChapterAu