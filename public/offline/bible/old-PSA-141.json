er":6,"content":["נִשְׁמְט֣וּ בִֽידֵי־סֶ֭לַע שֹׁפְטֵיהֶ֑ם וְשָׁמְע֥וּ אֲ֝מָרַ֗י כִּ֣י נָעֵֽמוּ׃"]},{"type":"verse","number":7,"content":["כְּמ֤וֹ פֹלֵ֣חַ וּבֹקֵ֣עַ בָּאָ֑רֶץ נִפְזְר֥וּ עֲ֝צָמֵ֗ינוּ לְפִ֣י שְׁאֽוֹל׃"]},{"type":"verse","number":8,"content":["כִּ֤י אֵלֶ֨יךָ ׀ יְהֹוִ֣ה אֲדֹנָ֣י עֵינָ֑י בְּכָ֥ה חָ֝סִ֗יתִי אַל־תְּעַ֥ר נַפְשִֽׁי׃"]},{"type":"verse","number":9,"content":["שָׁמְרֵ֗נִי מִ֣ידֵי פַ֭ח יָ֣קְשׁוּ לִ֑י וּ֝מֹקְשׁ֗וֹת פֹּ֣עֲלֵי אָֽוֶן׃"]},{"type":"verse","number":10,"content":["יִפְּל֣וּ בְמַכְמֹרָ֣יו רְשָׁעִ֑ים יַ֥חַד אָ֝נֹכִ֗י עַֽד־אֶעֱבֽוֹר׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/141.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":141},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/142.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":142},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/140.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":140},"previousChapterAudioLinks":{},"numberOfVerses":10}}