{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":116,"content":[{"type":"verse","number":1,"content":[{"text":"I love Yahweh, because he listens to my voice,","poem":1},{"text":"and my cries for mercy.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Because he has turned his ear to me,","poem":1},{"text":"therefore I will call on him as long as I live.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"The cords of death surrounded me,","poem":1},{"text":"the pains of Sheol","poem":2},{"noteId":41},{"text":"got a hold of me.","poem":2},{"lineBreak":true},{"text":"I found trouble and sorrow.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Then I called on Yahweh’s name:","poem":1},{"text":"“Yahweh, I beg you, deliver my soul.”","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Yahweh is gracious and righteous.","poem":1},{"text":"Yes, our God is merciful.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Yahweh preserves the simple.","poem":1},{"text":"I was brought low, and he saved me.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Return to your rest, my soul,","poem":1},{"text":"for Yahweh has dealt bountifully with you.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"For you have delivered my soul from death,","poem":1},{"text":"my eyes from tears,","poem":2},{"lineBreak":true},{"text":"and my feet from falling.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"I will walk before Yahweh in the land of the living.","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"I believed, therefore I said,","poem":1},{"text":"“I was greatly afflicted.”","poem":2}]},{"type":"verse","number":11,"content":[{"text":"I said in my haste,","poem":1},{"text":"“All people are liars.”","poem":2}]},{"type":"verse","number":12,"content":[{"text":"What will I give to Yahweh for all his benefits toward me?","poem":1}]},{"type":"verse","number":13,"content":[{"text":"I will take the cup of salvation, and call on Yahweh’s name.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"I will pay my vows to Yahweh,","poem":1},{"text":"yes, in the presence of all his people.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Precious in Yahweh’s sight is the death of his saints.","poem":1},{"lineBreak":true}]},{"type":"verse","number":16,"content":[{"text":"Yahweh, truly I am your servant.","poem":1},{"text":"I am your servant, the son of your servant girl.","poem":2},{"lineBreak":true},{"text":"You have freed me from my chains.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"I will offer to you the sacrifice of thanksgiving,","poem":1},{"text":"and will call on Yahweh’s name.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"I will pay my vows to Yahweh,","poem":1},{"text":"yes, in the presence of all his people,","poem":2}]},{"type":"verse","number":19,"content":[{"text":"in the courts of Yahweh’s house,","poem":1},{"text":"in the middle of you, Jerusalem.","poem":2},{"text":"Praise Yah!","poem":1}]}],"footnotes":[{"noteId":41,"caller":"+","text":"Sheol is the place of the dead.","reference":{"chapter":116,"verse":3}}]},"thisChapterLink":"/api/eng_web/PSA/116.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":116},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/117.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":117},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/115.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":115},"previousChapterAudioLinks":{},"numberOfVerses":19},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":116,"content":[{"type":"verse","number":1,"content":["אָ֭הַבְתִּי כִּֽי־יִשְׁמַ֥ע ׀ יְהוָ֑ה אֶת־ק֝וֹלִ֗י תַּחֲנוּנָֽי׃"]},{"type":"verse","number":2,"content":["כִּֽי־הִטָּ֣ה אָזְנ֣וֹ לִ֑י וּבְיָמַ֥י אֶקְרָֽא׃"]},{"type":"verse","number":3,"content":["אֲפָפ֤וּנִי ׀ חֶבְלֵי־מָ֗וֶת וּמְצָרֵ֣י שְׁא֣וֹל מְצָא֑וּנִי צָרָ֖ה וְיָג֣וֹן אֶמְצָֽא׃"]},{"type":"verse","number":4,"content":["וּבְשֵֽׁם־יְהוָ֥ה אֶקְרָ֑א אָנָּ֥ה יְ֝הוָ֗ה מַלְּטָ֥ה נַפְשִֽׁי׃"]},{"type":"verse","number":5,"content":["חַנּ֣וּן יְהֹוָ֣ה וְצַדִּ֑יק וֵ֖אלֹהֵ֣ינוּ מְרַחֵֽם׃"]},{"type":"verse","number":6,"content":["שֹׁמֵ֣ר פְּתָאיִ֣ם יְהֹוָ֑ה דַּ֝לּוֹתִ֗י וְלִ֣י יְהוֹשִֽׁיעַ׃"]},{"type":"verse","number":7,"content":["שׁוּבִ֣י נַ֭פְשִׁי לִמְנוּחָ֑יְכִי כִּֽי־יְ֝הוָ֗ה גָּמַ֥ל עָלָֽיְכִי׃"]},{"type":"verse","number":8,"content":["כִּ֤י חִלַּ֥צְתָּ נַפְשִׁ֗י מִ֫מָּ֥וֶת אֶת־עֵינִ֥י מִן־דִּמְעָ֑ה אֶת־רַגְלִ֥י מִדֶּֽחִי׃"]},{"type":"verse","number":9,"content":["אֶ֭תְהַלֵּךְ לִפְנֵ֣י יְהוָ֑ה בְּ֝אַרְצ֗וֹת הַֽחַיִּֽים׃"]},{"type":"verse","number":10,"content":["הֶ֭אֱמַנְתִּי כִּ֣י אֲדַבֵּ֑ר אֲ֝נִ֗י עָנִ֥יתִי מְאֹֽד׃"]},{"type":"verse","number":11,"content":["אֲ֭נִי אָמַ֣רְתִּי בְחָפְזִ֑י כָּֽל־הָאָדָ֥ם כֹּזֵֽב׃"]},{"type":"verse","number":12,"content":["מָֽה־אָשִׁ֥יב לַיהוָ֑ה כָּֽל־תַּגְמוּל֥וֹהִי עָלָֽי׃"]},{"type":"verse","number":13,"content":["כּוֹס־יְשׁוּע֥וֹת אֶשָּׂ֑א וּבְשֵׁ֖ם יְהוָ֣ה אֶקְרָֽא׃"]},{"type":"verse","number":14,"content":["נְ֭דָרַי לַיהוָ֣ה אֲשַׁלֵּ֑ם נֶגְדָה־נָּ֝֗א לְכָל־עַמּֽוֹ׃"]},{"type":"verse","number":15,"content":["יָ֭קָר בְּעֵינֵ֣י יְהוָ֑ה הַ֝מָּ֗וְתָה לַחֲסִידָֽיו׃"]},{"type":"verse","number":16,"content":["אָֽנָּ֣ה יְהוָה֮ כִּֽי־אֲנִ֪י עַ֫בְדֶּ֥ךָ אֲֽנִי־עַ֭בְדְּךָ בֶּן־אֲמָתֶ֑ךָ פִּ֝תַּ֗חְתָּ לְמוֹסֵרָֽי׃"]},{"type":"verse","number":17,"content":["לְֽךָ־אֶ֭זְבַּח זֶ֣בַח תּוֹדָ֑ה וּבְשֵׁ֖ם יְהוָ֣ה אֶקְרָֽא׃"]},{"type":"verse","number":18,"content":["נְ֭דָרַי לַיהוָ֣ה אֲשַׁלֵּ֑ם נֶגְדָה־נָּ֝֗א לְכָל־עַמּֽוֹ׃"]},{"type":"verse","number":19,"content":["בְּחַצְר֤וֹת ׀ בֵּ֤ית יְהוָ֗ה בְּֽת֘וֹכֵ֤כִי יְֽרוּשָׁלִָ֗ם הַֽלְלוּ־יָֽהּ ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/116.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":116},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/117.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":117},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/115.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":115},"previousChapterAudioLinks":{},"numberOfVerses":19}}