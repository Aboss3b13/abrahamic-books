{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":8,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician; on an instrument of Gath. A Psalm by David."]},{"type":"verse","number":1,"content":[{"text":"Yahweh, our Lord, how majestic is your name in all the earth!","poem":1},{"text":"You have set your glory above the heavens!","poem":2}]},{"type":"verse","number":2,"content":[{"text":"From the lips of babes and infants you have established strength,","poem":1},{"text":"because of your adversaries, that you might silence the enemy and the avenger.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"When I consider your heavens, the work of your fingers,","poem":1},{"text":"the moon and the stars, which you have ordained,","poem":2}]},{"type":"verse","number":4,"content":[{"text":"what is man, that you think of him?","poem":1},{"text":"What is the son of man, that you care for him?","poem":2}]},{"type":"verse","number":5,"content":[{"text":"For you have made him a little lower than the angels,","poem":1},{"noteId":7},{"text":"and crowned him with glory and honor.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"You make him ruler over the works of your hands.","poem":1},{"text":"You have put all things under his feet:","poem":2}]},{"type":"verse","number":7,"content":[{"text":"All sheep and cattle,","poem":1},{"text":"yes, and the animals of the field,","poem":2},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"the birds of the sky, the fish of the sea,","poem":2},{"lineBreak":true},{"text":"and whatever passes through the paths of the seas.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Yahweh, our Lord,","poem":1},{"text":"how majestic is your name in all the earth!","poem":2}]}],"footnotes":[{"noteId":7,"caller":"+","text":"Hebrew: Elohim. The word Elohim, used here, usually means “God”, but can also mean “gods”, “princes”, or “angels”. The Septuagint reads “angels” here. See also the quote from the Septuagint in Hebrews 2:7.","reference":{"chapter":8,"verse":5}}]},"thisChapterLink":"/api/eng_web/PSA/8.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":8},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/9.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":9},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/7.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":7},"previousChapterAudioLinks":{},"numberOfVerses":9},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":8,"content":[{"type":"verse","number":1,"content":["לַמְנַצֵּ֥חַ עַֽל־הַגִּתִּ֗ית מִזְמ֥וֹר לְדָוִֽד׃"]},{"type":"verse","number":2,"content":["יְהוָ֤ה אֲדֹנֵ֗ינוּ מָֽה־אַדִּ֣יר שִׁ֭מְךָ בְּכָל־הָאָ֑רֶץ אֲשֶׁ֥ר תְּנָ֥ה ה֝וֹדְךָ֗ עַל־הַשָּׁמָֽיִם׃"]},{"type":"verse","number":3,"content":["מִפִּ֤י עֽוֹלְלִ֨ים ׀ וְֽיֹנְקִים֮ יִסַּ֪דְתָּ֫ עֹ֥ז לְמַ֥עַן צוֹרְרֶ֑יךָ לְהַשְׁבִּ֥ית א֝וֹיֵ֗ב וּמִתְנַקֵּֽם׃"]},{"type":"verse","number":4,"content":["כִּֽי־אֶרְאֶ֣ה שָׁ֭מֶיךָ מַעֲשֵׂ֣י אֶצְבְּעֹתֶ֑יךָ יָרֵ֥חַ וְ֝כוֹכָבִ֗ים אֲשֶׁ֣ר כּוֹנָֽנְתָּה׃"]},{"type":"verse","number":5,"content":["מָֽה־אֱנ֥וֹשׁ כִּֽי־תִזְכְּרֶ֑נּוּ וּבֶן־אָ֝דָ֗ם כִּ֣י תִפְקְדֶֽנּוּ׃"]},{"type":"verse","number":6,"content":["וַתְּחַסְּרֵ֣הוּ מְּ֭עַט מֵאֱלֹהִ֑ים וְכָב֖וֹד וְהָדָ֣ר תְּעַטְּרֵֽהוּ׃"]},{"type":"verse","number":7,"content":["תַּ֭מְשִׁילֵהוּ בְּמַעֲשֵׂ֣י יָדֶ֑יךָ כֹּ֝ל שַׁ֣תָּה תַֽחַת־רַגְלָֽיו׃"]},{"type":"verse","number":8,"content":["צֹנֶ֣ה וַאֲלָפִ֣ים כֻּלָּ֑ם וְ֝גַ֗ם בַּהֲמ֥וֹת שָׂדָֽי׃"]},{"type":"verse","number":9,"content":["צִפּ֣וֹר שָׁ֭מַיִם וּדְגֵ֣י הַיָּ֑ם עֹ֝בֵ֗ר אָרְח֥וֹת יַמִּֽים׃"]},{"type":"verse","number":10,"content":["יְהוָ֥ה אֲדֹנֵ֑ינוּ מָֽה־אַדִּ֥יר שִׁ֝מְךָ֗ בְּכָל־הָאָֽרֶץ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/8.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":8},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/9.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":9},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/7.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":7},"previousChapterAudioLinks":{},"numberOfVerses":10}}