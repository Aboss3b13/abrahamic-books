{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":64,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. A Psalm by David."]},{"type":"verse","number":1,"content":[{"text":"Hear my voice, God, in my complaint.","poem":1},{"text":"Preserve my life from fear of the enemy.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Hide me from the conspiracy of the wicked,","poem":1},{"text":"from the noisy crowd of the ones doing evil;","poem":2}]},{"type":"verse","number":3,"content":[{"text":"who sharpen their tongue like a sword,","poem":1},{"text":"and aim their arrows, deadly words,","poem":2},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"to shoot innocent men from ambushes.","poem":2},{"lineBreak":true},{"text":"They shoot at him suddenly and fearlessly.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"They encourage themselves in evil plans.","poem":1},{"text":"They talk about laying snares secretly.","poem":2},{"lineBreak":true},{"text":"They say, “Who will see them?”","poem":2}]},{"type":"verse","number":6,"content":[{"text":"They plot injustice, saying, “We have made a perfect plan!”","poem":1},{"text":"Surely man’s mind and heart are cunning.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"But God will shoot at them.","poem":1},{"text":"They will be suddenly struck down with an arrow.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Their own tongues shall ruin them.","poem":1},{"text":"All who see them will shake their heads.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"All mankind shall be afraid.","poem":1},{"text":"They shall declare the work of God,","poem":2},{"lineBreak":true},{"text":"and shall wisely ponder what he has done.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"The righteous shall be glad in Yahweh,","poem":1},{"text":"and shall take refuge in him.","poem":2},{"lineBreak":true},{"text":"All the upright in heart shall praise him!","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/64.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":64},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/65.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":65},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/63.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":63},"previousChapterAudioLinks":{},"numberOfVerses":10},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":64,"content":[{"type":"verse","number":1,"content":["לַמְנַצֵּ֗חַ מִזְמ֥וֹר לְדָוִֽד׃"]},{"type":"verse","number":2,"content":["שְׁמַע־אֱלֹהִ֣ים קוֹלִ֣י בְשִׂיחִ֑י מִפַּ֥חַד א֝וֹיֵ֗ב תִּצֹּ֥ר חַיָּֽי׃"]},{"type":"verse","number":3,"content":["תַּ֭סְתִּירֵנִי מִסּ֣וֹד מְרֵעִ֑ים מֵ֝רִגְשַׁ֗ת פֹּ֣עֲלֵי אָֽוֶן׃"]},{"type":"verse","number":4,"content":["אֲשֶׁ֤ר שָׁנְנ֣וּ כַחֶ֣רֶב לְשׁוֹנָ֑ם דָּרְכ֥וּ חִ֝צָּ֗ם דָּבָ֥ר מָֽר׃"]},{"type":"verse","number":5,"content":["לִיר֣וֹת בַּמִּסְתָּרִ֣ים תָּ֑ם פִּתְאֹ֥ם יֹ֝רֻ֗הוּ וְלֹ֣א יִירָֽאוּ׃"]},{"type":"verse","number":6,"content":["יְחַזְּקוּ־לָ֨מוֹ ׀ דָּ֘בָ֤ר רָ֗ע יְֽ֭סַפְּרוּ לִטְמ֣וֹן מוֹקְשִׁ֑ים אָ֝מְר֗וּ מִ֣י יִרְאֶה־לָּֽמוֹ׃"]},{"type":"verse","number":7,"content":["יַֽחְפְּֽשׂוּ־עוֹלֹ֗ת תַּ֭מְנוּ חֵ֣פֶשׂ מְחֻפָּ֑שׂ וְקֶ֥רֶב אִ֝֗ישׁ וְלֵ֣ב עָמֹֽק׃"]},{"type":"verse","number":8,"content":["וַיֹּרֵ֗ם אֱלֹ֫הִ֥ים חֵ֥ץ פִּתְא֑וֹם הָ֝י֗וּ מַכּוֹתָֽם׃"]},{"type":"verse","number":9,"content":["וַיַּכְשִׁיל֣וּהוּ עָלֵ֣ימוֹ לְשׁוֹנָ֑ם יִ֝תְנֹדֲד֗וּ כָּל־רֹ֥אֵה בָֽם׃"]},{"type":"verse","number":10,"content":["וַיִּֽירְא֗וּ כָּל־אָ֫דָ֥ם וַ֭יַּגִּידוּ פֹּ֥עַל אֱלֹהִ֗ים וּֽמַעֲשֵׂ֥הוּ הִשְׂכִּֽילוּ׃"]},{"type":"verse","number":11,"content":["יִשְׂמַ֬ח צַדִּ֣יק בַּ֭יהוָה וְחָ֣סָה ב֑וֹ וְ֝יִתְהַֽלְל֗וּ כָּל־יִשְׁרֵי־לֵֽב׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/64.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":64},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/65.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":65},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/63.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":63},"previousChapterAudioLinks":{},"numberOfVerses":11}}