{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":52,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. A contemplation by David, when Doeg the Edomite came and told Saul, “David has come to Ahimelech’s house.”"]},{"type":"verse","number":1,"content":[{"text":"Why do you boast of mischief, mighty man?","poem":1},{"text":"God’s loving kindness endures continually.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Your tongue plots destruction,","poem":1},{"text":"like a sharp razor, working deceitfully.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"You love evil more than good,","poem":1},{"text":"lying rather than speaking the truth. Selah.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"You love all devouring words,","poem":1},{"text":"you deceitful tongue.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"God will likewise destroy you forever.","poem":1},{"text":"He will take you up, and pluck you out of your tent,","poem":2},{"lineBreak":true},{"text":"and root you out of the land of the living. Selah.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"The righteous also will see it, and fear,","poem":1},{"text":"and laugh at him, saying,","poem":2}]},{"type":"verse","number":7,"content":[{"text":"“Behold, this is the man who didn’t make God his strength,","poem":1},{"text":"but trusted in the abundance of his riches,","poem":2},{"lineBreak":true},{"text":"and strengthened himself in his wickedness.”","poem":2}]},{"type":"verse","number":8,"content":[{"text":"But as for me, I am like a green olive tree in God’s house.","poem":1},{"text":"I trust in God’s loving kindness forever and ever.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"I will give you thanks forever, because you have done it.","poem":1},{"text":"I will hope in your name, for it is good,","poem":2},{"lineBreak":true},{"text":"in the presence of your saints.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/52.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":52},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/53.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":53},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/51.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":51},"previousChapterAudioLinks":{},"numberOfVerses":9},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":52,"content":[{"type":"verse","number":1,"content":["לַמְנַצֵּ֗חַ מַשְׂכִּ֥יל לְדָוִֽד׃"]},{"type":"verse","number":2,"content":["בְּב֤וֹא ׀ דּוֹאֵ֣ג הָאֲדֹמִי֮ וַיַּגֵּ֪ד לְשָׁ֫א֥וּל וַיֹּ֥אמֶר ל֑וֹ בָּ֥א דָ֝וִ֗ד אֶל־בֵּ֥ית אֲחִימֶֽלֶךְ׃"]},{"type":"verse","number":3,"content":["מַה־תִּתְהַלֵּ֣ל בְּ֭רָעָה הַגִּבּ֑וֹר חֶ֥סֶד אֵ֝֗ל כָּל־הַיּֽוֹם׃"]},{"type":"verse","number":4,"content":["הַ֭וּוֹת תַּחְשֹׁ֣ב לְשׁוֹנֶ֑ךָ כְּתַ֥עַר מְ֝לֻטָּ֗שׁ עֹשֵׂ֥ה רְמִיָּֽה׃"]},{"type":"verse","number":5,"content":["אָהַ֣בְתָּ רָּ֣ע מִטּ֑וֹב שֶׁ֓קֶר ׀ מִדַּבֵּ֖ר צֶ֣דֶק סֶֽלָה׃"]},{"type":"verse","number":6,"content":["אָהַ֥בְתָּ כָֽל־דִּבְרֵי ־בָ֗לַע לְשׁ֣וֹן מִרְמָֽה׃"]},{"type":"verse","number":7,"content":["גַּם־אֵל֮ יִתָּצְךָ֪ לָ֫נֶ֥צַח יַחְתְּךָ֣ וְיִסָּחֲךָ֣ מֵאֹ֑הֶל וְשֵֽׁרֶשְׁךָ֨ מֵאֶ֖רֶץ חַיִּ֣ים סֶֽלָה׃"]},{"type":"verse","number":8,"content":["וְיִרְא֖וּ צַדִּיקִ֥ים וְיִירָ֗אוּ וְעָלָ֥יו יִשְׂחָֽקוּ׃"]},{"type":"verse","number":9,"content":["הִנֵּ֤ה הַגֶּ֗בֶר לֹ֤א יָשִׂ֥ים אֱלֹהִ֗ים מָֽע֫וּזּ֥וֹ וַ֭יִּבְטַח בְּרֹ֣ב עָשְׁר֑וֹ יָ֝עֹ֗ז בְּהַוָּתֽוֹ׃"]},{"type":"verse","number":10,"content":["וַאֲנִ֤י ׀ כְּזַ֣יִת רַ֭עֲנָן בְּבֵ֣ית אֱלֹהִ֑ים בָּטַ֥חְתִּי בְחֶֽסֶד־אֱ֝לֹהִ֗ים עוֹלָ֥ם וָעֶֽד׃"]},{"type":"verse","number":11,"content":["אוֹדְךָ֣ לְ֭עוֹלָם כִּ֣י עָשִׂ֑יתָ וַאֲקַוֶּ֖ה שִׁמְךָ֥ כִֽי־ט֝֗וֹב נֶ֣גֶד חֲסִידֶֽיךָ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/52.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":52},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/53.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":53},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/51.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":51},"previousChapterAudioLinks":{},"numberOfVerses":11}}