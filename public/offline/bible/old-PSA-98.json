{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":98,"content":[{"type":"hebrew_subtitle","content":["A Psalm."]},{"type":"verse","number":1,"content":[{"text":"Sing to Yahweh a new song,","poem":1},{"text":"for he has done marvelous things!","poem":2},{"lineBreak":true},{"text":"His right hand and his holy arm have worked salvation for him.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Yahweh has made known his salvation.","poem":1},{"text":"He has openly shown his righteousness in the sight of the nations.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"He has remembered his loving kindness and his faithfulness toward the house of Israel.","poem":1},{"text":"All the ends of the earth have seen the salvation of our God.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Make a joyful noise to Yahweh, all the earth!","poem":1},{"text":"Burst out and sing for joy, yes, sing praises!","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Sing praises to Yahweh with the harp,","poem":1},{"text":"with the harp and the voice of melody.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"With trumpets and sound of the ram’s horn,","poem":1},{"text":"make a joyful noise before the King, Yahweh.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Let the sea roar with its fullness;","poem":1},{"text":"the world, and those who dwell therein.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Let the rivers clap their hands.","poem":1},{"text":"Let the mountains sing for joy together.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Let them sing before Yahweh,","poem":1},{"text":"for he comes to judge the earth.","poem":2},{"text":"He will judge the world with righteousness,","poem":1},{"text":"and the peoples with equity.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/98.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":98},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/99.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":99},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/97.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":97},"previousChapterAudioLinks":{},"numberOfVerses":9},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":98,"content":[{"type":"verse","number":1,"content":["מִזְמ֡וֹר שִׁ֤ירוּ לַֽיהוָ֨ה ׀ שִׁ֣יר חָ֭דָשׁ כִּֽי־נִפְלָא֣וֹת עָשָׂ֑ה הוֹשִֽׁיעָה־לּ֥וֹ יְ֝מִינ֗וֹ וּזְר֥וֹעַ קָדְשֽׁוֹ׃"]},{"type":"verse","number":2,"content":["הוֹדִ֣יעַ יְ֭הוָה יְשׁוּעָת֑וֹ לְעֵינֵ֥י הַ֝גּוֹיִ֗ם גִּלָּ֥ה צִדְקָתֽוֹ׃"]},{"type":"verse","number":3,"content":["זָ֘כַ֤ר חַסְדּ֨וֹ ׀ וֶֽאֱֽמוּנָתוֹ֮ לְבֵ֪ית יִשְׂרָ֫אֵ֥ל רָא֥וּ כָל־אַפְסֵי־אָ֑רֶץ אֵ֝֗ת יְשׁוּעַ֥ת אֱלֹהֵֽינוּ׃"]},{"type":"verse","number":4,"content":["הָרִ֣יעוּ לַֽ֭יהוָה כָּל־הָאָ֑רֶץ פִּצְח֖וּ וְרַנְּנ֣וּ וְזַמֵּֽרוּ׃"]},{"type":"verse","number":5,"content":["זַמְּר֣וּ לַיהוָ֣ה בְּכִנּ֑וֹר בְּ֝כִנּ֗וֹר וְק֣וֹל זִמְרָֽה׃"]},{"type":"verse","number":6,"content":["בַּ֭חֲצֹ֣צְרוֹת וְק֣וֹל שׁוֹפָ֑ר הָ֝רִ֗יעוּ לִפְנֵ֤י ׀ הַמֶּ֬לֶךְ יְהוָֽה׃"]},{"type":"verse","number":7,"content":["יִרְעַ֣ם הַ֭יָּם וּמְלֹא֑וֹ תֵּ֝בֵ֗ל וְיֹ֣שְׁבֵי בָֽהּ׃"]},{"type":"verse","number":8,"content":["נְהָר֥וֹת יִמְחֲאוּ־כָ֑ף יַ֝֗חַד הָרִ֥ים יְרַנֵּֽנוּ׃"]},{"type":"verse","number":9,"content":["לִֽפְֽנֵי־יְהוָ֗ה כִּ֥י בָא֮ לִשְׁפֹּ֪ט הָ֫אָ֥רֶץ יִשְׁפֹּֽט־תֵּבֵ֥ל בְּצֶ֑דֶק וְ֝עַמִּ֗ים בְּמֵישָׁרִֽים׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PS