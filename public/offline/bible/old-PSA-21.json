{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":21,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. A Psalm by David."]},{"type":"verse","number":1,"content":[{"text":"The king rejoices in your strength, Yahweh!","poem":1},{"text":"How greatly he rejoices in your salvation!","poem":2}]},{"type":"verse","number":2,"content":[{"text":"You have given him his heart’s desire,","poem":1},{"text":"and have not withheld the request of his lips. Selah.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"For you meet him with the blessings of goodness.","poem":1},{"text":"You set a crown of fine gold on his head.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"He asked life of you and you gave it to him,","poem":1},{"text":"even length of days forever and ever.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"His glory is great in your salvation.","poem":1},{"text":"You lay honor and majesty on him.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"For you make him most blessed forever.","poem":1},{"text":"You make him glad with joy in your presence.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"For the king trusts in Yahweh.","poem":1},{"text":"Through the loving kindness of the Most High, he shall not be moved.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Your hand will find out all of your enemies.","poem":1},{"text":"Your right hand will find out those who hate you.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"You will make them as a fiery furnace in the time of your anger.","poem":1},{"text":"Yahweh will swallow them up in his wrath.","poem":2},{"lineBreak":true},{"text":"The fire shall devour them.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"You will destroy their descendants from the earth,","poem":1},{"text":"their posterity from among the children of men.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"For they intended evil against you.","poem":1},{"text":"They plotted evil against you which cannot succeed.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"For you will make them turn their back,","poem":1},{"text":"when you aim drawn bows at their face.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Be exalted, Yahweh, in your strength,","poem":1},{"text":"so we will sing and praise your power.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/21.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":21},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/22.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":22},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/20.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":20},"previousChapterAudioLinks":{},"numberOfVerses":13},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":21,"content":[{"type":"verse","number":1,"content":["לַמְנַצֵּ֗חַ מִזְמ֥וֹר לְדָוִֽד׃"]},{"type":"verse","number":2,"content":["יְֽהוָ֗ה בְּעָזְּךָ֥ יִשְׂמַח־מֶ֑לֶךְ וּ֝בִישׁ֥וּעָתְךָ֗ מַה־יגיל מְאֹֽד׃"]},{"type":"verse","number":3,"content":["תַּאֲוַ֣ת לִ֭בּוֹ נָתַ֣תָּה לּ֑וֹ וַאֲרֶ֥שֶׁת שְׂ֝פָתָ֗יו בַּל־מָנַ֥עְתָּ סֶּֽלָה׃"]},{"type":"verse","number":4,"content":["כִּֽי־תְ֭קַדְּמֶנּוּ בִּרְכ֣וֹת ט֑וֹב תָּשִׁ֥ית לְ֝רֹאשׁ֗וֹ עֲטֶ֣רֶת פָּֽז׃"]},{"type":"verse","number":5,"content":["חַיִּ֤ים ׀ שָׁאַ֣ל מִ֭מְּךָ נָתַ֣תָּה לּ֑וֹ אֹ֥רֶךְ יָ֝מִ֗ים עוֹלָ֥ם וָעֶֽד׃"]},{"type":"verse","number":6,"content":["גָּד֣וֹל כְּ֭בוֹדוֹ בִּישׁוּעָתֶ֑ךָ ה֥וֹד וְ֝הָדָר תְּשַׁוֶּ֥ה עָלָֽיו׃"]},{"type":"verse","number":7,"content":["כִּֽי־תְשִׁיתֵ֣הוּ בְרָכ֣וֹת לָעַ֑ד תְּחַדֵּ֥הוּ בְ֝שִׂמְחָ֗ה אֶת־פָּנֶֽיךָ׃"]},{"type":"verse","number":8,"content":["כִּֽי־הַ֭מֶּלֶךְ בֹּטֵ֣חַ בַּיהוָ֑ה וּבְחֶ֥סֶד עֶ֝לְי֗וֹן בַּל־יִמּֽוֹט׃"]},{"type":"verse","number":9,"content":["תִּמְצָ֣א יָ֭דְךָ לְכָל־אֹיְבֶ֑יךָ יְ֝מִֽינְךָ תִּמְצָ֥א שֹׂנְאֶֽיךָ׃"]},{"type":"verse","number":10,"content":["תְּשִׁיתֵ֤מוֹ ׀ כְּתַנּ֥וּר אֵשׁ֮ לְעֵ֪ת פָּ֫נֶ֥יךָ יְ֭הוָה בְּאַפּ֣וֹ יְבַלְּעֵ֑ם וְֽתֹאכְלֵ֥ם אֵֽשׁ׃"]},{"type":"verse","number":11,"content":["פִּ֭רְיָמוֹ מֵאֶ֣רֶץ תְּאַבֵּ֑ד וְ֝זַרְעָ֗ם מִבְּנֵ֥י אָדָֽם׃"]},{"type":"verse","number":12,"content":["כִּי־נָט֣וּ עָלֶ֣יךָ רָעָ֑ה חָֽשְׁב֥וּ מְ֝זִמָּ֗ה בַּל־יוּכָֽלוּ׃"]},{"type":"verse","number":13,"content":["כִּ֭י תְּשִׁיתֵ֣מוֹ שֶׁ֑כֶם בְּ֝מֵֽיתָרֶ֗יךָ תְּכוֹנֵ֥ן עַל־פְּנֵיהֶֽם׃"]},{"type":"verse","number":14,"content":["ר֣וּמָה יְהוָ֣ה בְּעֻזֶּ֑ךָ נָשִׁ֥ירָה וּֽ֝נְזַמְּרָה גְּבוּרָתֶֽךָ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/21.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":21},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/22.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":22},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/20.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":20},"previousChapterAudioLinks":{},"numberOfVerses":14}}