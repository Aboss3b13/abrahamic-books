{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":95,"content":[{"type":"verse","number":1,"content":[{"text":"Oh come, let’s sing to Yahweh.","poem":1},{"text":"Let’s shout aloud to the rock of our salvation!","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Let’s come before his presence with thanksgiving.","poem":1},{"text":"Let’s extol him with songs!","poem":2}]},{"type":"verse","number":3,"content":[{"text":"For Yahweh is a great God,","poem":1},{"text":"a great King above all gods.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"In his hand are the deep places of the earth.","poem":1},{"text":"The heights of the mountains are also his.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"The sea is his, and he made it.","poem":1},{"text":"His hands formed the dry land.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Oh come, let’s worship and bow down.","poem":1},{"text":"Let’s kneel before Yahweh, our Maker,","poem":2},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"for he is our God.","poem":2},{"text":"We are the people of his pasture,","poem":1},{"text":"and the sheep in his care.","poem":2},{"text":"Today, oh that you would hear his voice!","poem":1}]},{"type":"verse","number":8,"content":[{"text":"Don’t harden your heart, as at Meribah,","poem":2},{"lineBreak":true},{"text":"as in the day of Massah in the wilderness,","poem":2}]},{"type":"verse","number":9,"content":[{"text":"when your fathers tempted me,","poem":1},{"text":"tested me, and saw my work.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Forty long years I was grieved with that generation,","poem":1},{"text":"and said, “They are a people who err in their heart.","poem":2},{"lineBreak":true},{"text":"They have not known my ways.”","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Therefore I swore in my wrath,","poem":1},{"text":"“They won’t enter into my rest.”","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/95.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":95},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/96.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":96},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/94.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":94},"previousChapterAudioLinks":{},"numberOfVerses":11},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":95,"content":[{"type":"verse","number":1,"content":["לְ֭כוּ נְרַנְּנָ֣ה לַיהוָ֑ה נָ֝רִ֗יעָה לְצ֣וּר יִשְׁעֵֽנוּ׃"]},{"type":"verse","number":2,"content":["נְקַדְּמָ֣ה פָנָ֣יו בְּתוֹדָ֑ה בִּ֝זְמִר֗וֹת נָרִ֥יעַֽ לֽוֹ׃"]},{"type":"verse","number":3,"content":["כִּ֤י אֵ֣ל גָּד֣וֹל יְהוָ֑ה וּמֶ֥לֶךְ גָּ֝ד֗וֹל עַל־כָּל־אֱלֹהִֽים׃"]},{"type":"verse","number":4,"content":["אֲשֶׁ֣ר בְּ֭יָדוֹ מֶחְקְרֵי־אָ֑רֶץ וְתוֹעֲפ֖וֹת הָרִ֣ים לֽוֹ׃"]},{"type":"verse","number":5,"content":["אֲשֶׁר־ל֣וֹ הַ֭יָּם וְה֣וּא עָשָׂ֑הוּ וְ֝יַבֶּ֗שֶׁת יָדָ֥יו יָצָֽרוּ׃"]},{"type":"verse","number":6,"content":["בֹּ֭אוּ נִשְׁתַּחֲוֶ֣ה וְנִכְרָ֑עָה נִ֝בְרְכָ֗ה לִֽפְנֵי־יְהוָ֥ה עֹשֵֽׂנוּ׃"]},{"type":"verse","number":7,"content":["כִּ֘י ה֤וּא אֱלֹהֵ֗ינוּ וַאֲנַ֤חְנוּ עַ֣ם מַ֭רְעִיתוֹ וְצֹ֣אן יָד֑וֹ הַ֝יּ֗וֹם אִֽם־בְּקֹל֥וֹ תִשְׁמָֽעוּ׃"]},{"type":"verse","number":8,"content":["אַל־תַּקְשׁ֣וּ לְ֭בַבְכֶם כִּמְרִיבָ֑ה כְּי֥וֹם מַ֝סָּ֗ה בַּמִּדְבָּֽר׃"]},{"type":"verse","number":9,"content":["אֲשֶׁ֣ר נִ֭סּוּנִי אֲבוֹתֵיכֶ֑ם בְּ֝חָנ֗וּנִי גַּם־רָא֥וּ פָעֳלִֽי׃"]},{"type":"verse","number":10,"content":["אַרְבָּ֘עִ֤ים שָׁנָ֨ה ׀ אָ֘ק֤וּט בְּד֗וֹר וָאֹמַ֗ר עַ֤ם תֹּעֵ֣י לֵבָ֣ב הֵ֑ם וְ֝הֵ֗ם לֹא־יָדְע֥וּ דְרָכָֽי׃"]},{"type":"verse","number":11,"content":["אֲשֶׁר־נִשְׁבַּ֥עְתִּי בְאַפִּ֑י אִם־יְ֝בֹא֗וּן אֶל־מְנוּחָתִֽי׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/95.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":95},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/96.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":96},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/94.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":94},"previousChapterAudioLinks":{},"numberOfVerses":11}}