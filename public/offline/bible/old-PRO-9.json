{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PRO","translationId":"eng_web","name":"Proverbs","commonName":"Proverbs","title":"The Proverbs","order":20,"numberOfChapters":31,"sha256":"6e9a8c52dc41d2a2e236609b5a768cec11fefd85ac4132255680db2c9dd440bb","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PRO/1.json","firstChapterReference":{"translationId":"eng_web","book":"PRO","chapter":1},"lastChapterNumber":31,"lastChapterApiLink":"/api/eng_web/PRO/31.json","lastChapterReference":{"translationId":"eng_web","book":"PRO","chapter":31},"totalNumberOfVerses":915},"chapter":{"number":9,"content":[{"type":"verse","number":1,"content":[{"text":"Wisdom has built her house.","poem":1},{"text":"She has carved out her seven pillars.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"She has prepared her meat.","poem":1},{"text":"She has mixed her wine.","poem":2},{"lineBreak":true},{"text":"She has also set her table.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"She has sent out her maidens.","poem":1},{"text":"She cries from the highest places of the city:","poem":2}]},{"type":"verse","number":4,"content":[{"text":"“Whoever is simple, let him turn in here!”","poem":1},{"text":"As for him who is void of understanding, she says to him,","poem":2}]},{"type":"verse","number":5,"content":[{"text":"“Come, eat some of my bread,","poem":1},{"text":"Drink some of the wine which I have mixed!","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Leave your simple ways, and live.","poem":1},{"text":"Walk in the way of understanding.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"One who corrects a mocker invites insult.","poem":1},{"text":"One who reproves a wicked man invites abuse.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Don’t reprove a scoffer, lest he hate you.","poem":1},{"text":"Reprove a wise person, and he will love you.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Instruct a wise person, and he will be still wiser.","poem":1},{"text":"Teach a righteous person, and he will increase in learning.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"The fear of Yahweh is the beginning of wisdom.","poem":1},{"text":"The knowledge of the Holy One is understanding.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"For by me your days will be multiplied.","poem":1},{"text":"The years of your life will be increased.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"If you are wise, you are wise for yourself.","poem":1},{"text":"If you mock, you alone will bear it.","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"The foolish woman is loud,","poem":1},{"text":"undisciplined, and knows nothing.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"She sits at the door of her house,","poem":1},{"text":"on a seat in the high places of the city,","poem":2}]},{"type":"verse","number":15,"content":[{"text":"to call to those who pass by,","poem":1},{"text":"who go straight on their ways,","poem":2}]},{"type":"verse","number":16,"content":[{"text":"“Whoever is simple, let him turn in here.”","poem":1},{"text":"As for him who is void of understanding, she says to him,","poem":2}]},{"type":"verse","number":17,"content":[{"text":"“Stolen water is sweet.","poem":1},{"text":"Food eaten in secret is pleasant.”","poem":2}]},{"type":"verse","number":18,"content":[{"text":"But he doesn’t know that the departed spirits are there,","poem":1},{"text":"that her guests are in the depths of Sheol.","poem":2},{"noteId":6}]}],"footnotes":[{"noteId":6,"caller":"+","text":"Sheol is the place of the dead.","reference":{"chapter":9,"verse":18}}]},"thisChapterLink":"/api/eng_web/PRO/9.json","thisChapterReference":{"translationId":"eng_web","book":"PRO","chapter":9},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PRO/10.json","nextChapterReference":{"translationId":"eng_web","book":"PRO","chapter":10},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PRO/8.json","previousChapterReference":{"translationId":"eng_web","book":"PRO","chapter":8},"previousChapterAudioLinks":{},"numberOfVerses":18},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PRO","translationId":"hbo_wlc","name":"מִשְׁלֵי","commonName":"מִשְׁלֵי","title":"מִשְׁלֵי","order":20,"numberOfChapters":31,"sha256":"7c1b90327fe2d39695b53e3b31960d876f0e3a26a726bb2fb5b497d4b3fd0190","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PRO/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PRO","chapter":1},"lastChapterNumber":31,"lastChapterApiLink":"/api/hbo_wlc/PRO/31.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PRO","chapter":31},"totalNumberOfVerses":915},"chapter":{"number":9,"content":[{"type":"verse","number":1,"content":["חָ֭כְמוֹת בָּנְתָ֣ה בֵיתָ֑הּ חָצְבָ֖ה עַמּוּדֶ֣יהָ שִׁבְעָֽה׃"]},{"type":"verse","number":2,"content":["טָבְחָ֣ה טִ֭בְחָהּ מָסְכָ֣ה יֵינָ֑הּ אַ֝֗ף עָֽרְכָ֥ה שֻׁלְחָנָֽהּ׃"]},{"type":"verse","number":3,"content":["שָֽׁלְחָ֣ה נַעֲרֹתֶ֣יהָ תִקְרָ֑א עַל־גַּ֝פֵּ֗י מְרֹ֣מֵי קָֽרֶת׃"]},{"type":"verse","number":4,"content":["מִי־פֶ֭תִי יָסֻ֣ר הֵ֑נָּה חֲסַר־לֵ֝֗ב אָ֣מְרָה לּֽוֹ׃"]},{"type":"verse","number":5,"content":["לְ֭כוּ לַחֲמ֣וּ בְֽלַחֲמִ֑י וּ֝שְׁת֗וּ בְּיַ֣יִן מָסָֽכְתִּי׃"]},{"type":"verse","number":6,"content":["עִזְב֣וּ פְתָאיִ֣ם וִֽחְי֑וּ וְ֝אִשְׁר֗וּ בְּדֶ֣רֶךְ בִּינָֽה׃"]},{"type":"verse","number":7,"content":["יֹ֤סֵ֨ר ׀ לֵ֗ץ לֹקֵ֣חַֽ ל֣וֹ קָל֑וֹן וּמוֹכִ֖יחַ לְרָשָׁ֣ע מוּמֽוֹ׃"]},{"type":"verse","number":8,"content":["אַל־תּ֣וֹכַח לֵ֭ץ פֶּן־יִשְׂנָאֶ֑ךָּ הוֹכַ֥ח לְ֝חָכָ֗ם וְיֶאֱהָבֶֽךָּ׃"]},{"type":"verse","number":9,"content":["תֵּ֣ן לְ֭חָכָם וְיֶחְכַּם־ע֑וֹד הוֹדַ֥ע לְ֝צַדִּ֗יק וְי֣וֹסֶף לֶֽקַח׃ פ"]},{"type":"verse","number":10,"content":["תְּחִלַּ֣ת חָ֭כְמָה יִרְאַ֣ת יְהוָ֑ה וְדַ֖עַת קְדֹשִׁ֣ים בִּינָֽה׃"]},{"type":"verse","number":11,"content":["כִּי־בִ֭י יִרְבּ֣וּ יָמֶ֑יךָ וְיוֹסִ֥יפוּ לְּ֝ךָ֗ שְׁנ֣וֹת חַיִּֽים׃"]},{"type":"verse","number":12,"content":["אִם־חָ֭כַמְתָּ חָכַ֣מְתָּ לָּ֑ךְ וְ֝לַ֗צְתָּ לְֽבַדְּךָ֥ תִשָּֽׂא׃"]},{"type":"verse","number":13,"content":["אֵ֣שֶׁת כְּ֭סִילוּת הֹֽמִיָּ֑ה פְּ֝תַיּ֗וּת וּבַל־יָ֥דְעָה מָּֽה׃"]},{"type":"verse","number":14,"content":["וְֽ֭יָשְׁבָה לְפֶ֣תַח בֵּיתָ֑הּ עַל־כִּ֝סֵּ֗א מְרֹ֣מֵי קָֽרֶת׃"]},{"type":"verse","number":15,"content":["לִקְרֹ֥א לְעֹֽבְרֵי־דָ֑רֶךְ הַֽ֝מְיַשְּׁרִ֗ים אֹֽרְחוֹתָֽם׃"]},{"type":"verse","number":16,"content":["מִי־פֶ֭תִי יָסֻ֣ר הֵ֑נָּה וַחֲסַר־לֵ֝֗ב וְאָ֣מְרָה לּֽוֹ׃"]},{"type":"verse","number":17,"content":["מַֽיִם־גְּנוּבִ֥ים יִמְתָּ֑קוּ וְלֶ֖חֶם סְתָרִ֣ים יִנְעָֽם׃"]},{"type":"verse","number":18,"content":["וְֽלֹא־יָ֭דַע כִּֽי־רְפָאִ֣ים שָׁ֑ם בְּעִמְקֵ֖י שְׁא֣וֹל קְרֻאֶֽיהָ׃ פ"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PRO/9.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PRO","chapter":9},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PRO/10.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PRO","chapter":10},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PRO/8.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PRO","chapter":8},"previousChapterAudioLinks":{},"numberOfVerses":18}}