{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":111,"content":[{"type":"verse","number":1,"content":[{"text":"Praise Yah!","poem":1},{"noteId":39},{"text":"I will give thanks to Yahweh with my whole heart,","poem":2},{"lineBreak":true},{"text":"in the council of the upright, and in the congregation.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Yahweh’s works are great,","poem":1},{"text":"pondered by all those who delight in them.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"His work is honor and majesty.","poem":1},{"text":"His righteousness endures forever.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"He has caused his wonderful works to be remembered.","poem":1},{"text":"Yahweh is gracious and merciful.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"He has given food to those who fear him.","poem":1},{"text":"He always remembers his covenant.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"He has shown his people the power of his works,","poem":1},{"text":"in giving them the heritage of the nations.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"The works of his hands are truth and justice.","poem":1},{"text":"All his precepts are sure.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"They are established forever and ever.","poem":1},{"text":"They are done in truth and uprightness.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"He has sent redemption to his people.","poem":1},{"text":"He has ordained his covenant forever.","poem":2},{"lineBreak":true},{"text":"His name is holy and awesome!","poem":2}]},{"type":"verse","number":10,"content":[{"text":"The fear of Yahweh is the beginning of wisdom.","poem":1},{"text":"All those who do his work have a good understanding.","poem":2},{"text":"His praise endures forever!","poem":1}]}],"footnotes":[{"noteId":39,"caller":"+","text":"Psalm 111 is an acrostic poem, with each verse after the initial “Praise Yah!” starting with a letter of the alphabet (ordered from Alef to Tav).","reference":{"chapter":111,"verse":1}}]},"thisChapterLink":"/api/eng_web/PSA/111.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":111},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/112.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":112},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/110.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":110},"previousChapterAudioLinks":{},"numberOfVerses":10},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","lice