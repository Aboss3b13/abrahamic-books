׀ שָׁ֘לַ֤ח לְעַמּ֗וֹ צִוָּֽה־לְעוֹלָ֥ם בְּרִית֑וֹ קָד֖וֹשׁ וְנוֹרָ֣א שְׁמֽוֹ׃"]},{"type":"verse","number":10,"content":["רֵ֘אשִׁ֤ית חָכְמָ֨ה ׀ יִרְאַ֬ת יְהוָ֗ה שֵׂ֣כֶל ט֭וֹב לְכָל־עֹשֵׂיהֶ֑ם תְּ֝הִלָּת֗וֹ עֹמֶ֥דֶת לָעַֽד׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/111.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":111},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/112.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":112},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/110.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":110},"previousChapterAudioLinks":{},"numberOfVerses":10}}