{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":41,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. A Psalm by David."]},{"type":"verse","number":1,"content":[{"text":"Blessed is he who considers the poor.","poem":1},{"text":"Yahweh will deliver him in the day of evil.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Yahweh will preserve him, and keep him alive.","poem":1},{"text":"He shall be blessed on the earth,","poem":2},{"lineBreak":true},{"text":"and he will not surrender him to the will of his enemies.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Yahweh will sustain him on his sickbed,","poem":1},{"text":"and restore him from his bed of illness.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"I said, “Yahweh, have mercy on me!","poem":1},{"text":"Heal me, for I have sinned against you.”","poem":2}]},{"type":"verse","number":5,"content":[{"text":"My enemies speak evil against me:","poem":1},{"text":"“When will he die, and his name perish?”","poem":2}]},{"type":"verse","number":6,"content":[{"text":"If he comes to see me, he speaks falsehood.","poem":1},{"text":"His heart gathers iniquity to itself.","poem":2},{"lineBreak":true},{"text":"When he goes abroad, he tells it.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"All who hate me whisper together against me.","poem":1},{"text":"They imagine the worst for me.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"“An evil disease”, they say, “has afflicted him.","poem":1},{"text":"Now that he lies he shall rise up no more.”","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Yes, my own familiar friend, in whom I trusted,","poem":1},{"text":"who ate bread with me,","poem":2},{"lineBreak":true},{"text":"has lifted up his heel against me.","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"But you, Yahweh, have mercy on me, and raise me up,","poem":1},{"text":"that I may repay them.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"By this I know that you delight in me,","poem":1},{"text":"because my enemy doesn’t triumph over me.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"As for me, you uphold me in my integrity,","poem":1},{"text":"and set me in your presence forever.","poem":2}]},{"type":"line_break"},{"type":"verse","number":13,"content":[{"text":"Blessed be Yahweh, the God of Israel,","poem":1},{"text":"from everlasting and to everlasting!","poem":2},{"text":"Amen and amen.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/41.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":41},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/42.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":42},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/40.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":40},"previousChapterAudioLinks":{},"numberOfVerses":13},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":41,"content":[{"type":"verse","number":1,"content":["לַמְנַצֵּ֗חַ מִזְמ֥וֹר לְדָוִֽד׃"]},{"type":"verse","number":2,"content":["אַ֭שְׁרֵי מַשְׂכִּ֣יל אֶל־דָּ֑ל בְּי֥וֹם רָ֝עָ֗ה יְֽמַלְּטֵ֥הוּ יְהוָֽה׃"]},{"type":"verse","number":3,"content":["יְהוָ֤ה ׀ יִשְׁמְרֵ֣הוּ וִֽ֭יחַיֵּהוּ יאשר בָּאָ֑רֶץ וְאַֽל־תִּ֝תְּנֵ֗הוּ בְּנֶ֣פֶשׁ אֹיְבָֽיו׃"]},{"type":"verse","number":4,"content":["יְֽהוָ֗ה יִ֭סְעָדֶנּוּ עַל־עֶ֣רֶשׂ דְּוָ֑י כָּל־מִ֝שְׁכָּב֗וֹ הָפַ֥כְתָּ בְחָלְיֽוֹ׃"]},{"type":"verse","number":5,"content":["אֲֽנִי־אָ֭מַרְתִּי יְהוָ֣ה חָנֵּ֑נִי רְפָאָ֥ה נַ֝פְשִׁ֗י כִּי־חָטָ֥אתִי לָֽךְ׃"]},{"type":"verse","number":6,"content":["אוֹיְבַ֗י יֹאמְר֣וּ רַ֣ע לִ֑י מָתַ֥י יָ֝מ֗וּת וְאָבַ֥ד שְׁמֽוֹ׃"]},{"type":"verse","number":7,"content":["וְאִם־בָּ֤א לִרְא֨וֹת ׀ שָׁ֤וְא יְדַבֵּ֗ר לִבּ֗וֹ יִקְבָּץ־אָ֥וֶן ל֑וֹ יֵצֵ֖א לַח֣וּץ יְדַבֵּֽר׃"]},{"type":"verse","number":8,"content":["יַ֗חַד עָלַ֣י יִ֭תְלַחֲשׁוּ כָּל־שֹׂנְאָ֑י עָלַ֓י ׀ יַחְשְׁב֖וּ רָעָ֣ה לִֽי׃"]},{"type":"verse","number":9,"content":["דְּֽבַר־בְּ֭לִיַּעַל יָצ֣וּק בּ֑וֹ וַאֲשֶׁ֥ר שָׁ֝כַ֗ב לֹא־יוֹסִ֥יף לָקֽוּם׃"]},{"type":"verse","number":10,"content":["גַּם־אִ֤ישׁ שְׁלוֹמִ֨י ׀ אֲשֶׁר־בָּטַ֣חְתִּי ב֭וֹ אוֹכֵ֣ל לַחְמִ֑י הִגְדִּ֖יל עָלַ֣י עָקֵֽב׃"]},{"type":"verse","number":11,"content":["וְאַתָּ֤ה יְהוָ֗ה חָנֵּ֥נִי וַהֲקִימֵ֑נִי וַֽאֲשַׁלְּמָ֥ה לָהֶֽם׃"]},{"type":"verse","number":12,"content":["בְּזֹ֣את יָ֭דַעְתִּי כִּֽי־חָפַ֣צְתָּ בִּ֑י כִּ֤י לֹֽא־יָרִ֖יעַ אֹיְבִ֣י עָלָֽי׃"]},{"type":"verse","number":13,"content":["וַאֲנִ֗י בְּ֭תֻמִּי תָּמַ֣כְתָּ בִּ֑י וַתַּצִּיבֵ֖נִי לְפָנֶ֣יךָ לְעוֹלָֽם׃"]},{"type":"verse","number":14,"content":["בָּ֘ר֤וּךְ יְהוָ֨ה ׀ אֱלֹ֘הֵ֤י יִשְׂרָאֵ֗ל מֵֽ֭הָעוֹלָם וְעַ֥ד הָעוֹלָ֗ם אָ֘מֵ֥ן ׀ וְאָמֵֽן׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/41.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":41},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/42.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":42},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/40.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":40},"previousChapterAudioLinks":{},"numberOfVerses":14}}