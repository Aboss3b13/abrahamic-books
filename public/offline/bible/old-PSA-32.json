{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":32,"content":[{"type":"hebrew_subtitle","content":["By David. A contemplative psalm."]},{"type":"verse","number":1,"content":[{"text":"Blessed is he whose disobedience is forgiven,","poem":1},{"text":"whose sin is covered.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Blessed is the man to whom Yahweh doesn’t impute iniquity,","poem":1},{"text":"in whose spirit there is no deceit.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"When I kept silence, my bones wasted away through my groaning all day long.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"For day and night your hand was heavy on me.","poem":1},{"text":"My strength was sapped in the heat of summer. Selah.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"I acknowledged my sin to you.","poem":1},{"text":"I didn’t hide my iniquity.","poem":2},{"text":"I said, I will confess my transgressions to Yahweh,","poem":1},{"text":"and you forgave the iniquity of my sin. Selah.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"For this, let everyone who is godly pray to you in a time when you may be found.","poem":1},{"text":"Surely when the great waters overflow, they shall not reach to him.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"You are my hiding place.","poem":1},{"text":"You will preserve me from trouble.","poem":2},{"lineBreak":true},{"text":"You will surround me with songs of deliverance. Selah.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"I will instruct you and teach you in the way which you shall go.","poem":1},{"text":"I will counsel you with my eye on you.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Don’t be like the horse, or like the mule, which have no understanding,","poem":1},{"text":"who are controlled by bit and bridle, or else they will not come near to you.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Many sorrows come to the wicked,","poem":1},{"text":"but loving kindness shall surround him who trusts in Yahweh.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Be glad in Yahweh, and rejoice, you righteous!","poem":1},{"text":"Shout for joy, all you who are upright in heart!","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/32.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":32},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/33.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":33},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/31.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":31},"previousChapterAudioLinks":{},"numberOfVerses":11},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":32,"content":[{"type":"verse","number":1,"content":["לְדָוִ֗ד מַ֫שְׂכִּ֥יל אַשְׁרֵ֥י נְֽשׂוּי־פֶּ֗שַׁע כְּס֣וּי חֲטָאָֽה׃"]},{"type":"verse","number":2,"content":["אַ֥שְֽׁרֵי אָדָ֗ם לֹ֤א יַחְשֹׁ֬ב יְהוָ֣ה ל֣וֹ עָוֺ֑ן וְאֵ֖ין בְּרוּח֣וֹ רְמִיָּה׃"]},{"type":"verse","number":3,"content":["כִּֽי־הֶ֭חֱרַשְׁתִּי בָּל֣וּ עֲצָמָ֑י בְּ֝שַׁאֲגָתִ֗י כָּל־הַיּֽוֹם ׃"]},{"type":"verse","number":4,"content":["כִּ֤י ׀ יוֹמָ֣ם וָלַיְלָה֮ תִּכְבַּ֥ד עָלַ֗י יָ֫דֶ֥ךָ נֶהְפַּ֥ךְ לְשַׁדִּ֑י בְּחַרְבֹ֖נֵי קַ֣יִץ סֶֽלָה׃"]},{"type":"verse","number":5,"content":["חַטָּאתִ֨י אוֹדִ֪יעֲךָ֡ וַעֲוֺ֘נִ֤י לֹֽא־כִסִּ֗יתִי אָמַ֗רְתִּי אוֹדֶ֤ה עֲלֵ֣י פְ֭שָׁעַי לַיהוָ֑ה וְאַתָּ֨ה נָ֘שָׂ֤אתָ עֲוֺ֖ן חַטָּאתִ֣י סֶֽלָה׃"]},{"type":"verse","number":6,"content":["עַל־זֹ֡את יִתְפַּלֵּ֬ל כָּל־חָסִ֨יד ׀ אֵלֶיךָ֮ לְעֵ֪ת מְ֫צֹ֥א רַ֗ק לְ֭שֵׁטֶף מַ֣יִם רַבִּ֑ים אֵ֝לָ֗יו לֹ֣א יַגִּֽיעוּ׃"]},{"type":"verse","number":7,"content":["אַתָּ֤ה ׀ סֵ֥תֶר לִי֮ מִצַּ֪ר תִּ֫צְּרֵ֥נִי רָנֵּ֥י פַלֵּ֑ט תְּס֖וֹבְבֵ֣נִי סֶֽלָה׃"]},{"type":"verse","number":8,"content":["אַשְׂכִּֽילְךָ֨ ׀ וְֽאוֹרְךָ֗ בְּדֶֽרֶךְ־ז֥וּ תֵלֵ֑ךְ אִֽיעֲצָ֖ה עָלֶ֣יךָ עֵינִֽי׃"]},{"type":"verse","number":9,"content":["אַל־תִּֽהְי֤וּ ׀ כְּס֥וּס כְּפֶרֶד֮ אֵ֤ין הָ֫בִ֥ין בְּמֶֽתֶג־וָרֶ֣סֶן עֶדְי֣וֹ לִבְל֑וֹם בַּ֝֗ל קְרֹ֣ב אֵלֶֽיךָ׃"]},{"type":"verse","number":10,"content":["רַבִּ֥ים מַכְאוֹבִ֗ים לָרָ֫שָׁ֥ע וְהַבּוֹטֵ֥חַ בַּיהוָ֑ה חֶ֝֗סֶד יְסוֹבְבֶֽנּוּ׃"]},{"type":"verse","number":11,"content":["שִׂמְח֬וּ בַֽיהוָ֣ה וְ֭גִילוּ צַדִּיקִ֑ים וְ֝הַרְנִ֗ינוּ כָּל־יִשְׁרֵי־ לֵֽב׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/32.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":32},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/33.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":33},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/31.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":31},"previousChapterAudioLinks":{},"numberOfVerses":11}}