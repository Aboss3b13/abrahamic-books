{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":108,"content":[{"type":"hebrew_subtitle","content":["A Song. A Psalm by David."]},{"type":"verse","number":1,"content":[{"text":"My heart is steadfast, God.","poem":1},{"text":"I will sing and I will make music with my soul.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Wake up, harp and lyre!","poem":1},{"text":"I will wake up the dawn.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"I will give thanks to you, Yahweh, among the nations.","poem":1},{"text":"I will sing praises to you among the peoples.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"For your loving kindness is great above the heavens.","poem":1},{"text":"Your faithfulness reaches to the skies.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Be exalted, God, above the heavens!","poem":1},{"text":"Let your glory be over all the earth.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"That your beloved may be delivered,","poem":1},{"text":"save with your right hand, and answer us.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"God has spoken from his sanctuary: “In triumph,","poem":1},{"text":"I will divide Shechem, and measure out the valley of Succoth.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Gilead is mine. Manasseh is mine.","poem":1},{"text":"Ephraim also is my helmet.","poem":2},{"lineBreak":true},{"text":"Judah is my scepter.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Moab is my wash pot.","poem":1},{"text":"I will toss my sandal on Edom.","poem":2},{"lineBreak":true},{"text":"I will shout over Philistia.”","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Who will bring me into the fortified city?","poem":1},{"text":"Who will lead me to Edom?","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Haven’t you rejected us, God?","poem":1},{"text":"You don’t go out, God, with our armies.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Give us help against the enemy,","poem":1},{"text":"for the help of man is vain.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Through God, we will do valiantly,","poem":1},{"text":"for it is he who will tread down our enemies.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/108.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":108},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/109.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":109},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/107.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":107},"previousChapterAudioLinks":{},"numberOfVerses":13},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":108,"content":[{"type":"verse","number":1,"content":["שִׁ֖יר מִזְמ֣וֹר לְדָוִֽד׃"]},{"type":"verse","number":2,"content":["נָכ֣וֹן לִבִּ֣י אֱלֹהִ֑ים אָשִׁ֥ירָה וַ֝אֲזַמְּרָ֗ה אַף־כְּבוֹדִֽי׃"]},{"type":"verse","number":3,"content":["ע֭וּרָֽה הַנֵּ֥בֶל וְכִנּ֗וֹר אָעִ֥ירָה שָּֽׁחַר׃"]},{"type":"verse","number":4,"content":["אוֹדְךָ֖ בָעַמִּ֥ים ׀ יְהוָ֑ה וַ֝אֲזַמֶּרְךָ֗ בַּל־אֻמִּֽים׃"]},{"type":"verse","number":5,"content":["כִּֽי־גָד֣וֹל מֵֽעַל־שָׁמַ֣יִם חַסְדֶּ֑ךָ וְֽעַד־שְׁחָקִ֥ים אֲמִתֶּֽךָ׃"]},{"type":"verse","number":6,"content":["ר֣וּמָה עַל־שָׁמַ֣יִם אֱלֹהִ֑ים וְעַ֖ל כָּל־הָאָ֣רֶץ כְּבוֹדֶֽךָ׃"]},{"type":"verse","number":7,"content":["לְ֭מַעַן יֵחָלְצ֣וּן יְדִידֶ֑יךָ הוֹשִׁ֖יעָה יְמִֽינְךָ֣ וַעֲנֵֽנִי׃"]},{"type":"verse","number":8,"content":["אֱלֹהִ֤ים ׀ דִּבֶּ֥ר בְּקָדְשׁ֗וֹ אֶעְלֹ֥זָה אֲחַלְּקָ֥ה שְׁכֶ֑ם וְעֵ֖מֶק סֻכּ֣וֹת אֲמַדֵּֽד׃"]},{"type":"verse","number":9,"content":["לִ֤י גִלְעָ֨ד ׀ לִ֤י מְנַשֶּׁ֗ה וְ֭אֶפְרַיִם מָע֣וֹז רֹאשִׁ֑י יְ֝הוּדָ֗ה מְחֹקְקִֽי׃"]},{"type":"verse","number":10,"content":["מוֹאָ֤ב ׀ סִ֬יר רַחְצִ֗י עַל־אֱ֭דוֹם אַשְׁלִ֣יךְ נַעֲלִ֑י עֲלֵֽי־פְ֝לֶ֗שֶׁת אֶתְרוֹעָֽע׃"]},{"type":"verse","number":11,"content":["מִ֣י יֹ֭בִלֵנִי עִ֣יר מִבְצָ֑ר מִ֖י נָחַ֣נִי עַד־אֱדֽוֹם׃"]},{"type":"verse","number":12,"content":["הֲלֹֽא־אֱלֹהִ֥ים זְנַחְתָּ֑נוּ וְֽלֹא־תֵצֵ֥א אֱ֝לֹהִ֗ים בְּצִבְאֹתֵֽינוּ׃"]},{"type":"verse","number":13,"content":["הָֽבָה־לָּ֣נוּ עֶזְרָ֣ת מִצָּ֑ר וְ֝שָׁ֗וְא תְּשׁוּעַ֥ת אָדָֽם׃"]},{"type":"verse","number":14,"content":["בֵּֽאלֹהִ֥ים נַעֲשֶׂה־חָ֑יִל וְ֝ה֗וּא יָב֥וּס צָרֵֽינוּ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/108.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":108},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/109.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":109},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/107.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":107},"previousChapterAudioLinks":{},"numberOfVerses":14}}