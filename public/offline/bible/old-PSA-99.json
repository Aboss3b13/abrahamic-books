 אֱלֹהֵ֗ינוּ וְ֭הִֽשְׁתַּחֲווּ לְהַ֣ר קָדְשׁ֑וֹ כִּֽי־קָ֝ד֗וֹשׁ יְהוָ֥ה אֱלֹהֵֽינוּ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/99.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":99},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/100.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":100},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/98.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":98},"previousChapterAudioLinks":{},"numberOfVerses":9}}