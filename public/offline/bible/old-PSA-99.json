eBreak":true},{"text":"You execute justice and righteousness in Jacob.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Exalt Yahweh our God.","poem":1},{"text":"Worship at his footstool.","poem":2},{"lineBreak":true},{"text":"He is Holy!","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Moses and Aaron were among his priests,","poem":1},{"text":"Samuel was among those who call on his name.","poem":2},{"lineBreak":true},{"text":"They called on Yahweh, and he answered them.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"He spoke to them in the pillar of cloud.","poem":1},{"text":"They kept his testimonies,","poem":2},{"lineBreak":true},{"text":"the statute that he gave them.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"You answered them, Yahweh our God.","poem":1},{"text":"You are a God who forgave them,","poem":2},{"lineBreak":true},{"text":"although you took vengeance for their doings.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Exalt Yahweh, our God.","poem":1},{"text":"Worship at his holy hill,","poem":2},{"lineBreak":true},{"text":"for Yahweh, our God, is holy!","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/99.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":99},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/100.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":100},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/98.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":98},"previousChapterAudioLinks":{},"numberOfVerses":9},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"