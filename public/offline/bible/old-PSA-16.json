{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":16,"content":[{"type":"hebrew_subtitle","content":["A Poem by David."]},{"type":"verse","number":1,"content":[{"text":"Preserve me, God, for I take refuge in you.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"My soul, you have said to Yahweh, “You are my Lord.","poem":1},{"text":"Apart from you I have no good thing.”","poem":2}]},{"type":"verse","number":3,"content":[{"text":"As for the saints who are in the earth,","poem":1},{"text":"they are the excellent ones in whom is all my delight.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"Their sorrows shall be multiplied who give gifts to another god.","poem":1},{"text":"Their drink offerings of blood I will not offer,","poem":2},{"lineBreak":true},{"text":"nor take their names on my lips.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Yahweh assigned my portion and my cup.","poem":1},{"text":"You made my lot secure.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"The lines have fallen to me in pleasant places.","poem":1},{"text":"Yes, I have a good inheritance.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"I will bless Yahweh, who has given me counsel.","poem":1},{"text":"Yes, my heart instructs me in the night seasons.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"I have set Yahweh always before me.","poem":1},{"text":"Because he is at my right hand, I shall not be moved.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Therefore my heart is glad, and my tongue rejoices.","poem":1},{"text":"My body shall also dwell in safety.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"For you will not leave my soul in Sheol,","poem":1},{"noteId":9},{"text":"neither will you allow your holy one to see corruption.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"You will show me the path of life.","poem":1},{"text":"In your presence is fullness of joy.","poem":2},{"text":"In your right hand there are pleasures forever more.","poem":1}]}],"footnotes":[{"noteId":9,"caller":"+","text":"Sheol is the place of the dead.","reference":{"chapter":16,"verse":10}}]},"thisChapterLink":"/api/eng_web/PSA/16.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":16},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/17.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":17},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/15.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":15},"previousChapterAudioLinks":{},"numberOfVerses":11},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":16,"content":[{"type":"verse","number":1,"content":["מִכְתָּ֥ם לְדָוִ֑ד שָֽׁמְרֵ֥נִי אֵ֝֗ל כִּֽי־חָסִ֥יתִי בָֽךְ׃"]},{"type":"verse","number":2,"content":["אָמַ֣רְתְּ לַֽ֭יהוָה אֲדֹנָ֣י אָ֑תָּה ט֝וֹבָתִ֗י בַּל־עָלֶֽיךָ׃"]},{"type":"verse","number":3,"content":["לִ֭קְדוֹשִׁים אֲשֶׁר־בָּאָ֣רֶץ הֵ֑מָּה וְ֝אַדִּירֵ֗י כָּל־חֶפְצִי־בָֽם׃"]},{"type":"verse","number":4,"content":["יִרְבּ֥וּ עַצְּבוֹתָם֮ אַחֵ֪ר מָ֫הָ֥רוּ בַּל־אַסִּ֣יךְ נִסְכֵּיהֶ֣ם מִדָּ֑ם וּֽבַל־אֶשָּׂ֥א אֶת־שְׁ֝מוֹתָ֗ם עַל־שְׂפָתָֽי׃"]},{"type":"verse","number":5,"content":["יְֽהוָ֗ה מְנָת־חֶלְקִ֥י וְכוֹסִ֑י אַ֝תָּ֗ה תּוֹמִ֥יךְ גּוֹרָלִֽי׃"]},{"type":"verse","number":6,"content":["חֲבָלִ֣ים נָֽפְלוּ־לִ֭י בַּנְּעִמִ֑ים אַף־נַ֝חֲלָ֗ת שָֽׁפְרָ֥ה עָלָֽי׃"]},{"type":"verse","number":7,"content":["אֲבָרֵ֗ךְ אֶת־יְ֭הוָה אֲשֶׁ֣ר יְעָצָ֑נִי אַף־לֵ֝יל֗וֹת יִסְּר֥וּנִי כִלְיוֹתָֽי׃"]},{"type":"verse","number":8,"content":["שִׁוִּ֬יתִי יְהוָ֣ה לְנֶגְדִּ֣י תָמִ֑יד כִּ֥י מִֽ֝ימִינִ֗י בַּל־אֶמּֽוֹט׃"]},{"type":"verse","number":9,"content":["לָכֵ֤ן ׀ שָׂמַ֣ח לִ֭בִּי וַיָּ֣גֶל כְּבוֹדִ֑י אַף־בְּ֝שָׂרִ֗י יִשְׁכֹּ֥ן לָבֶֽטַח׃"]},{"type":"verse","number":10,"content":["כִּ֤י ׀ לֹא־תַעֲזֹ֣ב נַפְשִׁ֣י לִשְׁא֑וֹל לֹֽא־תִתֵּ֥ן חֲ֝סִידְךָ֗ לִרְא֥וֹת שָֽׁחַת׃"]},{"type":"verse","number":11,"content":["תּֽוֹדִיעֵנִי֮ אֹ֤רַח חַ֫יִּ֥ים שֹׂ֣בַע שְׂ֭מָחוֹת אֶת־פָּנֶ֑יךָ נְעִמ֖וֹת בִּימִינְךָ֣ נֶֽצַח׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/16.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":16},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/17.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":17},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/15.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":15},"previousChapterAudioLinks":{},"numberOfVerses":11}}