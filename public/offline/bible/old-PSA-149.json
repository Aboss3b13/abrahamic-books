ns the humble with salvation.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Let the saints rejoice in honor.","poem":1},{"text":"Let them sing for joy on their beds.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"May the high praises of God be in their mouths,","poem":1},{"text":"and a two-edged sword in their hand,","poem":2}]},{"type":"verse","number":7,"content":[{"text":"to execute vengeance on the nations,","poem":1},{"text":"and punishments on the peoples;","poem":2}]},{"type":"verse","number":8,"content":[{"text":"to bind their kings with chains,","poem":1},{"text":"and their nobles with fetters of iron;","poem":2}]},{"type":"verse","number":9,"content":[{"text":"to execute on them the written judgment.","poem":1},{"text":"All his saints have this honor.","poem":2},{"text":"Praise Yah!","poem":1}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/149.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":149},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/150.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/148.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":148},"previousChapterAudioLinks":{},"numberOfVerses":9},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","langu