{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":58,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. To the tune of “Do Not Destroy.” A poem by David."]},{"type":"verse","number":1,"content":[{"text":"Do you indeed speak righteousness, silent ones?","poem":1},{"text":"Do you judge blamelessly, you sons of men?","poem":2}]},{"type":"verse","number":2,"content":[{"text":"No, in your heart you plot injustice.","poem":1},{"text":"You measure out the violence of your hands in the earth.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"The wicked go astray from the womb.","poem":1},{"text":"They are wayward as soon as they are born, speaking lies.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Their poison is like the poison of a snake,","poem":1},{"text":"like a deaf cobra that stops its ear,","poem":2},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"which doesn’t listen to the voice of charmers,","poem":2},{"lineBreak":true},{"text":"no matter how skillful the charmer may be.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Break their teeth, God, in their mouth.","poem":1},{"text":"Break out the great teeth of the young lions, Yahweh.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Let them vanish like water that flows away.","poem":1},{"text":"When they draw the bow, let their arrows be made blunt.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Let them be like a snail which melts and passes away,","poem":1},{"text":"like the stillborn child, who has not seen the sun.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Before your pots can feel the heat of the thorns,","poem":1},{"text":"he will sweep away the green and the burning alike.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"The righteous shall rejoice when he sees the vengeance.","poem":1},{"text":"He shall wash his feet in the blood of the wicked,","poem":2}]},{"type":"verse","number":11,"content":[{"text":"so that men shall say, “Most certainly there is a reward for the righteous.","poem":1},{"text":"Most certainly there is a God who judges the earth.”","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/58.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":58},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/59.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":59},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/57.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":57},"previousChapterAudioLinks":{},"numberOfVerses":11},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":58,"content":[{"type":"verse","number":1,"content":["לַמְנַצֵּ֥חַ אַל־תַּשְׁחֵ֗ת לְדָוִ֥ד מִכְתָּֽם׃"]},{"type":"verse","number":2,"content":["הַֽאֻמְנָ֗ם אֵ֣לֶם צֶ֭דֶק תְּדַבֵּר֑וּן מֵישָׁרִ֥ים תִּ֝שְׁפְּט֗וּ בְּנֵ֣י אָדָֽם׃"]},{"type":"verse","number":3,"content":["אַף־בְּלֵב֮ עוֹלֹ֪ת תִּפְעָ֫ל֥וּן בָּאָ֡רֶץ חֲמַ֥ס יְ֝דֵיכֶ֗ם תְּפַלֵּֽסֽוּן׃"]},{"type":"verse","number":4,"content":["זֹ֣רוּ רְשָׁעִ֣ים מֵרָ֑חֶם תָּע֥וּ מִ֝בֶּ֗טֶן דֹּבְרֵ֥י כָזָֽב׃"]},{"type":"verse","number":5,"content":["חֲמַת־לָ֗מוֹ כִּדְמ֥וּת חֲמַת־נָחָ֑שׁ כְּמוֹ־פֶ֥תֶן חֵ֝רֵ֗שׁ יַאְטֵ֥ם אָזְנֽוֹ׃"]},{"type":"verse","number":6,"content":["אֲשֶׁ֣ר לֹא־יִ֭שְׁמַע לְק֣וֹל מְלַחֲשִׁ֑ים חוֹבֵ֖ר חֲבָרִ֣ים מְחֻכָּֽם׃"]},{"type":"verse","number":7,"content":["אֱֽלֹהִ֗ים הֲרָס־שִׁנֵּ֥ימוֹ בְּפִ֑ימוֹ מַלְתְּע֥וֹת כְּ֝פִירִ֗ים נְתֹ֣ץ ׀ יְהוָֽה׃"]},{"type":"verse","number":8,"content":["יִמָּאֲס֣וּ כְמוֹ־מַ֭יִם יִתְהַלְּכוּ־לָ֑מוֹ יִדְרֹ֥ךְ חצו כְּמ֣וֹ יִתְמֹלָֽלוּ׃"]},{"type":"verse","number":9,"content":["כְּמ֣וֹ שַׁ֭בְּלוּל תֶּ֣מֶס יַהֲלֹ֑ךְ נֵ֥פֶל אֵ֝֗שֶׁת בַּל־חָ֥זוּ שָֽׁמֶשׁ׃"]},{"type":"verse","number":10,"content":["בְּטֶ֤רֶם יָבִ֣ינוּ סִּֽירֹתֵיכֶ֣ם אָטָ֑ד כְּמוֹ־חַ֥י כְּמוֹ־חָ֝ר֗וֹן יִשְׂעָרֶֽנּוּ׃"]},{"type":"verse","number":11,"content":["יִשְׂמַ֣ח צַ֭דִּיק כִּי־חָזָ֣ה נָקָ֑ם פְּעָמָ֥יו יִ֝רְחַ֗ץ בְּדַ֣ם הָרָשָֽׁע׃"]},{"type":"verse","number":12,"content":["וְיֹאמַ֣ר אָ֭דָם אַךְ־פְּרִ֣י לַצַּדִּ֑יק אַ֥ךְ יֵשׁ־אֱ֝לֹהִ֗ים שֹׁפְטִ֥ים בָּאָֽרֶץ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/58.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":58},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/59.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":59},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/57.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":57},"previousChapterAudioLinks":{},"numberOfVerses":12}}