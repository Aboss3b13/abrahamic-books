":["הָרְפָאִ֥ים יְחוֹלָ֑לוּ מִתַּ֥חַת מַ֝֗יִם וְשֹׁכְנֵיהֶֽם׃"]},{"type":"verse","number":6,"content":["עָר֣וֹם שְׁא֣וֹל נֶגְדּ֑וֹ וְאֵ֥ין כְּ֝ס֗וּת לָֽאֲבַדּֽוֹן׃"]},{"type":"verse","number":7,"content":["נֹטֶ֣ה צָפ֣וֹן עַל־תֹּ֑הוּ תֹּ֥לֶה אֶ֝֗רֶץ עַל־בְּלִי־מָֽה׃"]},{"type":"verse","number":8,"content":["צֹרֵֽר־מַ֥יִם בְּעָבָ֑יו וְלֹא־נִבְקַ֖ע עָנָ֣ן תַּחְתָּֽם׃"]},{"type":"verse","number":9,"content":["מְאַחֵ֥ז פְּנֵי־כִסֵּ֑ה פַּרְשֵׁ֖ז עָלָ֣יו עֲנָנֽוֹ׃"]},{"type":"verse","number":10,"content":["חֹֽק־חָ֭ג עַל־פְּנֵי־מָ֑יִם עַד־תַּכְלִ֖ית א֣וֹר עִם־חֹֽשֶׁךְ׃"]},{"type":"verse","number":11,"content":["עַמּוּדֵ֣י שָׁמַ֣יִם יְרוֹפָ֑פוּ וְ֝יִתְמְה֗וּ מִגַּעֲרָתֽוֹ׃"]},{"type":"verse","number":12,"content":["בְּ֭כֹחוֹ רָגַ֣ע הַיָּ֑ם ובתובנתו מָ֣חַץ רָֽהַב׃"]},{"type":"verse","number":13,"content":["בְּ֭רוּחוֹ שָׁמַ֣יִם שִׁפְרָ֑ה חֹֽלֲלָ֥ה יָ֝ד֗וֹ נָחָ֥שׁ בָּרִֽיחַ׃"]},{"type":"verse","number":14,"content":["הֶן־אֵ֤לֶּה ׀ קְצ֬וֹת דרכו וּמַה־שֵּׁ֣מֶץ דָּ֭בָר נִשְׁמַע־בּ֑וֹ וְרַ֥עַם גבורתו מִ֣י יִתְבּוֹנָֽן׃ ס"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/JOB/26.json","thisChapterReference":{"translationId":"hbo_wlc","book":"JOB","chapter":26},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/JOB/27.json","nextChapterReference":{"translationId":"hbo_wlc","book":"JOB","chapter":27},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/JOB/25.json","previousChapterReference":{"translationId":"hbo_wlc","book":"JOB","chapter":25},"previousChapterAudioLinks":{},"numberOfVerses":14}}