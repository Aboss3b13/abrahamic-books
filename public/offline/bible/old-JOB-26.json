{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"JOB","translationId":"eng_web","name":"Job","commonName":"Job","title":"The Book of Job","order":18,"numberOfChapters":42,"sha256":"6dac796e2819a7919823cdaf78d98bff44300681f09e567bccbda12a2dac86c2","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/JOB/1.json","firstChapterReference":{"translationId":"eng_web","book":"JOB","chapter":1},"lastChapterNumber":42,"lastChapterApiLink":"/api/eng_web/JOB/42.json","lastChapterReference":{"translationId":"eng_web","book":"JOB","chapter":42},"totalNumberOfVerses":1070},"chapter":{"number":26,"content":[{"type":"verse","number":1,"content":["Then Job answered,"]},{"type":"verse","number":2,"content":[{"text":"“How have you helped him who is without power!","poem":1},{"text":"How have you saved the arm that has no strength!","poem":2}]},{"type":"verse","number":3,"content":[{"text":"How have you counseled him who has no wisdom,","poem":1},{"text":"and plentifully declared sound knowledge!","poem":2}]},{"type":"verse","number":4,"content":[{"text":"To whom have you uttered words?","poem":1},{"text":"Whose spirit came out of you?","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"“The departed spirits tremble,","poem":1},{"text":"those beneath the waters and all that live in them.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Sheol","poem":1},{"noteId":11},{"text":"is naked before God,","poem":1},{"text":"and Abaddon","poem":2},{"noteId":12},{"text":"has no covering.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"He stretches out the north over empty space,","poem":1},{"text":"and hangs the earth on nothing.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"He binds up the waters in his thick clouds,","poem":1},{"text":"and the cloud is not burst under them.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"He encloses the face of his throne,","poem":1},{"text":"and spreads his cloud on it.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"He has described a boundary on the surface of the waters,","poem":1},{"text":"and to the confines of light and darkness.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"The pillars of heaven tremble","poem":1},{"text":"and are astonished at his rebuke.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"He stirs up the sea with his power,","poem":1},{"text":"and by his understanding he strikes through Rahab.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"By his Spirit the heavens are garnished.","poem":1},{"text":"His hand has pierced the swift serpent.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"Behold, these are but the outskirts of his ways.","poem":1},{"text":"How small a whisper do we hear of him!","poem":2},{"lineBreak":true},{"text":"But the thunder of his power who can understand?”","poem":2}]}],"footnotes":[{"noteId":11,"caller":"+","text":"Sheol is the place of the dead.","reference":{"chapter":26,"verse":6}},{"noteId":12,"caller":"+","text":"Abaddon means Destroyer.","reference":{"chapter":26,"verse":6}}]},"thisChapterLink":"/api/eng_web/JOB/26.json","thisChapterReference":{"translationId":"eng_web","book":"JOB","chapter":26},"thisChapter