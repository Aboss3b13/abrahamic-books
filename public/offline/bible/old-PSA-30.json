{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":30,"content":[{"type":"hebrew_subtitle","content":["A Psalm. A Song for the Dedication of the Temple. By David."]},{"type":"verse","number":1,"content":[{"text":"I will extol you, Yahweh, for you have raised me up,","poem":1},{"text":"and have not made my foes to rejoice over me.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Yahweh my God, I cried to you,","poem":1},{"text":"and you have healed me.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Yahweh, you have brought up my soul from Sheol.","poem":1},{"noteId":13},{"text":"You have kept me alive, that I should not go down to the pit.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Sing praise to Yahweh, you saints of his.","poem":1},{"text":"Give thanks to his holy name.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"For his anger is but for a moment.","poem":1},{"text":"His favor is for a lifetime.","poem":2},{"text":"Weeping may stay for the night,","poem":1},{"text":"but joy comes in the morning.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"As for me, I said in my prosperity,","poem":1},{"text":"“I shall never be moved.”","poem":2}]},{"type":"verse","number":7,"content":[{"text":"You, Yahweh, when you favored me, made my mountain stand strong;","poem":1},{"text":"but when you hid your face, I was troubled.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"I cried to you, Yahweh.","poem":1},{"text":"I made supplication to the Lord:","poem":2}]},{"type":"verse","number":9,"content":[{"text":"“What profit is there in my destruction, if I go down to the pit?","poem":1},{"text":"Shall the dust praise you?","poem":2},{"lineBreak":true},{"text":"Shall it declare your truth?","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Hear, Yahweh, and have mercy on me.","poem":1},{"text":"Yahweh, be my helper.”","poem":2}]},{"type":"verse","number":11,"content":[{"text":"You have turned my mourning into dancing for me.","poem":1},{"text":"You have removed my sackcloth, and clothed me with gladness,","poem":2},{"lineBreak":true}]},{"type":"verse","number":12,"content":[{"text":"to the end that my heart may sing praise to you, and not be silent.","poem":2},{"text":"Yahweh my God, I will give thanks to you forever!","poem":1}]}],"footnotes":[{"noteId":13,"caller":"+","text":"Sheol is the place of the dead.","reference":{"chapter":30,"verse":3}}]},"thisChapterLink":"/api/eng_web/PSA/30.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":30},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/31.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":31},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/29.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":29},"previousChapterAudioLinks":{},"numberOfVerses":12},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":30,"content":[{"type":"verse","number":1,"content":["מִזְמ֡וֹר שִׁיר־חֲנֻכַּ֖ת הַבַּ֣יִת לְדָוִֽד׃"]},{"type":"verse","number":2,"content":["אֲרוֹמִמְךָ֣ יְ֭הוָה כִּ֣י דִלִּיתָ֑נִי וְלֹא־שִׂמַּ֖חְתָּ אֹיְבַ֣י לִֽי׃"]},{"type":"verse","number":3,"content":["יְהוָ֥ה אֱלֹהָ֑י שִׁוַּ֥עְתִּי אֵ֝לֶ֗יךָ וַתִּרְפָּאֵֽנִי׃"]},{"type":"verse","number":4,"content":["יְֽהוָ֗ה הֶֽעֱלִ֣יתָ מִן־שְׁא֣וֹל נַפְשִׁ֑י חִ֝יִּיתַ֗נִי מיורדי ־בֽוֹר׃"]},{"type":"verse","number":5,"content":["זַמְּר֣וּ לַיהוָ֣ה חֲסִידָ֑יו וְ֝הוֹד֗וּ לְזֵ֣כֶר קָדְשֽׁוֹ׃"]},{"type":"verse","number":6,"content":["כִּ֤י רֶ֨גַע ׀ בְּאַפּוֹ֮ חַיִּ֪ים בִּרְצ֫וֹנ֥וֹ בָּ֭עֶרֶב יָלִ֥ין בֶּ֗כִי וְלַבֹּ֥קֶר רִנָּֽה׃"]},{"type":"verse","number":7,"content":["וַ֭אֲנִי אָמַ֣רְתִּי בְשַׁלְוִ֑י בַּל־אֶמּ֥וֹט לְעוֹלָֽם׃"]},{"type":"verse","number":8,"content":["יְֽהוָ֗ה בִּרְצוֹנְךָ֮ הֶעֱמַ֪דְתָּה לְֽהַרְרִ֫י עֹ֥ז הִסְתַּ֥רְתָּ פָנֶ֗יךָ הָיִ֥יתִי נִבְהָֽל׃"]},{"type":"verse","number":9,"content":["אֵלֶ֣יךָ יְהוָ֣ה אֶקְרָ֑א וְאֶל־אֲ֝דֹנָ֗י אֶתְחַנָּֽן׃"]},{"type":"verse","number":10,"content":["מַה־בֶּ֥צַע בְּדָמִי֮ בְּרִדְתִּ֪י אֶ֫ל־שָׁ֥חַת הֲיוֹדְךָ֥ עָפָ֑ר הֲיַגִּ֥יד אֲמִתֶּֽךָ׃"]},{"type":"verse","number":11,"content":["שְׁמַע־יְהוָ֥ה וְחָנֵּ֑נִי יְ֝הוָה הֱֽיֵה־עֹזֵ֥ר לִֽי׃"]},{"type":"verse","number":12,"content":["הָפַ֣כְתָּ מִסְפְּדִי֮ לְמָח֪וֹל לִ֥י פִּתַּ֥חְתָּ שַׂקִּ֑י וַֽתְּאַזְּרֵ֥נִי שִׂמְחָֽה׃"]},{"type":"verse","number":13,"content":["לְמַ֤עַן ׀ יְזַמֶּרְךָ֣ כָ֭בוֹד וְלֹ֣א יִדֹּ֑ם יְהוָ֥ה אֱ֝לֹהַ֗י לְעוֹלָ֥ם אוֹדֶֽךָּ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/30.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":30},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/31.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":31},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/29.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":29},"previousChapterAudioLinks":{},"numberOfVerses":13}}