{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":112,"content":[{"type":"verse","number":1,"content":[{"text":"Praise Yah!","poem":1},{"noteId":40},{"text":"Blessed is the man who fears Yahweh,","poem":2},{"lineBreak":true},{"text":"who delights greatly in his commandments.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"His offspring will be mighty in the land.","poem":1},{"text":"The generation of the upright will be blessed.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Wealth and riches are in his house.","poem":1},{"text":"His righteousness endures forever.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Light dawns in the darkness for the upright,","poem":1},{"text":"gracious, merciful, and righteous.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"It is well with the man who deals graciously and lends.","poem":1},{"text":"He will maintain his cause in judgment.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"For he will never be shaken.","poem":1},{"text":"The righteous will be remembered forever.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"He will not be afraid of evil news.","poem":1},{"text":"His heart is steadfast, trusting in Yahweh.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"His heart is established.","poem":1},{"text":"He will not be afraid in the end when he sees his adversaries.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"He has dispersed, he has given to the poor.","poem":1},{"text":"His righteousness endures forever.","poem":2},{"lineBreak":true},{"text":"His horn will be exalted with honor.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"The wicked will see it, and be grieved.","poem":1},{"text":"He shall gnash with his teeth, and melt away.","poem":2},{"lineBreak":true},{"text":"The desire of the wicked will perish.","poem":2}]}],"footnotes":[{"noteId":40,"caller":"+","text":"Psalm 112 is an acrostic poem, with each verse after the initial “Praise Yah!” starting with a letter of the alphabet (ordered from Alef to Tav).","reference":{"chapter":112,"verse":1}}]},"thisChapterLink":"/api/eng_web/PSA/112.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":112},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/113.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":113},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/111.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":111},"previousChapterAudioLinks":{},"numberOfVerses":10},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":112,"content":[{"type":"verse","number":1,"content":["הַ֥לְלוּ יָ֨הּ ׀ אַשְׁרֵי־אִ֭ישׁ יָרֵ֣א אֶת־יְהוָ֑ה בְּ֝מִצְוֺתָ֗יו חָפֵ֥ץ מְאֹֽד׃"]},{"type":"verse","number":2,"content":["גִּבּ֣וֹר בָּ֭אָרֶץ יִהְיֶ֣ה זַרְע֑וֹ דּ֭וֹר יְשָׁרִ֣ים יְבֹרָֽךְ׃"]},{"type":"verse","number":3,"content":["הוֹן־וָעֹ֥שֶׁר בְּבֵית֑וֹ וְ֝צִדְקָת֗וֹ עֹמֶ֥דֶת לָעַֽד׃"]},{"type":"verse","number":4,"content":["זָ֘רַ֤ח בַּחֹ֣שֶׁךְ א֭וֹר לַיְשָׁרִ֑ים חַנּ֖וּן וְרַח֣וּם וְצַדִּֽיק׃"]},{"type":"verse","number":5,"content":["טֽוֹב־אִ֭ישׁ חוֹנֵ֣ן וּמַלְוֶ֑ה יְכַלְכֵּ֖ל דְּבָרָ֣יו בְּמִשְׁפָּֽט׃"]},{"type":"verse","number":6,"content":["כִּֽי־לְעוֹלָ֥ם לֹא־יִמּ֑וֹט לְזֵ֥כֶר ע֝וֹלָ֗ם יִהְיֶ֥ה צַדִּֽיק׃"]},{"type":"verse","number":7,"content":["מִשְּׁמוּעָ֣ה רָ֭עָה לֹ֣א יִירָ֑א נָכ֥וֹן לִ֝בּ֗וֹ בָּטֻ֥חַ בַּיהוָֽה׃"]},{"type":"verse","number":8,"content":["סָמ֣וּךְ לִ֭בּוֹ לֹ֣א יִירָ֑א עַ֖ד אֲשֶׁר־יִרְאֶ֣ה בְצָרָֽיו׃"]},{"type":"verse","number":9,"content":["פִּזַּ֤ר ׀ נָ֘תַ֤ן לָאֶבְיוֹנִ֗ים צִ֭דְקָתוֹ עֹמֶ֣דֶת לָעַ֑ד קַ֝רְנ֗וֹ תָּר֥וּם בְּכָבֽוֹד׃"]},{"type":"verse","number":10,"content":["רָ֘שָׁ֤ע יִרְאֶ֨ה ׀ וְכָעָ֗ס שִׁנָּ֣יו יַחֲרֹ֣ק וְנָמָ֑ס תַּאֲוַ֖ת רְשָׁעִ֣ים תֹּאבֵֽד׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/112.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":112},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/113.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":113},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/111.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":111},"previousChapterAudioLinks":{},"numberOfVerses":10}}