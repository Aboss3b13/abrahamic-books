{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":6,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician; on stringed instruments, upon the eight-stringed lyre. A Psalm by David."]},{"type":"verse","number":1,"content":[{"text":"Yahweh, don’t rebuke me in your anger,","poem":1},{"text":"neither discipline me in your wrath.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Have mercy on me, Yahweh, for I am faint.","poem":1},{"text":"Yahweh, heal me, for my bones are troubled.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"My soul is also in great anguish.","poem":1},{"text":"But you, Yahweh—how long?","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Return, Yahweh. Deliver my soul,","poem":1},{"text":"and save me for your loving kindness’ sake.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"For in death there is no memory of you.","poem":1},{"text":"In Sheol,","poem":2},{"noteId":5},{"text":"who shall give you thanks?","poem":2}]},{"type":"verse","number":6,"content":[{"text":"I am weary with my groaning.","poem":1},{"text":"Every night I flood my bed.","poem":2},{"lineBreak":true},{"text":"I drench my couch with my tears.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"My eye wastes away because of grief.","poem":1},{"text":"It grows old because of all my adversaries.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Depart from me, all you workers of iniquity,","poem":1},{"text":"for Yahweh has heard the voice of my weeping.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Yahweh has heard my supplication.","poem":1},{"text":"Yahweh accepts my prayer.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"May all my enemies be ashamed and dismayed.","poem":1},{"text":"They shall turn back, they shall be disgraced suddenly.","poem":2}]}],"footnotes":[{"noteId":5,"caller":"+","text":"Sheol is the place of the dead.","reference":{"chapter":6,"verse":5}}]},"thisChapterLink":"/api/eng_web/PSA/6.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":6},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/7.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":7},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/5.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":5},"previousChapterAudioLinks":{},"numberOfVerses":10},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":6,"content":[{"type":"verse","number":1,"content":["לַמְנַצֵּ֣חַ בִּ֭נְגִינוֹת עַֽל־הַשְּׁמִינִ֗ית מִזְמ֥וֹר לְדָוִֽד׃"]},{"type":"verse","number":2,"content":["יְֽהוָ֗ה אַל־בְּאַפְּךָ֥ תוֹכִיחֵ֑נִי וְֽאַל־בַּחֲמָתְךָ֥ תְיַסְּרֵֽנִי׃"]},{"type":"verse","number":3,"content":["חָנֵּ֥נִי יְהוָה֮ כִּ֤י אֻמְלַ֫ל אָ֥נִי רְפָאֵ֥נִי יְהוָ֑ה כִּ֖י נִבְהֲל֣וּ עֲצָמָֽי׃"]},{"type":"verse","number":4,"content":["וְ֭נַפְשִׁי נִבְהֲלָ֣ה מְאֹ֑ד ואת יְ֝הוָ֗ה עַד־מָתָֽי׃"]},{"type":"verse","number":5,"content":["שׁוּבָ֣ה יְ֭הוָה חַלְּצָ֣ה נַפְשִׁ֑י ה֝וֹשִׁיעֵ֗נִי לְמַ֣עַן חַסְדֶּֽךָ׃"]},{"type":"verse","number":6,"content":["כִּ֤י אֵ֣ין בַּמָּ֣וֶת זִכְרֶ֑ךָ בִּ֝שְׁא֗וֹל מִ֣י יֽוֹדֶה־לָּֽךְ׃"]},{"type":"verse","number":7,"content":["יָגַ֤עְתִּי ׀ בְּֽאַנְחָתִ֗י אַשְׂחֶ֣ה בְכָל־לַ֭יְלָה מִטָּתִ֑י בְּ֝דִמְעָתִ֗י עַרְשִׂ֥י אַמְסֶֽה׃"]},{"type":"verse","number":8,"content":["עָֽשְׁשָׁ֣ה מִכַּ֣עַס עֵינִ֑י עָֽ֝תְקָ֗ה בְּכָל־צוֹרְרָֽי׃"]},{"type":"verse","number":9,"content":["ס֣וּרוּ מִ֭מֶּנִּי כָּל־פֹּ֣עֲלֵי אָ֑וֶן כִּֽי־שָׁמַ֥ע יְ֝הוָ֗ה ק֣וֹל בִּכְיִֽי׃"]},{"type":"verse","number":10,"content":["שָׁמַ֣ע יְ֭הוָה תְּחִנָּתִ֑י יְ֝הוָ֗ה תְּֽפִלָּתִ֥י יִקָּֽח׃"]},{"type":"verse","number":11,"content":["יֵבֹ֤שׁוּ ׀ וְיִבָּהֲל֣וּ מְ֭אֹד כָּל־אֹיְבָ֑י יָ֝שֻׁ֗בוּ יֵבֹ֥שׁוּ רָֽגַע׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/6.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":6},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/7.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":7},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/5.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":5},"previousChapterAudioLinks":{},"numberOfVerses":11}}