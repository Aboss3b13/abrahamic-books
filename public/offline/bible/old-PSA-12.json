{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":12,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician; upon an eight-stringed lyre. A Psalm of David."]},{"type":"verse","number":1,"content":[{"text":"Help, Yahweh; for the godly man ceases.","poem":1},{"text":"For the faithful fail from among the children of men.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Everyone lies to his neighbor.","poem":1},{"text":"They speak with flattering lips, and with a double heart.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"May Yahweh cut off all flattering lips,","poem":1},{"text":"and the tongue that boasts,","poem":2}]},{"type":"verse","number":4,"content":[{"text":"who have said, “With our tongue we will prevail.","poem":1},{"text":"Our lips are our own.","poem":2},{"lineBreak":true},{"text":"Who is lord over us?”","poem":2}]},{"type":"verse","number":5,"content":[{"text":"“Because of the oppression of the weak and because of the groaning of the needy,","poem":1},{"text":"I will now arise,” says Yahweh;","poem":2},{"text":"“I will set him in safety from those who malign him.”","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"Yahweh’s words are flawless words,","poem":1},{"text":"as silver refined in a clay furnace, purified seven times.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"You will keep them, Yahweh.","poem":1},{"text":"You will preserve them from this generation forever.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"The wicked walk on every side,","poem":1},{"text":"when what is vile is exalted among the sons of men.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/12.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":12},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/13.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":13},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/11.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":11},"previousChapterAudioLinks":{},"numberOfVerses":8},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"to