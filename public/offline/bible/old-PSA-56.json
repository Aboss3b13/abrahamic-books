{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":56,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. To the tune of “Silent Dove in Distant Lands.” A poem by David, when the Philistines seized him in Gath."]},{"type":"verse","number":1,"content":[{"text":"Be merciful to me, God, for man wants to swallow me up.","poem":1},{"text":"All day long, he attacks and oppresses me.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"My enemies want to swallow me up all day long,","poem":1},{"text":"for they are many who fight proudly against me.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"When I am afraid,","poem":1},{"text":"I will put my trust in you.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"In God, I praise his word.","poem":1},{"text":"In God, I put my trust.","poem":2},{"text":"I will not be afraid.","poem":1},{"text":"What can flesh do to me?","poem":2}]},{"type":"verse","number":5,"content":[{"text":"All day long they twist my words.","poem":1},{"text":"All their thoughts are against me for evil.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"They conspire and lurk,","poem":1},{"text":"watching my steps.","poem":2},{"lineBreak":true},{"text":"They are eager to take my life.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Shall they escape by iniquity?","poem":1},{"text":"In anger cast down the peoples, God.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"You count my wanderings.","poem":1},{"text":"You put my tears into your container.","poem":2},{"lineBreak":true},{"text":"Aren’t they in your book?","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Then my enemies shall turn back in the day that I call.","poem":1},{"text":"I know this: that God is for me.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"In God, I will praise his word.","poem":1},{"text":"In Yahweh, I will praise his word.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"I have put my trust in God.","poem":1},{"text":"I will not be afraid.","poem":2},{"lineBreak":true},{"text":"What can man do to me?","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Your vows are on me, God.","poem":1},{"text":"I will give thank offerings to you.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"For you have delivered my soul from death,","poem":1},{"text":"and prevented my feet from falling,","poem":2},{"lineBreak":true},{"text":"that I may walk before God in the light of the living.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/56.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":56},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/57.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":57},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/55.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":55},"previousChapterAudioLinks":{},"numberOfVerses":13},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":56,"content":[{"type":"verse","number":1,"content":["לַמְנַצֵּ֤חַ ׀ עַל־י֬וֹנַת אֵ֣לֶם רְ֭חֹקִים לְדָוִ֣ד מִכְתָּ֑ם בֶּֽאֱחֹ֨ז אֹת֖וֹ פְלִשְׁתִּ֣ים בְּגַֽת׃"]},{"type":"verse","number":2,"content":["חָנֵּ֣נִי אֱ֭לֹהִים כִּֽי־שְׁאָפַ֣נִי אֱנ֑וֹשׁ כָּל־הַ֝יּ֗וֹם לֹחֵ֥ם יִלְחָצֵֽנִי׃"]},{"type":"verse","number":3,"content":["שָׁאֲפ֣וּ שׁ֭וֹרְרַי כָּל־הַיּ֑וֹם כִּֽי־רַבִּ֨ים לֹחֲמִ֖ים לִ֣י מָרֽוֹם׃"]},{"type":"verse","number":4,"content":["י֥וֹם אִירָ֑א אֲ֝נִ֗י אֵלֶ֥יךָ אֶבְטָֽח׃"]},{"type":"verse","number":5,"content":["בֵּאלֹהִים֮ אֲהַלֵּ֪ל דְּבָ֫ר֥וֹ בֵּאלֹהִ֣ים בָּ֭טַחְתִּי לֹ֣א אִירָ֑א מַה־יַּעֲשֶׂ֖ה בָשָׂ֣ר לִֽי׃"]},{"type":"verse","number":6,"content":["כָּל־הַ֭יּוֹם דְּבָרַ֣י יְעַצֵּ֑בוּ עָלַ֖י כָּל־מַחְשְׁבֹתָ֣ם לָרָֽע׃"]},{"type":"verse","number":7,"content":["יָג֤וּרוּ ׀ יצפינו הֵ֭מָּה עֲקֵבַ֣י יִשְׁמֹ֑רוּ כַּ֝אֲשֶׁ֗ר קִוּ֥וּ נַפְשִֽׁי׃"]},{"type":"verse","number":8,"content":["עַל־אָ֥וֶן פַּלֶּט־לָ֑מוֹ בְּ֝אַ֗ף עַמִּ֤ים ׀ הוֹרֵ֬ד אֱלֹהִֽים׃"]},{"type":"verse","number":9,"content":["נֹדִי֮ סָפַ֪רְתָּ֫ה אָ֥תָּה שִׂ֣ימָה דִמְעָתִ֣י בְנֹאדֶ֑ךָ הֲ֝לֹ֗א בְּסִפְרָתֶֽךָ׃"]},{"type":"verse","number":10,"content":["אָ֥֨ז יָ֘שׁ֤וּבוּ אוֹיְבַ֣י אָ֭חוֹר בְּי֣וֹם אֶקְרָ֑א זֶה־יָ֝דַ֗עְתִּי כִּֽי־אֱלֹהִ֥ים לִֽי׃"]},{"type":"verse","number":11,"content":["בֵּֽ֭אלֹהִים אֲהַלֵּ֣ל דָּבָ֑ר בַּ֝יהוָ֗ה אֲהַלֵּ֥ל דָּבָֽר׃"]},{"type":"verse","number":12,"content":["בֵּֽאלֹהִ֣ים בָּ֭טַחְתִּי לֹ֣א אִירָ֑א מַה־יַּעֲשֶׂ֖ה אָדָ֣ם לִֽי׃"]},{"type":"verse","number":13,"content":["עָלַ֣י אֱלֹהִ֣ים נְדָרֶ֑יךָ אֲשַׁלֵּ֖ם תּוֹדֹ֣ת לָֽךְ׃"]},{"type":"verse","number":14,"content":["כִּ֤י הִצַּ֪לְתָּ נַפְשִׁ֡י מִמָּוֶת֮ הֲלֹ֥א רַגְלַ֗י מִ֫דֶּ֥חִי לְ֭הִֽתְהַלֵּךְ לִפְנֵ֣י אֱלֹהִ֑ים בְּ֝א֗וֹר הַֽחַיִּֽים׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/56.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":56},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/57.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":57},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/55.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":55},"previousChapterAudioLinks":{},"numberOfVerses":14}}