{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"JOB","translationId":"eng_web","name":"Job","commonName":"Job","title":"The Book of Job","order":18,"numberOfChapters":42,"sha256":"6dac796e2819a7919823cdaf78d98bff44300681f09e567bccbda12a2dac86c2","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/JOB/1.json","firstChapterReference":{"translationId":"eng_web","book":"JOB","chapter":1},"lastChapterNumber":42,"lastChapterApiLink":"/api/eng_web/JOB/42.json","lastChapterReference":{"translationId":"eng_web","book":"JOB","chapter":42},"totalNumberOfVerses":1070},"chapter":{"number":35,"content":[{"type":"verse","number":1,"content":["Moreover Elihu answered,"]},{"type":"verse","number":2,"content":[{"text":"“Do you think this to be your right,","poem":1},{"text":"or do you say, ‘My righteousness is more than God’s,’","poem":2}]},{"type":"verse","number":3,"content":[{"text":"that you ask, ‘What advantage will it be to you?","poem":1},{"text":"What profit will I have, more than if I had sinned?’","poem":2}]},{"type":"verse","number":4,"content":[{"text":"I will answer you,","poem":1},{"text":"and your companions with you.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Look to the skies, and see.","poem":1},{"text":"See the skies, which are higher than you.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"If you have sinned, what effect do you have against him?","poem":1},{"text":"If your transgressions are multiplied, what do you do to him?","poem":2}]},{"type":"verse","number":7,"content":[{"text":"If you are righteous, what do you give him?","poem":1},{"text":"Or what does he receive from your hand?","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Your wickedness may hurt a man as you are,","poem":1},{"text":"and your righteousness may profit a son of man.","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"“By reason of the multitude of oppressions they cry out.","poem":1},{"text":"They cry for help by reason of the arm of the mighty.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"But no one says, ‘Where is God my Maker,","poem":1},{"text":"who gives songs in the night,","poem":2}]},{"type":"verse","number":11,"content":[{"text":"who teaches us more than the animals of the earth,","poem":1},{"text":"and makes us wiser than the birds of the sky?’","poem":2}]},{"type":"verse","number":12,"content":[{"text":"There they cry, but no one answers,","poem":1},{"text":"because of the pride of evil men.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Surely God will not hear an empty cry,","poem":1},{"text":"neither will the Almighty regard it.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"How much less when you say you don’t see him.","poem":1},{"text":"The cause is before him, and you wait for him!","poem":2}]},{"type":"verse","number":15,"content":[{"text":"But now, because he has not visited in his anger,","poem":1},{"text":"neither does he greatly regard arrogance,","poem":2}]},{"type":"verse","number":16,"content":[{"text":"therefore Job opens his mouth with empty talk,","poem":1},{"text":"and he multiplies words without knowledge.”","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/eng_web/JOB/35.json","thisChapterReference":{"translationId":"eng_web","book":"JOB","chapter":35},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/JOB/36.json","nextChapterReference":{"translationId":"eng_web","book":"JOB","chapter":36},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/JOB/34.json","previousChapterReference":{"translationId":"eng_web","book":"JOB","chapter":34},"previousChapterAudioLinks":{},"numberOfVerses":16},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"JOB","translationId":"hbo_wlc","name":"איוב","commonName":"איוב","title":"איוב","order":18,"numberOfChapters":42,"sha256":"40714f6da0dbbbfa33e6e988fa228d1df6b53dc67303267a827d6a609985c62f","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/JOB/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"JOB","chapter":1},"lastChapterNumber":42,"lastChapterApiLink":"/api/hbo_wlc/JOB/42.json","lastChapterReference":{"translationId":"hbo_wlc","book":"JOB","chapter":42},"totalNumberOfVerses":1070},"chapter":{"number":35,"content":[{"type":"verse","number":1,"content":["וַיַּ֥עַן אֱלִיה֗וּ וַיֹּאמַֽר׃"]},{"type":"verse","number":2,"content":["הֲ֭זֹאת חָשַׁ֣בְתָּ לְמִשְׁפָּ֑ט אָ֝מַ֗רְתָּ צִדְקִ֥י מֵאֵֽל׃"]},{"type":"verse","number":3,"content":["כִּֽי־תֹ֭אמַר מַה־יִּסְכָּן־לָ֑ךְ מָֽה־אֹ֝עִ֗יל מֵֽחַטָּאתִֽי׃"]},{"type":"verse","number":4,"content":["אֲ֭נִי אֲשִֽׁיבְךָ֣ מִלִּ֑ין וְֽאֶת־רֵעֶ֥יךָ עִמָּֽךְ׃"]},{"type":"verse","number":5,"content":["הַבֵּ֣ט שָׁמַ֣יִם וּרְאֵ֑ה וְשׁ֥וּר שְׁ֝חָקִ֗ים גָּבְה֥וּ מִמֶּֽךָּ׃"]},{"type":"verse","number":6,"content":["אִם־חָ֭טָאתָ מַה־תִּפְעָל־בּ֑וֹ וְרַבּ֥וּ פְ֝שָׁעֶ֗יךָ מַה־תַּעֲשֶׂה־לּֽוֹ׃"]},{"type":"verse","number":7,"content":["אִם־צָ֭דַקְתָּ מַה־תִּתֶּן־ל֑וֹ א֥וֹ מַה־מִיָּדְךָ֥ יִקָּֽח׃"]},{"type":"verse","number":8,"content":["לְאִישׁ־כָּמ֥וֹךָ רִשְׁעֶ֑ךָ וּלְבֶן־אָ֝דָ֗ם צִדְקָתֶֽךָ׃"]},{"type":"verse","number":9,"content":["מֵ֭רֹב עֲשׁוּקִ֣ים יַזְעִ֑יקוּ יְשַׁוְּע֖וּ מִזְּר֣וֹעַ רַבִּֽים׃"]},{"type":"verse","number":10,"content":["וְֽלֹא־אָמַ֗ר אַ֭יֵּה אֱל֣וֹהַּ עֹשָׂ֑י נֹתֵ֖ן זְמִר֣וֹת בַּלָּֽיְלָה׃"]},{"type":"verse","number":11,"content":["מַ֭לְּפֵנוּ מִבַּהֲמ֣וֹת אָ֑רֶץ וּמֵע֖וֹף הַשָּׁמַ֣יִם יְחַכְּמֵֽנוּ׃"]},{"type":"verse","number":12,"content":["שָׁ֣ם יִ֭צְעֲקוּ וְלֹ֣א יַעֲנֶ֑ה מִ֝פְּנֵ֗י גְּא֣וֹן רָעִֽים׃"]},{"type":"verse","number":13,"content":["אַךְ־שָׁ֭וְא לֹא־יִשְׁמַ֥ע ׀ אֵ֑ל וְ֝שַׁדַּ֗י לֹ֣א יְשׁוּרֶֽנָּה׃"]},{"type":"verse","number":14,"content":["אַ֣ף כִּֽי־תֹ֭אמַר לֹ֣א תְשׁוּרֶ֑נּוּ דִּ֥ין לְ֝פָנָ֗יו וּתְח֥וֹלֵֽל לֽוֹ׃"]},{"type":"verse","number":15,"content":["וְעַתָּ֗ה כִּי־אַ֭יִן פָּקַ֣ד אַפּ֑וֹ וְלֹֽא־יָדַ֖ע בַּפַּ֣שׁ מְאֹֽד׃"]},{"type":"verse","number":16,"content":["וְ֭אִיּוֹב הֶ֣בֶל יִפְצֶה־פִּ֑יהוּ בִּבְלִי־דַ֝֗עַת מִלִּ֥ין יַכְבִּֽר׃ פ"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/JOB/35.json","thisChapterReference":{"translationId":"hbo_wlc","book":"JOB","chapter":35},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/JOB/36.json","nextChapterReference":{"translationId":"hbo_wlc","book":"JOB","chapter":36},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/JOB/34.json","previousChapterReference":{"translationId":"hbo_wlc","book":"JOB","chapter":34},"previousChapterAudioLinks":{},"numberOfVerses":16}}