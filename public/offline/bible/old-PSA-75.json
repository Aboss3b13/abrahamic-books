{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":75,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. To the tune of “Do Not Destroy.” A Psalm by Asaph. A song."]},{"type":"verse","number":1,"content":[{"text":"We give thanks to you, God.","poem":1},{"text":"We give thanks, for your Name is near.","poem":2},{"lineBreak":true},{"text":"Men tell about your wondrous works.","poem":2}]},{"type":"line_break"},{"type":"verse","number":2,"content":[{"text":"When I choose the appointed time,","poem":1},{"text":"I will judge blamelessly.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"The earth and all its inhabitants quake.","poem":1},{"text":"I firmly hold its pillars. Selah.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"I said to the arrogant, “Don’t boast!”","poem":1},{"text":"I said to the wicked, “Don’t lift up the horn.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Don’t lift up your horn on high.","poem":1},{"text":"Don’t speak with a stiff neck.”","poem":2}]},{"type":"verse","number":6,"content":[{"text":"For neither from the east, nor from the west,","poem":1},{"text":"nor yet from the south, comes exaltation.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"But God is the judge.","poem":1},{"text":"He puts down one, and lifts up another.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"For in Yahweh’s hand there is a cup,","poem":1},{"text":"full of foaming wine mixed with spices.","poem":2},{"text":"He pours it out.","poem":1},{"text":"Indeed the wicked of the earth drink and drink it to its very dregs.","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"But I will declare this forever:","poem":1},{"text":"I will sing praises to the God of Jacob.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"I will cut off all the horns of the wicked,","poem":1},{"text":"but the horns of the righteous shall be lifted up.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/75.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":75},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/76.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":76},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/74.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":74},"previousChapterAudioLinks":{},"numberOfVerses":10},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":75,"content":[{"type":"verse","number":1,"content":["לַמְנַצֵּ֥חַ אַל־תַּשְׁחֵ֑ת מִזְמ֖וֹר לְאָסָ֣ף שִֽׁיר׃"]},{"type":"verse","number":2,"content":["ה֘וֹדִ֤ינוּ לְּךָ֨ ׀ אֱֽלֹהִ֗ים ה֭וֹדִינוּ וְקָר֣וֹב שְׁמֶ֑ךָ סִ֝פְּר֗וּ נִפְלְאוֹתֶֽיךָ׃"]},{"type":"verse","number":3,"content":["כִּ֭י אֶקַּ֣ח מוֹעֵ֑ד אֲ֝נִ֗י מֵישָׁרִ֥ים אֶשְׁפֹּֽט׃"]},{"type":"verse","number":4,"content":["נְֽמֹגִ֗ים אֶ֥רֶץ וְכָל־יֹשְׁבֶ֑יהָ אָנֹכִ֨י תִכַּ֖נְתִּי עַמּוּדֶ֣יהָ סֶּֽלָה׃"]},{"type":"verse","number":5,"content":["אָמַ֣רְתִּי לַֽ֭הוֹלְלִים אַל־תָּהֹ֑לּוּ וְ֝לָרְשָׁעִ֗ים אַל־תָּרִ֥ימוּ קָֽרֶן׃"]},{"type":"verse","number":6,"content":["אַל־תָּרִ֣ימוּ לַמָּר֣וֹם קַרְנְכֶ֑ם תְּדַבְּר֖וּ בְצַוָּ֣אר עָתָֽק׃"]},{"type":"verse","number":7,"content":["כִּ֤י לֹ֣א מִ֭מּוֹצָא וּמִֽמַּעֲרָ֑ב וְ֝לֹ֗א מִמִּדְבַּ֥ר הָרִֽים׃"]},{"type":"verse","number":8,"content":["כִּֽי־אֱלֹהִ֥ים שֹׁפֵ֑ט זֶ֥ה יַ֝שְׁפִּ֗יל וְזֶ֣ה יָרִֽים׃"]},{"type":"verse","number":9,"content":["כִּ֤י כ֪וֹס בְּֽיַד־יְהוָ֡ה וְיַ֤יִן חָמַ֨ר ׀ מָ֥לֵא מֶסֶךְ֮ וַיַּגֵּ֪ר מִ֫זֶּ֥ה אַךְ־שְׁ֭מָרֶיהָ יִמְצ֣וּ יִשְׁתּ֑וּ כֹּ֝֗ל רִשְׁעֵי־אָֽרֶץ׃"]},{"type":"verse","number":10,"content":["וַ֭אֲנִי אַגִּ֣יד לְעֹלָ֑ם אֲ֝זַמְּרָ֗ה לֵאלֹהֵ֥י יַעֲקֹֽב׃"]},{"type":"verse","number":11,"content":["וְכָל־קַרְנֵ֣י רְשָׁעִ֣ים אֲגַדֵּ֑עַ תְּ֝רוֹמַ֗מְנָה קַֽרְנ֥וֹת צַדִּֽיק׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/75.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":75},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/76.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":76},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/74.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":74},"previousChapterAudioLinks":{},"numberOfVerses":11}}