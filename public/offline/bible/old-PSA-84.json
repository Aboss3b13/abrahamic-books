{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":84,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. On an instrument of Gath. A Psalm by the sons of Korah."]},{"type":"verse","number":1,"content":[{"text":"How lovely are your dwellings,","poem":1},{"text":"Yahweh of Armies!","poem":2}]},{"type":"verse","number":2,"content":[{"text":"My soul longs, and even faints for the courts of Yahweh.","poem":1},{"text":"My heart and my flesh cry out for the living God.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Yes, the sparrow has found a home,","poem":1},{"text":"and the swallow a nest for herself, where she may have her young,","poem":2},{"lineBreak":true},{"text":"near your altars, Yahweh of Armies, my King, and my God.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Blessed are those who dwell in your house.","poem":1},{"text":"They are always praising you. Selah.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Blessed are those whose strength is in you,","poem":1},{"text":"who have set their hearts on a pilgrimage.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Passing through the valley of Weeping, they make it a place of springs.","poem":1},{"text":"Yes, the autumn rain covers it with blessings.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"They go from strength to strength.","poem":1},{"text":"Every one of them appears before God in Zion.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Yahweh, God of Armies, hear my prayer.","poem":1},{"text":"Listen, God of Jacob. Selah.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Behold, God our shield,","poem":1},{"text":"look at the face of your anointed.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"For a day in your courts is better than a thousand.","poem":1},{"text":"I would rather be a doorkeeper in the house of my God,","poem":2},{"lineBreak":true},{"text":"than to dwell in the tents of wickedness.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"For Yahweh God is a sun and a shield.","poem":1},{"text":"Yahweh will give grace and glory.","poem":2},{"lineBreak":true},{"text":"He withholds no good thing from those who walk blamelessly.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Yahweh of Armies,","poem":1},{"text":"blessed is the man who trusts in you.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/84.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":84},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/85.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":85},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/83.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":83},"previousChapterAudioLinks":{},"numberOfVerses":12},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":84,"content":[{"type":"verse","number":1,"content":["לַמְנַצֵּ֥חַ עַֽל־הַגִּתִּ֑ית לִבְנֵי־קֹ֥רַח מִזְמֽוֹר׃"]},{"type":"verse","number":2,"content":["מַה־יְּדִיד֥וֹת מִשְׁכְּנוֹתֶ֗יךָ יְהוָ֥ה צְבָאֽוֹת׃"]},{"type":"verse","number":3,"content":["נִכְסְפָ֬ה וְגַם־כָּלְתָ֨ה ׀ נַפְשִׁי֮ לְחַצְר֪וֹת יְה֫וָ֥ה לִבִּ֥י וּבְשָׂרִ֑י יְ֝רַנְּנ֗וּ אֶ֣ל אֵֽל־חָֽי׃"]},{"type":"verse","number":4,"content":["גַּם־צִפּ֨וֹר ׀ מָ֪צְאָה בַ֡יִת וּדְר֤וֹר ׀ קֵ֥ן לָהּ֮ אֲשֶׁר־שָׁ֪תָה אֶפְרֹ֫חֶ֥יהָ אֶֽת־מִ֭זְבְּחוֹתֶיךָ יְהוָ֣ה צְבָא֑וֹת מַ֝לְכִּ֗י וֵאלֹהָֽי׃"]},{"type":"verse","number":5,"content":["אַ֭שְׁרֵי יוֹשְׁבֵ֣י בֵיתֶ֑ךָ ע֝֗וֹד יְֽהַלְל֥וּךָ סֶּֽלָה׃"]},{"type":"verse","number":6,"content":["אַשְׁרֵ֣י אָ֭דָם עֽוֹז־ל֥וֹ בָ֑ךְ מְ֝סִלּ֗וֹת בִּלְבָבָֽם׃"]},{"type":"verse","number":7,"content":["עֹבְרֵ֤י ׀ בְּעֵ֣מֶק הַ֭בָּכָא מַעְיָ֣ן יְשִׁית֑וּהוּ גַּם־בְּ֝רָכ֗וֹת יַעְטֶ֥ה מוֹרֶֽה׃"]},{"type":"verse","number":8,"content":["יֵ֭לְכוּ מֵחַ֣יִל אֶל־חָ֑יִל יֵרָאֶ֖ה אֶל־אֱלֹהִ֣ים בְּצִיּֽוֹן׃"]},{"type":"verse","number":9,"content":["יְה֘וָ֤ה אֱלֹהִ֣ים צְ֭בָאוֹת שִׁמְעָ֣ה תְפִלָּתִ֑י הַאֲזִ֨ינָה אֱלֹהֵ֖י יַעֲקֹ֣ב סֶֽלָה׃"]},{"type":"verse","number":10,"content":["מָ֭גִנֵּנוּ רְאֵ֣ה אֱלֹהִ֑ים וְ֝הַבֵּ֗ט פְּנֵ֣י מְשִׁיחֶֽךָ׃"]},{"type":"verse","number":11,"content":["כִּ֤י טֽוֹב־י֥וֹם בַּחֲצֵרֶ֗יךָ מֵ֫אָ֥לֶף בָּחַ֗רְתִּי הִ֭סְתּוֹפֵף בְּבֵ֣ית אֱלֹהַ֑י מִ֝דּ֗וּר בְּאָהֳלֵי־רֶֽשַׁע׃"]},{"type":"verse","number":12,"content":["כִּ֤י שֶׁ֨מֶשׁ ׀ וּמָגֵן֮ יְהוָ֪ה אֱלֹ֫הִ֥ים חֵ֣ן וְ֭כָבוֹד יִתֵּ֣ן יְהוָ֑ה לֹ֥א יִמְנַע־ט֝֗וֹב לַֽהֹלְכִ֥ים בְּתָמִֽים׃"]},{"type":"verse","number":13,"content":["יְהוָ֥ה צְבָא֑וֹת אַֽשְׁרֵ֥י אָ֝דָ֗ם בֹּטֵ֥חַ בָּֽךְ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/84.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":84},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/85.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":85},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/83.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":83},"previousChapterAudioLinks":{},"numberOfVerses":13}}