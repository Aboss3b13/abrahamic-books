:4,"content":[{"text":"Yahweh is in his holy temple.","poem":1},{"text":"Yahweh is on his throne in heaven.","poem":2},{"text":"His eyes observe.","poem":1},{"text":"His eyes examine the children of men.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Yahweh examines the righteous,","poem":1},{"text":"but his soul hates the wicked and him who loves violence.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"On the wicked he will rain blazing coals;","poem":1},{"text":"fire, sulfur, and scorching wind shall be the portion of their cup.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"For Yahweh is righteous.","poem":1},{"text":"He loves righteousness.","poem":2},{"lineBreak":true},{"text":"The upright shall see his face.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/11.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":11},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/12.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":12},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/10.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":10},"previousChapterAudioLinks":{},"numberOfVerses":7},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","