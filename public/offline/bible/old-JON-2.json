{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"JON","translationId":"eng_web","name":"Jonah","commonName":"Jonah","title":"The Book of Jonah","order":32,"numberOfChapters":4,"sha256":"23b99d62b85cf28331b0a0e76d43c9e122f5fd421254a6d494c5053249f1c139","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/JON/1.json","firstChapterReference":{"translationId":"eng_web","book":"JON","chapter":1},"lastChapterNumber":4,"lastChapterApiLink":"/api/eng_web/JON/4.json","lastChapterReference":{"translationId":"eng_web","book":"JON","chapter":4},"totalNumberOfVerses":48},"chapter":{"number":2,"content":[{"type":"verse","number":1,"content":["Then Jonah prayed to Yahweh, his God, out of the fish’s belly."]},{"type":"verse","number":2,"content":["He said,",{"text":"“I called because of my affliction to Yahweh.","poem":1},{"text":"He answered me.","poem":2},{"text":"Out of the belly of Sheol","poem":1},{"noteId":4},{"text":"I cried.","poem":1},{"text":"You heard my voice.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"For you threw me into the depths,","poem":1},{"text":"in the heart of the seas.","poem":2},{"text":"The flood was all around me.","poem":1},{"text":"All your waves and your billows passed over me.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"I said, ‘I have been banished from your sight;","poem":1},{"text":"yet I will look again toward your holy temple.’","poem":2}]},{"type":"verse","number":5,"content":[{"text":"The waters surrounded me,","poem":1},{"text":"even to the soul.","poem":2},{"text":"The deep was around me.","poem":1},{"text":"The weeds were wrapped around my head.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"I went down to the bottoms of the mountains.","poem":1},{"text":"The earth barred me in forever;","poem":2},{"lineBreak":true},{"text":"yet you have brought my life up from the pit, Yahweh my God.","poem":2}]},{"type":"line_break"},{"type":"verse","number":7,"content":[{"text":"“When my soul fainted within me, I remembered Yahweh.","poem":1},{"text":"My prayer came in to you, into your holy temple.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Those who regard vain idols forsake their own mercy.","poem":1}]},{"type":"verse","number":9,"content":[{"text":"But I will sacrifice to you with the voice of thanksgiving.","poem":2},{"lineBreak":true},{"text":"I will pay that which I have vowed.","poem":2},{"text":"Salvation belongs to Yahweh.”","poem":1}]},{"type":"verse","number":10,"content":["Then Yahweh spoke to the fish, and it vomited out Jonah on the dry land."]}],"footnotes":[{"noteId":4,"caller":"+","text":"Sheol is the place of the dead.","reference":{"chapter":2,"verse":2}}]},"thisChapterLink":"/api/eng_web/JON/2.json","thisChapterReference":{"translationId":"eng_web","book":"JON","chapter":2},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/JON/3.json","nextChapterReference":{"translationId":"eng_web","book":"JON","chapter":3},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/JON/1.json","previousChapterReference":{"translationId":"eng_web","book":"JON","chapter":1},"previousChapterAudioLinks":{},"numberOfVerses":10},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"JON","translationId":"hbo_wlc","name":"יונה","commonName":"יונה","title":"יונה","order":32,"numberOfChapters":4,"sha256":"dc697d9a1c901376ced9617219fef1b50fb05d5069f039bfd97d8f78a9aa9083","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/JON/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"JON","chapter":1},"lastChapterNumber":4,"lastChapterApiLink":"/api/hbo_wlc/JON/4.json","lastChapterReference":{"translationId":"hbo_wlc","book":"JON","chapter":4},"totalNumberOfVerses":48},"chapter":{"number":2,"content":[{"type":"verse","number":1,"content":["וַיְמַ֤ן יְהוָה֙ דָּ֣ג גָּד֔וֹל לִבְלֹ֖עַ אֶת־יוֹנָ֑ה וַיְהִ֤י יוֹנָה֙ בִּמְעֵ֣י הַדָּ֔ג שְׁלֹשָׁ֥ה יָמִ֖ים וּשְׁלֹשָׁ֥ה לֵילֽוֹת׃"]},{"type":"verse","number":2,"content":["וַיִּתְפַּלֵּ֣ל יוֹנָ֔ה אֶל־יְהוָ֖ה אֱלֹהָ֑יו מִמְּעֵ֖י הַדָּגָֽה׃"]},{"type":"verse","number":3,"content":["וַיֹּ֗אמֶר קָ֠רָאתִי מִצָּ֥רָה לִ֛י אֶל־יְהוָ֖ה וַֽיַּעֲנֵ֑נִי מִבֶּ֧טֶן שְׁא֛וֹל שִׁוַּ֖עְתִּי שָׁמַ֥עְתָּ קוֹלִֽי׃"]},{"type":"verse","number":4,"content":["וַתַּשְׁלִיכֵ֤נִי מְצוּלָה֙ בִּלְבַ֣ב יַמִּ֔ים וְנָהָ֖ר יְסֹבְבֵ֑נִי כָּל־מִשְׁבָּרֶ֥יךָ וְגַלֶּ֖יךָ עָלַ֥י עָבָֽרוּ׃"]},{"type":"verse","number":5,"content":["וַאֲנִ֣י אָמַ֔רְתִּי נִגְרַ֖שְׁתִּי מִנֶּ֣גֶד עֵינֶ֑יךָ אַ֚ךְ אוֹסִ֣יף לְהַבִּ֔יט אֶל־הֵיכַ֖ל קָדְשֶֽׁךָ׃"]},{"type":"verse","number":6,"content":["אֲפָפ֤וּנִי מַ֙יִם֙ עַד־נֶ֔פֶשׁ תְּה֖וֹם יְסֹבְבֵ֑נִי ס֖וּף חָב֥וּשׁ לְרֹאשִֽׁי׃"]},{"type":"verse","number":7,"content":["לְקִצְבֵ֤י הָרִים֙ יָרַ֔דְתִּי הָאָ֛רֶץ בְּרִחֶ֥יהָ בַעֲדִ֖י לְעוֹלָ֑ם וַתַּ֧עַל מִשַּׁ֛חַת חַיַּ֖י יְהוָ֥ה אֱלֹהָֽי׃"]},{"type":"verse","number":8,"content":["בְּהִתְעַטֵּ֤ף עָלַי֙ נַפְשִׁ֔י אֶת־יְהוָ֖ה זָכָ֑רְתִּי וַתָּב֤וֹא אֵלֶ֙יךָ֙ תְּפִלָּתִ֔י אֶל־הֵיכַ֖ל קָדְשֶֽׁךָ׃"]},{"type":"verse","number":9,"content":["מְשַׁמְּרִ֖ים הַבְלֵי־שָׁ֑וְא חַסְדָּ֖ם יַעֲזֹֽבוּ׃"]},{"type":"verse","number":10,"content":["וַאֲנִ֗י בְּק֤וֹל תּוֹדָה֙ אֶזְבְּחָה־לָּ֔ךְ אֲשֶׁ֥ר נָדַ֖רְתִּי אֲשַׁלֵּ֑מָה יְשׁוּעָ֖תָה לַיהוָֽה׃ ס"]},{"type":"verse","number":11,"content":["וַיֹּ֥אמֶר יְהוָ֖ה לַדָּ֑ג וַיָּקֵ֥א אֶת־יוֹנָ֖ה אֶל־הַיַּבָּשָֽׁה׃ פ"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/JON/2.json","thisChapterReference":{"translationId":"hbo_wlc","book":"JON","chapter":2},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/JON/3.json","nextChapterReference":{"translationId":"hbo_wlc","book":"JON","chapter":3},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/JON/1.json","previousChapterReference":{"translationId":"hbo_wlc","book":"JON","chapter":1},"previousChapterAudioLinks":{},"numberOfVerses":11}}