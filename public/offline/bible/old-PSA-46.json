֥וֹת בֹּֽקֶר׃"]},{"type":"verse","number":7,"content":["הָמ֣וּ ג֭וֹיִם מָ֣טוּ מַמְלָכ֑וֹת נָתַ֥ן בְּ֝קוֹל֗וֹ תָּמ֥וּג אָֽרֶץ׃"]},{"type":"verse","number":8,"content":["יְהוָ֣ה צְבָא֣וֹת עִמָּ֑נוּ מִשְׂגָּֽב־לָ֝נוּ אֱלֹהֵ֖י יַעֲקֹ֣ב סֶֽלָה׃"]},{"type":"verse","number":9,"content":["לְֽכוּ־חֲ֭זוּ מִפְעֲל֣וֹת יְהוָ֑ה אֲשֶׁר־שָׂ֖ם שַׁמּ֣וֹת בָּאָֽרֶץ׃"]},{"type":"verse","number":10,"content":["מַשְׁבִּ֥ית מִלְחָמוֹת֮ עַד־קְצֵ֪ה הָ֫אָ֥רֶץ קֶ֣שֶׁת יְ֭שַׁבֵּר וְקִצֵּ֣ץ חֲנִ֑ית עֲ֝גָל֗וֹת יִשְׂרֹ֥ף בָּאֵֽשׁ׃"]},{"type":"verse","number":11,"content":["הַרְפּ֣וּ וּ֭דְעוּ כִּי־אָנֹכִ֣י אֱלֹהִ֑ים אָר֥וּם בַּ֝גּוֹיִ֗ם אָר֥וּם בָּאָֽרֶץ׃"]},{"type":"verse","number":12,"content":["יְהוָ֣ה צְבָא֣וֹת עִמָּ֑נוּ מִשְׂגָּֽב־לָ֝נוּ אֱלֹהֵ֖י יַעֲקֹ֣ב סֶֽלָה׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/46.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":46},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/47.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":47},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/45.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":45},"previousChapterAudioLinks":{},"numberOfVerses":12}}