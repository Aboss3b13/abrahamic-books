{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":46,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. By the sons of Korah. According to Alamoth.",{"noteId":19}]},{"type":"verse","number":1,"content":[{"text":"God is our refuge and strength,","poem":1},{"text":"a very present help in trouble.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Therefore we won’t be afraid, though the earth changes,","poem":1},{"text":"though the mountains are shaken into the heart of the seas;","poem":2},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"though its waters roar and are troubled,","poem":2},{"lineBreak":true},{"text":"though the mountains tremble with their swelling. Selah.","poem":2}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"There is a river, the streams of which make the city of God glad,","poem":1},{"text":"the holy place of the tents of the Most High.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"God is within her. She shall not be moved.","poem":1},{"text":"God will help her at dawn.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"The nations raged. The kingdoms were moved.","poem":1},{"text":"He lifted his voice and the earth melted.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Yahweh of Armies is with us.","poem":1},{"text":"The God of Jacob is our refuge. Selah.","poem":2}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Come, see Yahweh’s works,","poem":1},{"text":"what desolations he has made in the earth.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"He makes wars cease to the end of the earth.","poem":1},{"text":"He breaks the bow, and shatters the spear.","poem":2},{"lineBreak":true},{"text":"He burns the chariots in the fire.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"“Be still, and know that I am God.","poem":1},{"text":"I will be exalted among the nations.","poem":2},{"lineBreak":true},{"text":"I will be exalted in the earth.”","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Yahweh of Armies is with us.","poem":1},{"text":"The God of Jacob is our refuge. Selah.","poem":2}]},{"type":"line_break"}],"footnotes":[{"noteId":19,"caller":"+","text":"Alamoth is a musical term.","reference":{"chapter":46,"verse":0}}]},"thisChapterLink":"/api/eng_web/PSA/46.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":46},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/47.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":47},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/45.json","previousChapterReference":{"