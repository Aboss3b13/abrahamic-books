{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":92,"content":[{"type":"hebrew_subtitle","content":["A Psalm. A song for the Sabbath day."]},{"type":"verse","number":1,"content":[{"text":"It is a good thing to give thanks to Yahweh,","poem":1},{"text":"to sing praises to your name, Most High,","poem":2}]},{"type":"verse","number":2,"content":[{"text":"to proclaim your loving kindness in the morning,","poem":1},{"text":"and your faithfulness every night,","poem":2}]},{"type":"verse","number":3,"content":[{"text":"with the ten-stringed lute, with the harp,","poem":1},{"text":"and with the melody of the lyre.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"For you, Yahweh, have made me glad through your work.","poem":1},{"text":"I will triumph in the works of your hands.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"How great are your works, Yahweh!","poem":1},{"text":"Your thoughts are very deep.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"A senseless man doesn’t know,","poem":1},{"text":"neither does a fool understand this:","poem":2}]},{"type":"verse","number":7,"content":[{"text":"though the wicked spring up as the grass,","poem":1},{"text":"and all the evildoers flourish,","poem":2},{"lineBreak":true},{"text":"they will be destroyed forever.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"But you, Yahweh, are on high forever more.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"For behold, your enemies, Yahweh,","poem":1},{"text":"for behold, your enemies shall perish.","poem":2},{"lineBreak":true},{"text":"All the evildoers will be scattered.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"But you have exalted my horn like that of the wild ox.","poem":1},{"text":"I am anointed with fresh oil.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"My eye has also seen my enemies.","poem":1},{"text":"My ears have heard of the wicked enemies who rise up against me.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"The righteous shall flourish like the palm tree.","poem":1},{"text":"He will grow like a cedar in Lebanon.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"They are planted in Yahweh’s house.","poem":1},{"text":"They will flourish in our God’s courts.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"They will still produce fruit in old age.","poem":1},{"text":"They will be full of sap and green,","poem":2},{"lineBreak":true}]},{"type":"verse","number":15,"content":[{"text":"to show that Yahweh is upright.","poem":2},{"text":"He is my rock,","poem":1},{"text":"and there is no unrighteousness in him.","poem":2}]}],"footnotes":[]},"thi