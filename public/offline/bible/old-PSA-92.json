,{"type":"verse","number":4,"content":["עֲֽלֵי־עָ֭שׂוֹר וַעֲלֵי־נָ֑בֶל עֲלֵ֖י הִגָּי֣וֹן בְּכִנּֽוֹר׃"]},{"type":"verse","number":5,"content":["כִּ֤י שִׂמַּחְתַּ֣נִי יְהוָ֣ה בְּפָעֳלֶ֑ךָ בְּֽמַעֲשֵׂ֖י יָדֶ֣יךָ אֲרַנֵּֽן׃"]},{"type":"verse","number":6,"content":["מַה־גָּדְל֣וּ מַעֲשֶׂ֣יךָ יְהוָ֑ה מְ֝אֹ֗ד עָמְק֥וּ מַחְשְׁבֹתֶֽיךָ׃"]},{"type":"verse","number":7,"content":["אִֽישׁ־בַּ֭עַר לֹ֣א יֵדָ֑ע וּ֝כְסִ֗יל לֹא־יָבִ֥ין אֶת־זֹֽאת׃"]},{"type":"verse","number":8,"content":["בִּפְרֹ֤חַ רְשָׁעִ֨ים ׀ כְּמ֥וֹ עֵ֗שֶׂב וַ֭יָּצִיצוּ כָּל־פֹּ֣עֲלֵי אָ֑וֶן לְהִשָּֽׁמְדָ֥ם עֲדֵי־עַֽד׃"]},{"type":"verse","number":9,"content":["וְאַתָּ֥ה מָר֗וֹם לְעֹלָ֥ם יְהוָֽה׃"]},{"type":"verse","number":10,"content":["כִּ֤י הִנֵּ֪ה אֹיְבֶ֡יךָ ׀ יְֽהוָ֗ה כִּֽי־הִנֵּ֣ה אֹיְבֶ֣יךָ יֹאבֵ֑דוּ יִ֝תְפָּרְד֗וּ כָּל־פֹּ֥עֲלֵי אָֽוֶן׃"]},{"type":"verse","number":11,"content":["וַתָּ֣רֶם כִּרְאֵ֣ים קַרְנִ֑י בַּ֝לֹּתִ֗י בְּשֶׁ֣מֶן רַעֲנָֽן׃"]},{"type":"verse","number":12,"content":["וַתַּבֵּ֥ט עֵינִ֗י בְּשׁ֫וּרָ֥י בַּקָּמִ֖ים עָלַ֥י מְרֵעִ֗ים תִּשְׁמַ֥עְנָה אָזְנָֽי׃"]},{"type":"verse","number":13,"content":["צַ֭דִּיק כַּתָּמָ֣ר יִפְרָ֑ח כְּאֶ֖רֶז בַּלְּבָנ֣וֹן יִשְׂגֶּֽה׃"]},{"type":"verse","number":14,"content":["שְׁ֭תוּלִים בְּבֵ֣ית יְהוָ֑ה בְּחַצְר֖וֹת אֱלֹהֵ֣ינוּ יַפְרִֽיחוּ׃"]},{"type":"verse","number":15,"content":["ע֭וֹד יְנוּב֣וּן בְּשֵׂיבָ֑ה דְּשֵׁנִ֖ים וְרַֽעֲנַנִּ֣ים יִהְיֽוּ׃"]},{"type":"verse","number":16,"content":["לְ֭הַגִּיד כִּֽי־יָשָׁ֣ר יְהוָ֑ה צ֝וּרִ֗י וְֽלֹא־עלתה בּֽוֹ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/92.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":92},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/93.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":93},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/91.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":91},"previousChapterAudioLinks":{},"numberOfVerses":16}}