{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":62,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. To Jeduthun. A Psalm by David."]},{"type":"verse","number":1,"content":[{"text":"My soul rests in God alone.","poem":1},{"text":"My salvation is from him.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"He alone is my rock, my salvation, and my fortress.","poem":1},{"text":"I will never be greatly shaken.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"How long will you assault a man?","poem":1},{"text":"Would all of you throw him down,","poem":2},{"lineBreak":true},{"text":"like a leaning wall, like a tottering fence?","poem":2}]},{"type":"verse","number":4,"content":[{"text":"They fully intend to throw him down from his lofty place.","poem":1},{"text":"They delight in lies.","poem":2},{"lineBreak":true},{"text":"They bless with their mouth, but they curse inwardly. Selah.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"My soul, wait in silence for God alone,","poem":1},{"text":"for my expectation is from him.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"He alone is my rock and my salvation, my fortress.","poem":1},{"text":"I will not be shaken.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"My salvation and my honor is with God.","poem":1},{"text":"The rock of my strength, and my refuge, is in God.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Trust in him at all times, you people.","poem":1},{"text":"Pour out your heart before him.","poem":2},{"lineBreak":true},{"text":"God is a refuge for us. Selah.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Surely men of low degree are just a breath,","poem":1},{"text":"and men of high degree are a lie.","poem":2},{"text":"In the balances they will go up.","poem":1},{"text":"They are together lighter than a breath.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Don’t trust in oppression.","poem":1},{"text":"Don’t become vain in robbery.","poem":2},{"text":"If riches increase,","poem":1},{"text":"don’t set your heart on them.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"God has spoken once;","poem":1},{"text":"twice I have heard this,","poem":2},{"lineBreak":true},{"text":"that power belongs to God.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Also to you, Lord, belongs loving kindness,","poem":1},{"text":"for you reward every man according to his work.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/62.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":62},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/63.json","nex