{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":29,"content":[{"type":"hebrew_subtitle","content":["A Psalm by David."]},{"type":"verse","number":1,"content":[{"text":"Ascribe to Yahweh, you sons of the mighty,","poem":1},{"text":"ascribe to Yahweh glory and strength.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Ascribe to Yahweh the glory due to his name.","poem":1},{"text":"Worship Yahweh in holy array.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"Yahweh’s voice is on the waters.","poem":1},{"text":"The God of glory thunders, even Yahweh on many waters.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Yahweh’s voice is powerful.","poem":1},{"text":"Yahweh’s voice is full of majesty.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Yahweh’s voice breaks the cedars.","poem":1},{"text":"Yes, Yahweh breaks in pieces the cedars of Lebanon.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"He makes them also to skip like a calf;","poem":1},{"text":"Lebanon and Sirion like a young, wild ox.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Yahweh’s voice strikes with flashes of lightning.","poem":1}]},{"type":"verse","number":8,"content":[{"text":"Yahweh’s voice shakes the wilderness.","poem":2},{"lineBreak":true},{"text":"Yahweh shakes the wilderness of Kadesh.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Yahweh’s voice makes the deer calve,","poem":1},{"text":"and strips the forests bare.","poem":2},{"lineBreak":true},{"text":"In his temple everything says, “Glory!”","poem":2}]},{"type":"line_break"},{"type":"verse","number":10,"content":[{"text":"Yahweh sat enthroned at the Flood.","poem":1},{"text":"Yes, Yahweh sits as King forever.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Yahweh will give strength to his people.","poem":1},{"text":"Yahweh will bless his people with peace.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/29.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":29},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/30.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":30},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/28.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":28},"previousChapterAudioLinks":{},"numberOfVerses":11},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":29,"content":[{"type":"verse","number":1,"content":["מִזְמ֗וֹר לְדָ֫וִ֥ד הָב֣וּ לַֽ֭יהוָה בְּנֵ֣י אֵלִ֑ים הָב֥וּ לַ֝יהוָ֗ה כָּב֥וֹד וָעֹֽז׃"]},{"type":"verse","number":2,"content":["הָב֣וּ לַֽ֭יהוָה כְּב֣וֹד שְׁמ֑וֹ הִשְׁתַּחֲו֥וּ לַ֝יהוָ֗ה בְּהַדְרַת־קֹֽדֶשׁ׃"]},{"type":"verse","number":3,"content":["ק֥וֹל יְהוָ֗ה עַל־הַ֫מָּ֥יִם אֵֽל־הַכָּב֥וֹד הִרְעִ֑ים יְ֝הוָ֗ה עַל־מַ֥יִם רַבִּֽים׃"]},{"type":"verse","number":4,"content":["קוֹל־יְהוָ֥ה בַּכֹּ֑חַ ק֥וֹל יְ֝הוָ֗ה בֶּהָדָֽר׃"]},{"type":"verse","number":5,"content":["ק֣וֹל יְ֭הוָה שֹׁבֵ֣ר אֲרָזִ֑ים וַיְשַׁבֵּ֥ר יְ֝הוָ֗ה אֶת־אַרְזֵ֥י הַלְּבָנֽוֹן׃"]},{"type":"verse","number":6,"content":["וַיַּרְקִידֵ֥ם כְּמוֹ־עֵ֑גֶל לְבָנ֥וֹן וְ֝שִׂרְיֹ֗ן כְּמ֣וֹ בֶן־רְאֵמִֽים׃"]},{"type":"verse","number":7,"content":["קוֹל־יְהוָ֥ה חֹצֵ֗ב לַהֲב֥וֹת אֵֽשׁ׃"]},{"type":"verse","number":8,"content":["ק֣וֹל יְ֭הוָה יָחִ֣יל מִדְבָּ֑ר יָחִ֥יל יְ֝הוָ֗ה מִדְבַּ֥ר קָדֵֽשׁ׃"]},{"type":"verse","number":9,"content":["ק֤וֹל יְהוָ֨ה ׀ יְחוֹלֵ֣ל אַיָּלוֹת֮ וַֽיֶּחֱשֹׂ֪ף יְעָ֫ר֥וֹת וּבְהֵיכָל֑וֹ כֻּ֝לּ֗וֹ אֹמֵ֥ר כָּבֽוֹד׃"]},{"type":"verse","number":10,"content":["יְ֭הוָה לַמַּבּ֣וּל יָשָׁ֑ב וַיֵּ֥שֶׁב יְ֝הוָ֗ה מֶ֣לֶךְ לְעוֹלָֽם׃"]},{"type":"verse","number":11,"content":["יְֽהוָ֗ה עֹ֭ז לְעַמּ֣וֹ יִתֵּ֑ן יְהוָ֓ה ׀ יְבָרֵ֖ךְ אֶת־עַמּ֣וֹ בַשָּׁלֽוֹם׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/29.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":29},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/30.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":30},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/28.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":28},"previousChapterAudioLinks":{},"numberOfVerses":11}}