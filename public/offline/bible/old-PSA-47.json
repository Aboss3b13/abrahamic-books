{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":47,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. A Psalm by the sons of Korah."]},{"type":"verse","number":1,"content":[{"text":"Oh clap your hands, all you nations.","poem":1},{"text":"Shout to God with the voice of triumph!","poem":2}]},{"type":"verse","number":2,"content":[{"text":"For Yahweh Most High is awesome.","poem":1},{"text":"He is a great King over all the earth.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"He subdues nations under us,","poem":1},{"text":"and peoples under our feet.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"He chooses our inheritance for us,","poem":1},{"text":"the glory of Jacob whom he loved. Selah.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"God has gone up with a shout,","poem":1},{"text":"Yahweh with the sound of a trumpet.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Sing praises to God! Sing praises!","poem":1},{"text":"Sing praises to our King! Sing praises!","poem":2}]},{"type":"verse","number":7,"content":[{"text":"For God is the King of all the earth.","poem":1},{"text":"Sing praises with understanding.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"God reigns over the nations.","poem":1},{"text":"God sits on his holy throne.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"The princes of the peoples are gathered together,","poem":1},{"lineBreak":true},{"text":"the people of the God of Abraham.","poem":1},{"text":"For the shields of the earth belong to God.","poem":2},{"lineBreak":true},{"text":"He is greatly exalted!","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/47.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":47},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/48.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":48},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/46.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":46},"previousChapterAudioLinks":{},"numberOfVerses":9},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"total