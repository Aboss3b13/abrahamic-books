{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":132,"content":[{"type":"hebrew_subtitle","content":["A Song of Ascents."]},{"type":"verse","number":1,"content":[{"text":"Yahweh, remember David and all his affliction,","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"how he swore to Yahweh,","poem":1},{"text":"and vowed to the Mighty One of Jacob:","poem":2}]},{"type":"verse","number":3,"content":[{"text":"“Surely I will not come into the structure of my house,","poem":1},{"text":"nor go up into my bed;","poem":2}]},{"type":"verse","number":4,"content":[{"text":"I will not give sleep to my eyes,","poem":1},{"text":"or slumber to my eyelids,","poem":2}]},{"type":"verse","number":5,"content":[{"text":"until I find out a place for Yahweh,","poem":1},{"text":"a dwelling for the Mighty One of Jacob.”","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Behold, we heard of it in Ephrathah.","poem":1},{"text":"We found it in the field of Jaar.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"“We will go into his dwelling place.","poem":1},{"text":"We will worship at his footstool.”","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Arise, Yahweh, into your resting place,","poem":1},{"text":"you, and the ark of your strength.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Let your priests be clothed with righteousness.","poem":1},{"text":"Let your saints shout for joy!","poem":2}]},{"type":"verse","number":10,"content":[{"text":"For your servant David’s sake,","poem":1},{"text":"don’t turn away the face of your anointed one.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Yahweh has sworn to David in truth.","poem":1},{"text":"He will not turn from it:","poem":2},{"lineBreak":true},{"text":"“I will set the fruit of your body on your throne.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"If your children will keep my covenant,","poem":1},{"text":"my testimony that I will teach them,","poem":2},{"lineBreak":true},{"text":"their children also will sit on your throne forever more.”","poem":2}]},{"type":"verse","number":13,"content":[{"text":"For Yahweh has chosen Zion.","poem":1},{"text":"He has desired it for his habitation.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"“This is my resting place forever.","poem":1},{"text":"I will live here, for I have desired it.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"I will abundantly bless her provision.","poem":1},{"text":"I will satisfy her poor with bread.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"I will also clothe her priests with salvation.","poem":1},{"text":"Her saints will shout aloud for joy.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"I will make the horn of David to bud there.","poem":1},{"text":"I have ordained a lamp for my anointed.","poem":2}]},{"type":"verse","number":18,"content":[{"text":"I will clothe his enemies with shame,","poem":1},{"text":"but on himself, his crown will shine.”","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/132.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":132},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/133.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":133},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/131.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":131},"previousChapterAudioLinks":{},"numberOfVerses":18},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":132,"content":[{"type":"verse","number":1,"content":["שִׁ֗יר הַֽמַּ֫עֲל֥וֹת זְכוֹר־יְהוָ֥ה לְדָוִ֑ד אֵ֝ת כָּל־עֻנּוֹתֽוֹ׃"]},{"type":"verse","number":2,"content":["אֲשֶׁ֣ר נִ֭שְׁבַּע לַיהוָ֑ה נָ֝דַ֗ר לַאֲבִ֥יר יַעֲקֹֽב׃"]},{"type":"verse","number":3,"content":["אִם־אָ֭בֹא בְּאֹ֣הֶל בֵּיתִ֑י אִם־אֶ֝עֱלֶ֗ה עַל־עֶ֥רֶשׂ יְצוּעָֽי׃"]},{"type":"verse","number":4,"content":["אִם־אֶתֵּ֣ן שְׁנַ֣ת לְעֵינָ֑י לְֽעַפְעַפַּ֥י תְּנוּמָֽה׃"]},{"type":"verse","number":5,"content":["עַד־אֶמְצָ֣א מָ֭קוֹם לַיהוָ֑ה מִ֝שְׁכָּנ֗וֹת לַאֲבִ֥יר יַעֲקֹֽב׃"]},{"type":"verse","number":6,"content":["הִנֵּֽה־שְׁמַֽעֲנ֥וּהָ בְאֶפְרָ֑תָה מְ֝צָאנ֗וּהָ בִּשְׂדֵי־יָֽעַר׃"]},{"type":"verse","number":7,"content":["נָב֥וֹאָה לְמִשְׁכְּנוֹתָ֑יו נִ֝שְׁתַּחֲוֶ֗ה לַהֲדֹ֥ם רַגְלָֽיו׃"]},{"type":"verse","number":8,"content":["קוּמָ֣ה יְ֭הוָה לִמְנוּחָתֶ֑ךָ אַ֝תָּ֗ה וַאֲר֥וֹן עֻזֶּֽךָ׃"]},{"type":"verse","number":9,"content":["כֹּהֲנֶ֥יךָ יִלְבְּשׁוּ־צֶ֑דֶק וַחֲסִידֶ֥יךָ יְרַנֵּֽנוּ׃"]},{"type":"verse","number":10,"content":["בַּ֭עֲבוּר דָּוִ֣ד עַבְדֶּ֑ךָ אַל־תָּ֝שֵׁ֗ב פְּנֵ֣י מְשִׁיחֶֽךָ׃"]},{"type":"verse","number":11,"content":["נִשְׁבַּֽע־יְהוָ֨ה ׀ לְדָוִ֡ד אֱמֶת֮ לֹֽא־יָשׁ֪וּב מִ֫מֶּ֥נָּה מִפְּרִ֥י בִטְנְךָ֑ אָ֝שִׁ֗ית לְכִסֵּא־לָֽךְ׃"]},{"type":"verse","number":12,"content":["אִֽם־יִשְׁמְר֬וּ בָנֶ֨יךָ ׀ בְּרִיתִי֮ וְעֵדֹתִ֥י ז֗וֹ אֲלַ֫מְּדֵ֥ם גַּם־בְּנֵיהֶ֥ם עֲדֵי־עַ֑ד יֵ֝שְׁב֗וּ לְכִסֵּא־לָֽךְ׃"]},{"type":"verse","number":13,"content":["כִּֽי־בָחַ֣ר יְהוָ֣ה בְּצִיּ֑וֹן אִ֝וָּ֗הּ לְמוֹשָׁ֥ב לֽוֹ׃"]},{"type":"verse","number":14,"content":["זֹאת־מְנוּחָתִ֥י עֲדֵי־עַ֑ד פֹּֽה־אֵ֝שֵׁ֗ב כִּ֣י אִוִּתִֽיהָ׃"]},{"type":"verse","number":15,"content":["צֵ֭ידָהּ בָּרֵ֣ךְ אֲבָרֵ֑ךְ אֶ֝בְיוֹנֶ֗יהָ אַשְׂבִּ֥יעַֽ לָֽחֶם׃"]},{"type":"verse","number":16,"content":["וְֽ֭כֹהֲנֶיהָ אַלְבִּ֣ישׁ יֶ֑שַׁע וַ֝חֲסִידֶ֗יהָ רַנֵּ֥ן יְרַנֵּֽנוּ׃"]},{"type":"verse","number":17,"content":["שָׁ֤ם אַצְמִ֣יחַ קֶ֣רֶן לְדָוִ֑ד עָרַ֥כְתִּי נֵ֝֗ר לִמְשִׁיחִֽי׃"]},{"type":"verse","number":18,"content":["א֭וֹיְבָיו אַלְבִּ֣ישׁ בֹּ֑שֶׁת וְ֝עָלָ֗יו יָצִ֥יץ נִזְרֽוֹ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/132.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":132},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/133.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":133},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/131.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":131},"previousChapterAudioLinks":{},"numberOfVerses":18}}