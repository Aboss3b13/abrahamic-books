{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":60,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. To the tune of “The Lily of the Covenant.” A teaching poem by David, when he fought with Aram Naharaim and with Aram Zobah, and Joab returned, and killed twelve thousand of Edom in the Valley of Salt."]},{"type":"verse","number":1,"content":[{"text":"God, you have rejected us.","poem":1},{"text":"You have broken us down.","poem":2},{"text":"You have been angry.","poem":1},{"text":"Restore us, again.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"You have made the land tremble.","poem":1},{"text":"You have torn it.","poem":2},{"text":"Mend its fractures,","poem":1},{"text":"for it quakes.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"You have shown your people hard things.","poem":1},{"text":"You have made us drink the wine that makes us stagger.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"You have given a banner to those who fear you,","poem":1},{"text":"that it may be displayed because of the truth. Selah.","poem":2}]},{"type":"line_break"},{"type":"verse","number":5,"content":[{"text":"So that your beloved may be delivered,","poem":1},{"text":"save with your right hand, and answer us.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"God has spoken from his sanctuary:","poem":1},{"text":"“I will triumph.","poem":2},{"lineBreak":true},{"text":"I will divide Shechem,","poem":2},{"lineBreak":true},{"text":"and measure out the valley of Succoth.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Gilead is mine, and Manasseh is mine.","poem":1},{"text":"Ephraim also is the defense of my head.","poem":2},{"lineBreak":true},{"text":"Judah is my scepter.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Moab is my wash basin.","poem":1},{"text":"I will throw my sandal on Edom.","poem":2},{"lineBreak":true},{"text":"I shout in triumph over Philistia.”","poem":2}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"Who will bring me into the strong city?","poem":1},{"text":"Who has led me to Edom?","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Haven’t you, God, rejected us?","poem":1},{"text":"You don’t go out with our armies, God.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Give us help against the adversary,","poem":1},{"text":"for the help of man is vain.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Through God we will do valiantly,","poem":1},{"text":"for it is he who will tread down our adversaries.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/60.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":60},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/61.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":61},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/59.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":59},"previousChapterAudioLinks":{},"numberOfVerses":12},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":60,"content":[{"type":"verse","number":1,"content":["לַ֭מְנַצֵּחַ עַל־שׁוּשַׁ֣ן עֵד֑וּת מִכְתָּ֖ם לְדָוִ֣ד לְלַמֵּֽד׃"]},{"type":"verse","number":2,"content":["בְּהַצּוֹת֨וֹ ׀ אֶ֥ת אֲרַ֣ם נַהֲרַיִם֮ וְאֶת־אֲרַ֪ם צ֫וֹבָ֥ה וַיָּ֤שָׁב יוֹאָ֗ב וַיַּ֣ךְ אֶת־אֱד֣וֹם בְּגֵיא־מֶ֑לַח שְׁנֵ֖ים עָשָׂ֣ר אָֽלֶף׃"]},{"type":"verse","number":3,"content":["אֱ֭לֹהִים זְנַחְתָּ֣נוּ פְרַצְתָּ֑נוּ אָ֝נַ֗פְתָּ תְּשׁ֣וֹבֵ֥ב לָֽנוּ׃"]},{"type":"verse","number":4,"content":["הִרְעַ֣שְׁתָּה אֶ֣רֶץ פְּצַמְתָּ֑הּ רְפָ֖ה שְׁבָרֶ֣יהָ כִי־מָֽטָה׃"]},{"type":"verse","number":5,"content":["הִרְאִ֣יתָה עַמְּךָ֣ קָשָׁ֑ה הִ֝שְׁקִיתָ֗נוּ יַ֣יִן תַּרְעֵלָֽה׃"]},{"type":"verse","number":6,"content":["נָ֘תַ֤תָּה לִּירֵאֶ֣יךָ נֵּ֭ס לְהִתְנוֹסֵ֑ס מִ֝פְּנֵ֗י קֹ֣שֶׁט סֶֽלָה׃"]},{"type":"verse","number":7,"content":["לְ֭מַעַן יֵחָלְצ֣וּן יְדִידֶ֑יךָ הוֹשִׁ֖יעָה יְמִֽינְךָ֣ ועננו׃"]},{"type":"verse","number":8,"content":["אֱלֹהִ֤ים ׀ דִּבֶּ֥ר בְּקָדְשׁ֗וֹ אֶ֫עְלֹ֥זָה אֲחַלְּקָ֥ה שְׁכֶ֑ם וְעֵ֖מֶק סֻכּ֣וֹת אֲמַדֵּֽד׃"]},{"type":"verse","number":9,"content":["לִ֤י גִלְעָ֨ד ׀ וְלִ֬י מְנַשֶּׁ֗ה וְ֭אֶפְרַיִם מָע֣וֹז רֹאשִׁ֑י יְ֝הוּדָ֗ה מְחֹֽקְקִי׃"]},{"type":"verse","number":10,"content":["מוֹאָ֤ב ׀ סִ֬יר רַחְצִ֗י עַל־אֱ֭דוֹם אַשְׁלִ֣יךְ נַעֲלִ֑י עָ֝לַ֗י פְּלֶ֣שֶׁת הִתְרֹעָֽעִֽי׃"]},{"type":"verse","number":11,"content":["מִ֣י יֹ֭בִלֵנִי עִ֣יר מָצ֑וֹר מִ֖י נָחַ֣נִי עַד־אֱדֽוֹם׃"]},{"type":"verse","number":12,"content":["הֲלֹֽא־אַתָּ֣ה אֱלֹהִ֣ים זְנַחְתָּ֑נוּ וְֽלֹא־תֵצֵ֥א אֱ֝לֹהִ֗ים בְּצִבְאוֹתֵֽינוּ׃"]},{"type":"verse","number":13,"content":["הָֽבָה־לָּ֣נוּ עֶזְרָ֣ת מִצָּ֑ר וְ֝שָׁ֗וְא תְּשׁוּעַ֥ת אָדָם׃"]},{"type":"verse","number":14,"content":["בֵּֽאלֹהִ֥ים נַעֲשֶׂה־חָ֑יִל וְ֝ה֗וּא יָב֥וּס צָרֵֽינוּ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/60.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":60},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/61.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":61},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/59.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":59},"previousChapterAudioLinks":{},"numberOfVerses":14}}