em has gone back.","poem":1},{"text":"They have become filthy together.","poem":2},{"lineBreak":true},{"text":"There is no one who does good, no, not one.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Have the workers of iniquity no knowledge,","poem":1},{"text":"who eat up my people as they eat bread,","poem":2},{"lineBreak":true},{"text":"and don’t call on God?","poem":2}]},{"type":"verse","number":5,"content":[{"text":"There they were in great fear, where no fear was,","poem":1},{"text":"for God has scattered the bones of him who encamps against you.","poem":2},{"text":"You have put them to shame,","poem":1},{"text":"because God has rejected them.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Oh that the salvation of Israel would come out of Zion!","poem":1},{"text":"When God brings back his people from captivity,","poem":2},{"lineBreak":true},{"text":"then Jacob shall rejoice,","poem":2},{"lineBreak":true},{"text":"and Israel shall be glad.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/53.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":53},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/54.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":54},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/52.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":52},"previousChapterAudioLinks":{},"numberOfVerses":6},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/