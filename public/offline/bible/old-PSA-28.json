{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":28,"content":[{"type":"hebrew_subtitle","content":["By David."]},{"type":"verse","number":1,"content":[{"text":"To you, Yahweh, I call.","poem":1},{"text":"My rock, don’t be deaf to me,","poem":2},{"lineBreak":true},{"text":"lest, if you are silent to me,","poem":2},{"lineBreak":true},{"text":"I would become like those who go down into the pit.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Hear the voice of my petitions, when I cry to you,","poem":1},{"text":"when I lift up my hands toward your Most Holy Place.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Don’t draw me away with the wicked,","poem":1},{"text":"with the workers of iniquity who speak peace with their neighbors,","poem":2},{"lineBreak":true},{"text":"but mischief is in their hearts.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Give them according to their work, and according to the wickedness of their doings.","poem":1},{"text":"Give them according to the operation of their hands.","poem":2},{"lineBreak":true},{"text":"Bring back on them what they deserve.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Because they don’t respect the works of Yahweh,","poem":1},{"text":"nor the operation of his hands,","poem":2},{"lineBreak":true},{"text":"he will break them down and not build them up.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Blessed be Yahweh,","poem":1},{"text":"because he has heard the voice of my petitions.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Yahweh is my strength and my shield.","poem":1},{"text":"My heart has trusted in him, and I am helped.","poem":2},{"text":"Therefore my heart greatly rejoices.","poem":1},{"text":"With my song I will thank him.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Yahweh is their strength.","poem":1},{"text":"He is a stronghold of salvation to his anointed.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Save your people,","poem":1},{"text":"and bless your inheritance.","poem":2},{"text":"Be their shepherd also,","poem":1},{"text":"and bear them up forever.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/28.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":28},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/29.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":29},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/27.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":27},"previousChapterAudioLinks":{},"numberOfVerses":9},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":28,"content":[{"type":"verse","number":1,"content":["לְדָוִ֡ד אֵ֘לֶ֤יךָ יְהוָ֨ה ׀ אֶקְרָ֗א צוּרִי֮ אַֽל־תֶּחֱרַ֪שׁ מִ֫מֶּ֥נִּי פֶּן־תֶּֽחֱשֶׁ֥ה מִמֶּ֑נִּי וְ֝נִמְשַׁ֗לְתִּי עִם־י֥וֹרְדֵי בֽוֹר׃"]},{"type":"verse","number":2,"content":["שְׁמַ֤ע ק֣וֹל תַּ֭חֲנוּנַי בְּשַׁוְּעִ֣י אֵלֶ֑יךָ בְּנָשְׂאִ֥י יָ֝דַ֗י אֶל־דְּבִ֥יר קָדְשֶֽׁךָ׃"]},{"type":"verse","number":3,"content":["אַל־תִּמְשְׁכֵ֣נִי עִם־רְשָׁעִים֮ וְעִם־פֹּ֪עֲלֵ֫י אָ֥וֶן דֹּבְרֵ֣י שָׁ֭לוֹם עִם־רֵֽעֵיהֶ֑ם וְ֝רָעָ֗ה בִּלְבָבָֽם׃"]},{"type":"verse","number":4,"content":["תֶּן־לָהֶ֣ם כְּפָעֳלָם֮ וּכְרֹ֪עַ מַֽעַלְלֵ֫יהֶ֥ם כְּמַעֲשֵׂ֣ה יְ֭דֵיהֶם תֵּ֣ן לָהֶ֑ם הָשֵׁ֖ב גְּמוּלָ֣ם לָהֶֽם׃"]},{"type":"verse","number":5,"content":["כִּ֤י לֹ֤א יָבִ֡ינוּ אֶל־פְּעֻלֹּ֣ת יְ֭הוָה וְאֶל־מַעֲשֵׂ֣ה יָדָ֑יו יֶ֝הֶרְסֵ֗ם וְלֹ֣א יִבְנֵֽם׃"]},{"type":"verse","number":6,"content":["בָּר֥וּךְ יְהוָ֑ה כִּי־שָׁ֝מַע ק֣וֹל תַּחֲנוּנָֽי׃"]},{"type":"verse","number":7,"content":["יְהוָ֤ה ׀ עֻזִּ֥י וּמָגִנִּי֮ בּ֤וֹ בָטַ֥ח לִבִּ֗י וְֽנֶ֫עֱזָ֥רְתִּי וַיַּעֲלֹ֥ז לִבִּ֑י וּֽמִשִּׁירִ֥י אֲהוֹדֶֽנּוּ׃"]},{"type":"verse","number":8,"content":["יְהוָ֥ה עֹֽז־לָ֑מוֹ וּמָ֘ע֤וֹז יְשׁוּע֖וֹת מְשִׁיח֣וֹ הֽוּא׃"]},{"type":"verse","number":9,"content":["הוֹשִׁ֤יעָה ׀ אֶת־עַמֶּ֗ךָ וּבָרֵ֥ךְ אֶת־נַחֲלָתֶ֑ךָ וּֽרְעֵ֥ם וְ֝נַשְּׂאֵ֗ם עַד־הָעוֹלָֽם׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/28.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":28},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/29.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":29},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/27.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":27},"previousChapterAudioLinks":{},"numberOfVerses":9}}