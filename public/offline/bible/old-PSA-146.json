{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":146,"content":[{"type":"verse","number":1,"content":[{"text":"Praise Yah!","poem":1},{"text":"Praise Yahweh, my soul.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"While I live, I will praise Yahweh.","poem":1},{"text":"I will sing praises to my God as long as I exist.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Don’t put your trust in princes,","poem":1},{"text":"in a son of man in whom there is no help.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"His spirit departs, and he returns to the earth.","poem":1},{"text":"In that very day, his thoughts perish.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Happy is he who has the God of Jacob for his help,","poem":1},{"text":"whose hope is in Yahweh, his God,","poem":2}]},{"type":"verse","number":6,"content":[{"text":"who made heaven and earth,","poem":1},{"text":"the sea, and all that is in them;","poem":2},{"lineBreak":true},{"text":"who keeps truth forever;","poem":2}]},{"type":"verse","number":7,"content":[{"text":"who executes justice for the oppressed;","poem":1},{"text":"who gives food to the hungry.","poem":2},{"text":"Yahweh frees the prisoners.","poem":1}]},{"type":"verse","number":8,"content":[{"text":"Yahweh opens the eyes of the blind.","poem":2},{"lineBreak":true},{"text":"Yahweh raises up those who are bowed down.","poem":2},{"lineBreak":true},{"text":"Yahweh loves the righteous.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Yahweh preserves the foreigners.","poem":1},{"text":"He upholds the fatherless and widow,","poem":2},{"lineBreak":true},{"text":"but he turns the way of the wicked upside down.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Yahweh will reign forever;","poem":1},{"text":"your God, O Zion, to all generations.","poem":2},{"text":"Praise Yah!","poem":1}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/146.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":146},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/147.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":147},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/145.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":145},"previousChapterAudioLinks":{},"numberOfVerses":10},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":146,"content":[{"type":"verse","number":1,"content":["הַֽלְלוּ־יָ֡הּ הַלְלִ֥י נַ֝פְשִׁ֗י אֶת־יְהוָֽה׃"]},{"type":"verse","number":2,"content":["אֲהַלְלָ֣ה יְהוָ֣ה בְּחַיָּ֑י אֲזַמְּרָ֖ה לֵֽאלֹהַ֣י בְּעוֹדִֽי׃"]},{"type":"verse","number":3,"content":["אַל־תִּבְטְח֥וּ בִנְדִיבִ֑ים בְּבֶן־אָדָ֓ם ׀ שֶׁ֤אֵֽין ל֥וֹ תְשׁוּעָֽה׃"]},{"type":"verse","number":4,"content":["תֵּצֵ֣א ר֭וּחוֹ יָשֻׁ֣ב לְאַדְמָת֑וֹ בַּיּ֥וֹם הַ֝ה֗וּא אָבְד֥וּ עֶשְׁתֹּנֹתָֽיו׃"]},{"type":"verse","number":5,"content":["אַשְׁרֵ֗י שֶׁ֤אֵ֣ל יַעֲקֹ֣ב בְּעֶזְר֑וֹ שִׂ֝בְר֗וֹ עַל־יְהוָ֥ה אֱלֹהָֽיו׃"]},{"type":"verse","number":6,"content":["עֹשֶׂ֤ה ׀ שָׁ֘מַ֤יִם וָאָ֗רֶץ אֶת־הַיָּ֥ם וְאֶת־כָּל־אֲשֶׁר־בָּ֑ם הַשֹּׁמֵ֖ר אֱמֶ֣ת לְעוֹלָֽם׃"]},{"type":"verse","number":7,"content":["עֹשֶׂ֤ה מִשְׁפָּ֨ט ׀ לָעֲשׁוּקִ֗ים נֹתֵ֣ן לֶ֭חֶם לָרְעֵבִ֑ים יְ֝הוָ֗ה מַתִּ֥יר אֲסוּרִֽים׃"]},{"type":"verse","number":8,"content":["יְהוָ֤ה ׀ פֹּ֘קֵ֤חַ עִוְרִ֗ים יְ֭הוָה זֹקֵ֣ף כְּפוּפִ֑ים יְ֝הוָ֗ה אֹהֵ֥ב צַדִּיקִֽים׃"]},{"type":"verse","number":9,"content":["יְהוָ֤ה ׀ שֹׁ֘מֵ֤ר אֶת־גֵּרִ֗ים יָת֣וֹם וְאַלְמָנָ֣ה יְעוֹדֵ֑ד וְדֶ֖רֶךְ רְשָׁעִ֣ים יְעַוֵּֽת׃"]},{"type":"verse","number":10,"content":["יִמְלֹ֤ךְ יְהוָ֨ה ׀ לְעוֹלָ֗ם אֱלֹהַ֣יִךְ צִ֭יּוֹן לְדֹ֥ר וָדֹ֗ר הַֽלְלוּ־יָֽהּ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/146.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":146},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/147.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":147},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/145.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":145},"previousChapterAudioLinks":{},"numberOfVerses":10}}