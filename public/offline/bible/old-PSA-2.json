ֲ֝דֹנָ֗י יִלְעַג־לָֽמוֹ׃"]},{"type":"verse","number":5,"content":["אָ֤ז יְדַבֵּ֣ר אֵלֵ֣ימוֹ בְאַפּ֑וֹ וּֽבַחֲרוֹנ֥וֹ יְבַהֲלֵֽמוֹ׃"]},{"type":"verse","number":6,"content":["וַ֭אֲנִי נָסַ֣כְתִּי מַלְכִּ֑י עַל־צִ֝יּ֗וֹן הַר־קָדְשִֽׁי׃"]},{"type":"verse","number":7,"content":["אֲסַפְּרָ֗ה אֶֽ֫ל חֹ֥ק יְֽהוָ֗ה אָמַ֘ר אֵלַ֥י בְּנִ֥י אַ֑תָּה אֲ֝נִ֗י הַיּ֥וֹם יְלִדְתִּֽיךָ׃"]},{"type":"verse","number":8,"content":["שְׁאַ֤ל מִמֶּ֗נִּי וְאֶתְּנָ֣ה ג֭וֹיִם נַחֲלָתֶ֑ךָ וַ֝אֲחֻזָּתְךָ֗ אַפְסֵי־אָֽרֶץ׃"]},{"type":"verse","number":9,"content":["תְּ֭רֹעֵם בְּשֵׁ֣בֶט בַּרְזֶ֑ל כִּכְלִ֖י יוֹצֵ֣ר תְּנַפְּצֵֽם׃"]},{"type":"verse","number":10,"content":["וְ֭עַתָּה מְלָכִ֣ים הַשְׂכִּ֑ילוּ הִ֝וָּסְר֗וּ שֹׁ֣פְטֵי אָֽרֶץ׃"]},{"type":"verse","number":11,"content":["עִבְד֣וּ אֶת־יְהוָ֣ה בְּיִרְאָ֑ה וְ֝גִ֗ילוּ בִּרְעָדָֽה׃"]},{"type":"verse","number":12,"content":["נַשְּׁקוּ־בַ֡ר פֶּן־יֶאֱנַ֤ף ׀ וְתֹ֬אבְדוּ דֶ֗רֶךְ כִּֽי־יִבְעַ֣ר כִּמְעַ֣ט אַפּ֑וֹ אַ֝שְׁרֵ֗י כָּל־ח֥וֹסֵי בֽוֹ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/2.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":2},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/3.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":3},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/1.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"previousChapterAudioLinks":{},"numberOfVerses":12}}