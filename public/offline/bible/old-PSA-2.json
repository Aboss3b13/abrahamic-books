{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":2,"content":[{"type":"verse","number":1,"content":[{"text":"Why do the nations rage,","poem":1},{"text":"and the peoples plot a vain thing?","poem":2}]},{"type":"verse","number":2,"content":[{"text":"The kings of the earth take a stand,","poem":1},{"text":"and the rulers take counsel together,","poem":2},{"lineBreak":true},{"text":"against Yahweh, and against his Anointed,","poem":2},{"noteId":1},{"text":"saying,","poem":2}]},{"type":"verse","number":3,"content":[{"text":"“Let’s break their bonds apart,","poem":1},{"text":"and cast their cords from us.”","poem":2}]},{"type":"verse","number":4,"content":[{"text":"He who sits in the heavens will laugh.","poem":1},{"text":"The Lord","poem":2},{"noteId":2},{"text":"will have them in derision.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Then he will speak to them in his anger,","poem":1},{"text":"and terrify them in his wrath:","poem":2}]},{"type":"verse","number":6,"content":[{"text":"“Yet I have set my King on my holy hill of Zion.”","poem":1}]},{"type":"verse","number":7,"content":[{"text":"I will tell of the decree:","poem":2},{"text":"Yahweh said to me, “You are my son.","poem":1},{"text":"Today I have become your father.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Ask of me, and I will give the nations for your inheritance,","poem":1},{"text":"the uttermost parts of the earth for your possession.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"You shall break them with a rod of iron.","poem":1},{"text":"You shall dash them in pieces like a potter’s vessel.”","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Now therefore be wise, you kings.","poem":1},{"text":"Be instructed, you judges of the earth.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Serve Yahweh with fear,","poem":1},{"text":"and rejoice with trembling.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Give sincere homage to the Son,","poem":1},{"noteId":3},{"text":"lest he be angry, and you perish on the way,","poem":1},{"text":"for his wrath will soon be kindled.","poem":2},{"lineBreak":true},{"text":"Blessed are all those who take refuge in him.","poem":2}]}],"footnotes":[{"noteId":1,"caller":"+","text":"The word “Anointed” is the same as the word for “Messiah” or “Christ”","reference":{"chapter":2,"verse":2}},{"noteId":2,"caller":"+","text":"The word translated “Lord” is “Adonai.”","reference":{"chapter":2,"verse":4}},{"noteId":3,"caller":"+","text":"or, Kiss the son","reference":{"chapter":2,"verse":12}}]},"thisChapterLink":"/api/eng_web/PSA/2.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":2},"thisChapt