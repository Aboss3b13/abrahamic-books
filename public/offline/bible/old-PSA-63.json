{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":63,"content":[{"type":"hebrew_subtitle","content":["A Psalm by David, when he was in the desert of Judah."]},{"type":"verse","number":1,"content":[{"text":"God, you are my God.","poem":1},{"text":"I will earnestly seek you.","poem":2},{"text":"My soul thirsts for you.","poem":1},{"text":"My flesh longs for you,","poem":2},{"lineBreak":true},{"text":"in a dry and weary land, where there is no water.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"So I have seen you in the sanctuary,","poem":1},{"text":"watching your power and your glory.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"Because your loving kindness is better than life,","poem":1},{"text":"my lips shall praise you.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"So I will bless you while I live.","poem":1},{"text":"I will lift up my hands in your name.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"My soul shall be satisfied as with the richest food.","poem":1},{"text":"My mouth shall praise you with joyful lips,","poem":2},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"when I remember you on my bed,","poem":2},{"lineBreak":true},{"text":"and think about you in the night watches.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"For you have been my help.","poem":1},{"text":"I will rejoice in the shadow of your wings.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"My soul stays close to you.","poem":1},{"text":"Your right hand holds me up.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"But those who seek my soul to destroy it","poem":1},{"text":"shall go into the lower parts of the earth.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"They shall be given over to the power of the sword.","poem":1},{"text":"They shall be jackal food.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"But the king shall rejoice in God.","poem":1},{"text":"Everyone who swears by him will praise him,","poem":2},{"lineBreak":true},{"text":"for the mouth of those who speak lies shall be silenced.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/63.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":63},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/64.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":64},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/62.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":62},"previousChapterAudioLinks":{},"numberOfVerses":11},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":63,"content":[{"type":"verse","number":1,"content":["מִזְמ֥וֹר לְדָוִ֑ד בִּ֝הְיוֹת֗וֹ בְּמִדְבַּ֥ר יְהוּדָֽה׃"]},{"type":"verse","number":2,"content":["אֱלֹהִ֤ים ׀ אֵלִ֥י אַתָּ֗ה אֲֽשַׁחֲ֫רֶ֥ךָּ צָמְאָ֬ה לְךָ֨ ׀ נַפְשִׁ֗י כָּמַ֣הּ לְךָ֣ בְשָׂרִ֑י בְּאֶֽרֶץ־צִיָּ֖ה וְעָיֵ֣ף בְּלִי־מָֽיִם׃"]},{"type":"verse","number":3,"content":["כֵּ֭ן בַּקֹּ֣דֶשׁ חֲזִיתִ֑יךָ לִרְא֥וֹת עֻ֝זְּךָ֗ וּכְבוֹדֶֽךָ׃"]},{"type":"verse","number":4,"content":["כִּי־ט֣וֹב חַ֭סְדְּךָ מֵֽחַיִּ֗ים שְׂפָתַ֥י יְשַׁבְּחֽוּנְךָ׃"]},{"type":"verse","number":5,"content":["כֵּ֣ן אֲבָרֶכְךָ֣ בְחַיָּ֑י בְּ֝שִׁמְךָ אֶשָּׂ֥א כַפָּֽי׃"]},{"type":"verse","number":6,"content":["כְּמ֤וֹ חֵ֣לֶב וָ֭דֶשֶׁן תִּשְׂבַּ֣ע נַפְשִׁ֑י וְשִׂפְתֵ֥י רְ֝נָנ֗וֹת יְהַלֶּל־פִּֽי׃"]},{"type":"verse","number":7,"content":["אִם־זְכַרְתִּ֥יךָ עַל־יְצוּעָ֑י בְּ֝אַשְׁמֻר֗וֹת אֶהְגֶּה־בָּֽךְ׃"]},{"type":"verse","number":8,"content":["כִּֽי־הָיִ֣יתָ עֶזְרָ֣תָה לִּ֑י וּבְצֵ֖ל כְּנָפֶ֣יךָ אֲרַנֵּֽן׃"]},{"type":"verse","number":9,"content":["דָּבְקָ֣ה נַפְשִׁ֣י אַחֲרֶ֑יךָ בִּ֝֗י תָּמְכָ֥ה יְמִינֶֽךָ׃"]},{"type":"verse","number":10,"content":["וְהֵ֗מָּה לְ֭שׁוֹאָה יְבַקְשׁ֣וּ נַפְשִׁ֑י יָ֝בֹ֗אוּ בְּֽתַחְתִּיּ֥וֹת הָאָֽרֶץ׃"]},{"type":"verse","number":11,"content":["יַגִּירֻ֥הוּ עַל־יְדֵי ־חָ֑רֶב מְנָ֖ת שֻׁעָלִ֣ים יִהְיֽוּ׃"]},{"type":"verse","number":12,"content":["וְהַמֶּלֶךְ֮ יִשְׂמַ֪ח בֵּאלֹ֫הִ֥ים יִ֭תְהַלֵּל כָּל־הַנִּשְׁבָּ֣ע בּ֑וֹ כִּ֥י יִ֝סָּכֵ֗ר פִּ֣י דֽוֹבְרֵי־שָֽׁקֶר׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/63.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":63},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/64.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":64},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/62.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":62},"previousChapterAudioLinks":{},"numberOfVerses":12}}