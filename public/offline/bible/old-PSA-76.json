{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":76,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. On stringed instruments. A Psalm by Asaph. A song."]},{"type":"verse","number":1,"content":[{"text":"In Judah, God is known.","poem":1},{"text":"His name is great in Israel.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"His tabernacle is also in Salem.","poem":1},{"text":"His dwelling place in Zion.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"There he broke the flaming arrows of the bow,","poem":1},{"text":"the shield, and the sword, and the weapons of war. Selah.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Glorious are you, and excellent,","poem":1},{"text":"more than mountains of game.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Valiant men lie plundered,","poem":1},{"text":"they have slept their last sleep.","poem":2},{"lineBreak":true},{"text":"None of the men of war can lift their hands.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"At your rebuke, God of Jacob,","poem":1},{"text":"both chariot and horse are cast into a dead sleep.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"You, even you, are to be feared.","poem":1},{"text":"Who can stand in your sight when you are angry?","poem":2}]},{"type":"verse","number":8,"content":[{"text":"You pronounced judgment from heaven.","poem":1},{"text":"The earth feared, and was silent,","poem":2},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"when God arose to judgment,","poem":2},{"lineBreak":true},{"text":"to save all the afflicted ones of the earth. Selah.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Surely the wrath of man praises you.","poem":1},{"text":"The survivors of your wrath are restrained.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Make vows to Yahweh your God, and fulfill them!","poem":1},{"text":"Let all of his neighbors bring presents to him who is to be feared.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"He will cut off the spirit of princes.","poem":1},{"text":"He is feared by the kings of the earth.","poem":2}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/76.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":76},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/77.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":77},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/75.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":75},"previousChapterAudioLinks":{},"numberOfVerses":12},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":76,"content":[{"type":"verse","number":1,"content":["לַמְנַצֵּ֥חַ בִּנְגִינֹ֑ת מִזְמ֖וֹר לְאָסָ֣ף שִֽׁיר׃"]},{"type":"verse","number":2,"content":["נוֹדָ֣ע בִּֽיהוּדָ֣ה אֱלֹהִ֑ים בְּ֝יִשְׂרָאֵ֗ל גָּד֥וֹל שְׁמֽוֹ׃"]},{"type":"verse","number":3,"content":["וַיְהִ֣י בְשָׁלֵ֣ם סֻכּ֑וֹ וּמְע֖וֹנָת֣וֹ בְצִיּֽוֹן׃"]},{"type":"verse","number":4,"content":["שָׁ֭מָּה שִׁבַּ֣ר רִשְׁפֵי־קָ֑שֶׁת מָגֵ֬ן וְחֶ֖רֶב וּמִלְחָמָ֣ה סֶֽלָה׃"]},{"type":"verse","number":5,"content":["נָ֭אוֹר אַתָּ֥ה אַדִּ֗יר מֵֽהַרְרֵי־טָֽרֶף׃"]},{"type":"verse","number":6,"content":["אֶשְׁתּוֹלְל֨וּ ׀ אַבִּ֣ירֵי לֵ֭ב נָמ֣וּ שְׁנָתָ֑ם וְלֹא־מָצְא֖וּ כָל־אַנְשֵׁי־חַ֣יִל יְדֵיהֶֽם׃"]},{"type":"verse","number":7,"content":["מִ֭גַּעֲרָ֣תְךָ אֱלֹהֵ֣י יַעֲקֹ֑ב נִ֝רְדָּ֗ם וְרֶ֣כֶב וָסֽוּס׃"]},{"type":"verse","number":8,"content":["אַתָּ֤ה ׀ נ֥וֹרָא אַ֗תָּה וּמִֽי־יַעֲמֹ֥ד לְפָנֶ֗יךָ מֵאָ֥ז אַפֶּֽךָ׃"]},{"type":"verse","number":9,"content":["מִ֭שָּׁמַיִם הִשְׁמַ֣עְתָּ דִּ֑ין אֶ֖רֶץ יָֽרְאָ֣ה וְשָׁקָֽטָה׃"]},{"type":"verse","number":10,"content":["בְּקוּם־לַמִּשְׁפָּ֥ט אֱלֹהִ֑ים לְהוֹשִׁ֖יעַ כָּל־עַנְוֵי־אֶ֣רֶץ סֶֽלָה׃"]},{"type":"verse","number":11,"content":["כִּֽי־חֲמַ֣ת אָדָ֣ם תּוֹדֶ֑ךָּ שְׁאֵרִ֖ית חֵמֹ֣ת תַּחְגֹּֽר׃"]},{"type":"verse","number":12,"content":["נִֽדֲר֣וּ וְשַׁלְּמוּ֮ לַיהוָ֪ה אֱֽלֹהֵ֫יכֶ֥ם כָּל־סְבִיבָ֑יו יוֹבִ֥ילוּ שַׁ֝֗י לַמּוֹרָֽא׃"]},{"type":"verse","number":13,"content":["יִ֭בְצֹר ר֣וּחַ נְגִידִ֑ים נ֝וֹרָ֗א לְמַלְכֵי־אָֽרֶץ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/76.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":76},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/77.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":77},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/75.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":75},"previousChapterAudioLinks":{},"numberOfVerses":13}}