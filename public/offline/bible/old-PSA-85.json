{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":85,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. A Psalm by the sons of Korah."]},{"type":"verse","number":1,"content":[{"text":"Yahweh, you have been favorable to your land.","poem":1},{"text":"You have restored the fortunes of Jacob.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"You have forgiven the iniquity of your people.","poem":1},{"text":"You have covered all their sin. Selah.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"You have taken away all your wrath.","poem":1},{"text":"You have turned from the fierceness of your anger.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Turn us, God of our salvation,","poem":1},{"text":"and cause your indignation toward us to cease.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Will you be angry with us forever?","poem":1},{"text":"Will you draw out your anger to all generations?","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Won’t you revive us again,","poem":1},{"text":"that your people may rejoice in you?","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Show us your loving kindness, Yahweh.","poem":1},{"text":"Grant us your salvation.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"I will hear what God, Yahweh, will speak,","poem":1},{"text":"for he will speak peace to his people, his saints;","poem":2},{"lineBreak":true},{"text":"but let them not turn again to folly.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Surely his salvation is near those who fear him,","poem":1},{"text":"that glory may dwell in our land.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"Mercy and truth meet together.","poem":1},{"text":"Righteousness and peace have kissed each other.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Truth springs out of the earth.","poem":1},{"text":"Righteousness has looked down from heaven.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Yes, Yahweh will give that which is good.","poem":1},{"text":"Our land will yield its increase.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Righteousness goes before him,","poem":1},{"text":"and prepares the way for his steps.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/85.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":85},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/86.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":86},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/84.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":84},"previousChapterAudioLinks":{},"numberOfVerses":13},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":85,"content":[{"type":"verse","number":1,"content":["לַמְנַצֵּ֬חַ ׀ לִבְנֵי־קֹ֬רַח מִזְמֽוֹר׃"]},{"type":"verse","number":2,"content":["רָצִ֣יתָ יְהוָ֣ה אַרְצֶ֑ךָ שַׁ֝֗בְתָּ שבות יַעֲקֹֽב׃"]},{"type":"verse","number":3,"content":["נָ֭שָׂאתָ עֲוֺ֣ן עַמֶּ֑ךָ כִּסִּ֖יתָ כָל־חַטָּאתָ֣ם סֶֽלָה׃"]},{"type":"verse","number":4,"content":["אָסַ֥פְתָּ כָל־עֶבְרָתֶ֑ךָ הֱ֝שִׁיב֗וֹתָ מֵחֲר֥וֹן אַפֶּֽךָ׃"]},{"type":"verse","number":5,"content":["שׁ֭וּבֵנוּ אֱלֹהֵ֣י יִשְׁעֵ֑נוּ וְהָפֵ֖ר כַּֽעַסְךָ֣ עִמָּֽנוּ׃"]},{"type":"verse","number":6,"content":["הַלְעוֹלָ֥ם תֶּֽאֱנַף־בָּ֑נוּ תִּמְשֹׁ֥ךְ אַ֝פְּךָ֗ לְדֹ֣ר וָדֹֽר׃"]},{"type":"verse","number":7,"content":["הֲֽלֹא־אַ֭תָּה תָּשׁ֣וּב תְּחַיֵּ֑נוּ וְ֝עַמְּךָ֗ יִשְׂמְחוּ־בָֽךְ׃"]},{"type":"verse","number":8,"content":["הַרְאֵ֣נוּ יְהוָ֣ה חַסְדֶּ֑ךָ וְ֝יֶשְׁעֲךָ֗ תִּתֶּן־לָֽנוּ׃"]},{"type":"verse","number":9,"content":["אֶשְׁמְעָ֗ה מַה־יְדַבֵּר֮ הָאֵ֪ל ׀ יְה֫וָ֥ה כִּ֤י ׀ יְדַבֵּ֬ר שָׁל֗וֹם אֶל־עַמּ֥וֹ וְאֶל־חֲסִידָ֑יו וְֽאַל־יָשׁ֥וּבוּ לְכִסְלָֽה׃"]},{"type":"verse","number":10,"content":["אַ֤ךְ ׀ קָר֣וֹב לִירֵאָ֣יו יִשְׁע֑וֹ לִשְׁכֹּ֖ן כָּב֣וֹד בְּאַרְצֵֽנוּ׃"]},{"type":"verse","number":11,"content":["חֶֽסֶד־וֶאֱמֶ֥ת נִפְגָּ֑שׁוּ צֶ֖דֶק וְשָׁל֣וֹם נָשָֽׁקוּ׃"]},{"type":"verse","number":12,"content":["אֱ֭מֶת מֵאֶ֣רֶץ תִּצְמָ֑ח וְ֝צֶ֗דֶק מִשָּׁמַ֥יִם נִשְׁקָֽף׃"]},{"type":"verse","number":13,"content":["גַּם־יְ֭הוָה יִתֵּ֣ן הַטּ֑וֹב וְ֝אַרְצֵ֗נוּ תִּתֵּ֥ן יְבוּלָֽהּ׃"]},{"type":"verse","number":14,"content":["צֶ֭דֶק לְפָנָ֣יו יְהַלֵּ֑ךְ וְיָשֵׂ֖ם לְדֶ֣רֶךְ פְּעָמָֽיו׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/85.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":85},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/86.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":86},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/84.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":84},"previousChapterAudioLinks":{},"numberOfVerses":14}}