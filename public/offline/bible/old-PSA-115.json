{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":115,"content":[{"type":"verse","number":1,"content":[{"text":"Not to us, Yahweh, not to us,","poem":1},{"text":"but to your name give glory,","poem":2},{"lineBreak":true},{"text":"for your loving kindness, and for your truth’s sake.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Why should the nations say,","poem":1},{"text":"“Where is their God, now?”","poem":2}]},{"type":"verse","number":3,"content":[{"text":"But our God is in the heavens.","poem":1},{"text":"He does whatever he pleases.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Their idols are silver and gold,","poem":1},{"text":"the work of men’s hands.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"They have mouths, but they don’t speak.","poem":1},{"text":"They have eyes, but they don’t see.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"They have ears, but they don’t hear.","poem":1},{"text":"They have noses, but they don’t smell.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"They have hands, but they don’t feel.","poem":1},{"text":"They have feet, but they don’t walk,","poem":2},{"lineBreak":true},{"text":"neither do they speak through their throat.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Those who make them will be like them;","poem":1},{"text":"yes, everyone who trusts in them.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Israel, trust in Yahweh!","poem":1},{"text":"He is their help and their shield.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"House of Aaron, trust in Yahweh!","poem":1},{"text":"He is their help and their shield.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"You who fear Yahweh, trust in Yahweh!","poem":1},{"text":"He is their help and their shield.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Yahweh remembers us. He will bless us.","poem":1},{"text":"He will bless the house of Israel.","poem":2},{"lineBreak":true},{"text":"He will bless the house of Aaron.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"He will bless those who fear Yahweh,","poem":1},{"text":"both small and great.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"May Yahweh increase you more and more,","poem":1},{"text":"you and your children.","poem":2}]},{"type":"verse","number":15,"content":[{"text":"Blessed are you by Yahweh,","poem":1},{"text":"who made heaven and earth.","poem":2}]},{"type":"verse","number":16,"content":[{"text":"The heavens are Yahweh’s heavens,","poem":1},{"text":"but he has given the earth to the children of men.","poem":2}]},{"type":"verse","number":17,"content":[{"text":"The dead don’t praise Yah,","poem":1},{"text":"nor any who go down into silence,","poem":2}]},{"type":"verse","number":18,"content":[{"text":"but we will bless Yah,","poem":1},{"text":"from this time forward and forever more.","poem":2},{"text":"Praise Yah!","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/115.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":115},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/116.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":116},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/114.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":114},"previousChapterAudioLinks":{},"numberOfVerses":18},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":115,"content":[{"type":"verse","number":1,"content":["לֹ֤א לָ֥נוּ יְהוָ֗ה לֹ֫א לָ֥נוּ כִּֽי־לְ֭שִׁמְךָ תֵּ֣ן כָּב֑וֹד עַל־חַ֝סְדְּךָ֗ עַל־אֲמִתֶּֽךָ׃"]},{"type":"verse","number":2,"content":["לָ֭מָּה יֹאמְר֣וּ הַגּוֹיִ֑ם אַיֵּה־נָ֝֗א אֱלֹהֵיהֶֽם׃"]},{"type":"verse","number":3,"content":["וֵֽאלֹהֵ֥ינוּ בַשָּׁמָ֑יִם כֹּ֭ל אֲשֶׁר־חָפֵ֣ץ עָשָֽׂה׃"]},{"type":"verse","number":4,"content":["עֲֽ֭צַבֵּיהֶם כֶּ֣סֶף וְזָהָ֑ב מַ֝עֲשֵׂ֗ה יְדֵ֣י אָדָֽם׃"]},{"type":"verse","number":5,"content":["פֶּֽה־לָ֭הֶם וְלֹ֣א יְדַבֵּ֑רוּ עֵינַ֥יִם לָ֝הֶ֗ם וְלֹ֣א יִרְאֽוּ׃"]},{"type":"verse","number":6,"content":["אָזְנַ֣יִם לָ֭הֶם וְלֹ֣א יִשְׁמָ֑עוּ אַ֥ף לָ֝הֶ֗ם וְלֹ֣א יְרִיחֽוּן׃"]},{"type":"verse","number":7,"content":["יְדֵיהֶ֤ם ׀ וְלֹ֬א יְמִישׁ֗וּן רַ֭גְלֵיהֶם וְלֹ֣א יְהַלֵּ֑כוּ לֹֽא־יֶ֝הְגּ֗וּ בִּגְרוֹנָֽם׃"]},{"type":"verse","number":8,"content":["כְּ֭מוֹהֶם יִהְי֣וּ עֹשֵׂיהֶ֑ם כֹּ֭ל אֲשֶׁר־בֹּטֵ֣חַ בָּהֶֽם׃"]},{"type":"verse","number":9,"content":["יִ֭שְׂרָאֵל בְּטַ֣ח בַּיהוָ֑ה עֶזְרָ֖ם וּמָגִנָּ֣ם הֽוּא׃"]},{"type":"verse","number":10,"content":["בֵּ֣ית אַ֭הֲרֹן בִּטְח֣וּ בַיהוָ֑ה עֶזְרָ֖ם וּמָגִנָּ֣ם הֽוּא׃"]},{"type":"verse","number":11,"content":["יִרְאֵ֣י יְ֭הוָה בִּטְח֣וּ בַיהוָ֑ה עֶזְרָ֖ם וּמָגִנָּ֣ם הֽוּא׃"]},{"type":"verse","number":12,"content":["יְהוָה֮ זְכָרָ֪נוּ יְבָ֫רֵ֥ךְ יְ֭בָרֵךְ אֶת־בֵּ֣ית יִשְׂרָאֵ֑ל יְ֝בָרֵ֗ךְ אֶת־בֵּ֥ית אַהֲרֹֽן׃"]},{"type":"verse","number":13,"content":["יְ֭בָרֵךְ יִרְאֵ֣י יְהוָ֑ה הַ֝קְּטַנִּ֗ים עִם־הַגְּדֹלִֽים׃"]},{"type":"verse","number":14,"content":["יֹסֵ֣ף יְהוָ֣ה עֲלֵיכֶ֑ם עֲ֝לֵיכֶ֗ם וְעַל־בְּנֵיכֶֽם׃"]},{"type":"verse","number":15,"content":["בְּרוּכִ֣ים אַ֭תֶּם לַיהוָ֑ה עֹ֝שֵׂ֗ה שָׁמַ֥יִם וָאָֽרֶץ׃"]},{"type":"verse","number":16,"content":["הַשָּׁמַ֣יִם שָׁ֭מַיִם לַיהוָ֑ה וְ֝הָאָ֗רֶץ נָתַ֥ן לִבְנֵי־אָדָֽם׃"]},{"type":"verse","number":17,"content":["לֹ֣א הַ֭מֵּתִים יְהַֽלְלוּ־יָ֑הּ וְ֝לֹ֗א כָּל־יֹרְדֵ֥י דוּמָֽה׃"]},{"type":"verse","number":18,"content":["וַאֲנַ֤חְנוּ ׀ נְבָ֘רֵ֤ךְ יָ֗הּ מֵֽעַתָּ֥ה וְעַד־עוֹלָ֗ם הַֽלְלוּ־יָֽהּ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/115.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":115},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/116.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":116},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/114.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":114},"previousChapterAudioLinks":{},"numberOfVerses":18}}