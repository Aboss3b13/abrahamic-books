{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"JOB","translationId":"eng_web","name":"Job","commonName":"Job","title":"The Book of Job","order":18,"numberOfChapters":42,"sha256":"6dac796e2819a7919823cdaf78d98bff44300681f09e567bccbda12a2dac86c2","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/JOB/1.json","firstChapterReference":{"translationId":"eng_web","book":"JOB","chapter":1},"lastChapterNumber":42,"lastChapterApiLink":"/api/eng_web/JOB/42.json","lastChapterReference":{"translationId":"eng_web","book":"JOB","chapter":42},"totalNumberOfVerses":1070},"chapter":{"number":17,"content":[{"type":"verse","number":1,"content":[{"text":"“My spirit is consumed.","poem":1},{"text":"My days are extinct","poem":2},{"lineBreak":true},{"text":"and the grave is ready for me.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Surely there are mockers with me.","poem":1},{"text":"My eye dwells on their provocation.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"“Now give a pledge. Be collateral for me with yourself.","poem":1},{"text":"Who is there who will strike hands with me?","poem":2}]},{"type":"verse","number":4,"content":[{"text":"For you have hidden their heart from understanding,","poem":1},{"text":"therefore you will not exalt them.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"He who denounces his friends for plunder,","poem":1},{"text":"even the eyes of his children will fail.","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"“But he has made me a byword of the people.","poem":1},{"text":"They spit in my face.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"My eye also is dim by reason of sorrow.","poem":1},{"text":"All my members are as a shadow.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Upright men will be astonished at this.","poem":1},{"text":"The innocent will stir himself up against the godless.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Yet the righteous will hold to his way.","poem":1},{"text":"He who has clean hands will grow stronger and stronger.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"But as for you all, come back.","poem":1},{"text":"I will not find a wise man among you.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"My days are past.","poem":1},{"text":"My plans are broken off,","poem":2},{"lineBreak":true},{"text":"as are the thoughts of my heart.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"They change the night into day,","poem":1},{"text":"saying ‘The light is near’ in the presence of darkness.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"If I look for Sheol","poem":1},{"noteId":7},{"text":"as my house,","poem":1},{"text":"if I have spread my couch in the darkness,","poem":2}]},{"type":"verse","number":14,"content":[{"text":"if I have said to corruption, ‘You are my father,’","poem":1},{"text":"and to the worm, ‘My mother,’ and ‘My sister,’","poem":2}]},{"type":"verse","number":15,"content":[{"text":"where then is my hope?","poem":1},{"text":"As for my hope, who will see it?","poem":2}]},{"type":"verse","number":16,"content":[{"text":"Shall it go down with me to the gates of Sheol,","poem":1},{"noteId":8},{"text":"or descend together into the dust?”","poem":2}]},{"type":"line_break"}],"footnotes":[{"noteId":7,"caller":"+","text":"Sheol is the place of the dead.","reference":{"chapter":17,"verse":13}},{"noteId":8,"caller":"+","text":"Sheol is the place of the dead.","reference":{"chapter":17,"verse":16}}]},"thisChapterLink":"/api/eng_web/JOB/17.json","thisChapterReference":{"translationId":"eng_web","book":"JOB","chapter":17},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/JOB/18.json","nextChapterReference":{"translationId":"eng_web","book":"JOB","chapter":18},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/JOB/16.json","previousChapterReference":{"translationId":"eng_web","book":"JOB","chapter":16},"previousChapterAudioLinks":{},"numberOfVerses":16},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"JOB","translationId":"hbo_wlc","name":"איוב","commonName":"איוב","title":"איוב","order":18,"numberOfChapters":42,"sha256":"40714f6da0dbbbfa33e6e988fa228d1df6b53dc67303267a827d6a609985c62f","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/JOB/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"JOB","chapter":1},"lastChapterNumber":42,"lastChapterApiLink":"/api/hbo_wlc/JOB/42.json","lastChapterReference":{"translationId":"hbo_wlc","book":"JOB","chapter":42},"totalNumberOfVerses":1070},"chapter":{"number":17,"content":[{"type":"verse","number":1,"content":["רוּחִ֣י חֻ֭בָּלָה יָמַ֥י נִזְעָ֗כוּ קְבָרִ֥ים לִֽי׃"]},{"type":"verse","number":2,"content":["אִם־לֹ֣א הֲ֭תֻלִים עִמָּדִ֑י וּ֝בְהַמְּרוֹתָ֗ם תָּלַ֥ן עֵינִֽי׃"]},{"type":"verse","number":3,"content":["שִֽׂימָה־נָּ֭א עָרְבֵ֣נִי עִמָּ֑ךְ מִֽי ה֝֗וּא לְיָדִ֥י יִתָּקֵֽעַ׃"]},{"type":"verse","number":4,"content":["כִּֽי־לִ֭בָּם צָפַ֣נְתָּ מִּשָּׂ֑כֶל עַל־כֵּ֝֗ן לֹ֣א תְרֹמֵֽם׃"]},{"type":"verse","number":5,"content":["לְ֭חֵלֶק יַגִּ֣יד רֵעִ֑ים וְעֵינֵ֖י בָנָ֣יו תִּכְלֶֽנָה׃"]},{"type":"verse","number":6,"content":["וְֽ֭הִצִּגַנִי לִמְשֹׁ֣ל עַמִּ֑ים וְתֹ֖פֶת לְפָנִ֣ים אֶֽהְיֶֽה׃"]},{"type":"verse","number":7,"content":["וַתֵּ֣כַהּ מִכַּ֣עַשׂ עֵינִ֑י וִֽיצֻרַ֖י כַּצֵּ֣ל כֻּלָּֽם׃"]},{"type":"verse","number":8,"content":["יָשֹׁ֣מּוּ יְשָׁרִ֣ים עַל־זֹ֑את וְ֝נָקִ֗י עַל־חָנֵ֥ף יִתְעֹרָֽר׃"]},{"type":"verse","number":9,"content":["וְיֹאחֵ֣ז צַדִּ֣יק דַּרְכּ֑וֹ וּֽטֳהָר־יָ֝דַ֗יִם יֹסִ֥יף אֹֽמֶץ׃"]},{"type":"verse","number":10,"content":["וְֽאוּלָ֗ם כֻּלָּ֣ם תָּ֭שֻׁבוּ וּבֹ֣אוּ נָ֑א וְלֹֽא־אֶמְצָ֖א בָכֶ֣ם חָכָֽם׃"]},{"type":"verse","number":11,"content":["יָמַ֣י עָ֭בְרוּ זִמֹּתַ֣י נִתְּק֑וּ מ֖וֹרָשֵׁ֣י לְבָבִֽי׃"]},{"type":"verse","number":12,"content":["לַ֭יְלָה לְי֣וֹם יָשִׂ֑ימוּ א֝֗וֹר קָר֥וֹב מִפְּנֵי־חֹֽשֶׁךְ׃"]},{"type":"verse","number":13,"content":["אִם־אֲ֭קַוֶּה שְׁא֣וֹל בֵּיתִ֑י בַּ֝חֹ֗שֶׁךְ רִפַּ֥דְתִּי יְצוּעָֽי׃"]},{"type":"verse","number":14,"content":["לַשַּׁ֣חַת קָ֭רָאתִי אָ֣בִי אָ֑תָּה אִמִּ֥י וַ֝אֲחֹתִ֗י לָֽרִמָּֽה׃"]},{"type":"verse","number":15,"content":["וְ֭אַיֵּה אֵפ֣וֹ תִקְוָתִ֑י וְ֝תִקְוָתִ֗י מִ֣י יְשׁוּרֶֽנָּה׃"]},{"type":"verse","number":16,"content":["בַּדֵּ֣י שְׁאֹ֣ל תֵּרַ֑דְנָה אִם־יַ֖חַד עַל־עָפָ֣ר נָֽחַת׃ ס"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/JOB/17.json","thisChapterReference":{"translationId":"hbo_wlc","book":"JOB","chapter":17},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/JOB/18.json","nextChapterReference":{"translationId":"hbo_wlc","book":"JOB