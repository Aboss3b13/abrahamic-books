{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":20,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. A Psalm by David."]},{"type":"verse","number":1,"content":[{"text":"May Yahweh answer you in the day of trouble.","poem":1},{"text":"May the name of the God of Jacob set you up on high,","poem":2},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"send you help from the sanctuary,","poem":2},{"lineBreak":true},{"text":"grant you support from Zion,","poem":2},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"remember all your offerings,","poem":2},{"lineBreak":true},{"text":"and accept your burned sacrifice. Selah.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"May he grant you your heart’s desire,","poem":1},{"text":"and fulfill all your counsel.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"We will triumph in your salvation.","poem":1},{"text":"In the name of our God, we will set up our banners.","poem":2},{"lineBreak":true},{"text":"May Yahweh grant all your requests.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Now I know that Yahweh saves his anointed.","poem":1},{"text":"He will answer him from his holy heaven,","poem":2},{"lineBreak":true},{"text":"with the saving strength of his right hand.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Some trust in chariots, and some in horses,","poem":1},{"text":"but we trust in the name of Yahweh our God.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"They are bowed down and fallen,","poem":1},{"text":"but we rise up, and stand upright.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Save, Yahweh!","poem":1},{"text":"Let the King answer us when we call!","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/20.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":20},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/21.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":21},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/19.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":19},"previousChapterAudioLinks":{},"numberOfVerses":9},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":20,"content":[{"type":"verse","number":1,"content":["לַמְנַצֵּ֗חַ מִזְמ֥וֹר לְדָוִֽד׃"]},{"type":"verse","number":2,"content":["יַֽעַנְךָ֣ יְ֭הוָה בְּי֣וֹם צָרָ֑ה יְ֝שַׂגֶּבְךָ֗ שֵׁ֤ם ׀ אֱלֹהֵ֬י יַעֲקֹֽב׃"]},{"type":"verse","number":3,"content":["יִשְׁלַֽח־עֶזְרְךָ֥ מִקֹּ֑דֶשׁ וּ֝מִצִּיּ֗וֹן יִסְעָדֶֽךָּ׃"]},{"type":"verse","number":4,"content":["יִזְכֹּ֥ר כָּל־מִנְחֹתֶ֑ךָ וְעוֹלָתְךָ֖ יְדַשְּׁנֶ֣ה סֶֽלָה׃"]},{"type":"verse","number":5,"content":["יִֽתֶּן־לְךָ֥ כִלְבָבֶ֑ךָ וְֽכָל־עֲצָתְךָ֥ יְמַלֵּֽא׃"]},{"type":"verse","number":6,"content":["נְרַנְּנָ֤ה ׀ בִּ֘ישׁ֤וּעָתֶ֗ךָ וּבְשֵֽׁם־אֱלֹהֵ֥ינוּ נִדְגֹּ֑ל יְמַלֵּ֥א יְ֝הוָ֗ה כָּל־מִשְׁאֲלוֹתֶֽיךָ ׃"]},{"type":"verse","number":7,"content":["עַתָּ֤ה יָדַ֗עְתִּי כִּ֤י הוֹשִׁ֥יעַ ׀ יְהוָ֗ה מְשִׁ֫יח֥וֹ יַ֭עֲנֵהוּ מִשְּׁמֵ֣י קָדְשׁ֑וֹ בִּ֝גְבֻר֗וֹת יֵ֣שַׁע יְמִינֽוֹ׃"]},{"type":"verse","number":8,"content":["אֵ֣לֶּה בָ֭רֶכֶב וְאֵ֣לֶּה בַסּוּסִ֑ים וַאֲנַ֓חְנוּ ׀ בְּשֵׁם־יְהוָ֖ה אֱלֹהֵ֣ינוּ נַזְכִּֽיר׃"]},{"type":"verse","number":9,"content":["הֵ֭מָּה כָּרְע֣וּ וְנָפָ֑לוּ וַאֲנַ֥חְנוּ קַּ֝֗מְנוּ וַנִּתְעוֹדָֽד׃"]},{"type":"verse","number":10,"content":["יְהוָ֥ה הוֹשִׁ֑יעָה הַ֝מֶּ֗לֶךְ יַעֲנֵ֥נוּ בְיוֹם־קָרְאֵֽנוּ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/20.