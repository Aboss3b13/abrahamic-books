{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":57,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. To the tune of “Do Not Destroy.” A poem by David, when he fled from Saul, in the cave."]},{"type":"verse","number":1,"content":[{"text":"Be merciful to me, God, be merciful to me,","poem":1},{"text":"for my soul takes refuge in you.","poem":2},{"text":"Yes, in the shadow of your wings, I will take refuge,","poem":1},{"text":"until disaster has passed.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"I cry out to God Most High,","poem":1},{"lineBreak":true},{"text":"to God who accomplishes my requests for me.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"He will send from heaven, and save me,","poem":1},{"text":"he rebukes the one who is pursuing me. Selah.","poem":2},{"text":"God will send out his loving kindness and his truth.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"My soul is among lions.","poem":1},{"text":"I lie among those who are set on fire,","poem":2},{"lineBreak":true},{"text":"even the sons of men, whose teeth are spears and arrows,","poem":2},{"lineBreak":true},{"text":"and their tongue a sharp sword.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"Be exalted, God, above the heavens!","poem":1},{"text":"Let your glory be above all the earth!","poem":2}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"They have prepared a net for my steps.","poem":1},{"text":"My soul is bowed down.","poem":2},{"text":"They dig a pit before me.","poem":1},{"text":"They fall into the middle of it themselves. Selah.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"My heart is steadfast, God.","poem":1},{"text":"My heart is steadfast.","poem":2},{"lineBreak":true},{"text":"I will sing, yes, I will sing praises.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Wake up, my glory! Wake up, lute and harp!","poem":1},{"text":"I will wake up the dawn.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"I will give thanks to you, Lord, among the peoples.","poem":1},{"text":"I will sing praises to you among the nations.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"For your great loving kindness reaches to the heavens,","poem":1},{"text":"and your truth to the skies.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Be exalted, God, above the heavens.","poem":1},{"text":"Let your glory be over all the earth.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/57.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":57},"thisChapterAudioLinks":{},"nextChapterApiLink":