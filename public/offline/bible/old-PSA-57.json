 ׀ וְֽיוֹשִׁיעֵ֗נִי חֵרֵ֣ף שֹׁאֲפִ֣י סֶ֑לָה יִשְׁלַ֥ח אֱ֝לֹהִ֗ים חַסְדּ֥וֹ וַאֲמִתּֽוֹ׃"]},{"type":"verse","number":5,"content":["נַפְשִׁ֤י ׀ בְּת֥וֹךְ לְבָאִם֮ אֶשְׁכְּבָ֪ה לֹ֫הֲטִ֥ים בְּֽנֵי־אָדָ֗ם שִׁ֭נֵּיהֶם חֲנִ֣ית וְחִצִּ֑ים וּ֝לְשׁוֹנָ֗ם חֶ֣רֶב חַדָּֽה׃"]},{"type":"verse","number":6,"content":["ר֣וּמָה עַל־הַשָּׁמַ֣יִם אֱלֹהִ֑ים עַ֖ל כָּל־הָאָ֣רֶץ כְּבוֹדֶֽךָ׃"]},{"type":"verse","number":7,"content":["רֶ֤שֶׁת ׀ הֵכִ֣ינוּ לִפְעָמַי֮ כָּפַ֪ף נַ֫פְשִׁ֥י כָּר֣וּ לְפָנַ֣י שִׁיחָ֑ה נָפְל֖וּ בְתוֹכָ֣הּ סֶֽלָה׃"]},{"type":"verse","number":8,"content":["נָ֘כ֤וֹן לִבִּ֣י אֱ֭לֹהִים נָכ֣וֹן לִבִּ֑י אָ֝שִׁ֗ירָה וַאֲזַמֵּֽרָה׃"]},{"type":"verse","number":9,"content":["ע֤וּרָה כְבוֹדִ֗י ע֭וּרָֽה הַנֵּ֥בֶל וְכִנּ֗וֹר אָעִ֥ירָה שָּֽׁחַר׃"]},{"type":"verse","number":10,"content":["אוֹדְךָ֖ בָעַמִּ֥ים ׀ אֲדֹנָ֑י אֲ֝זַמֶּרְךָ֗ בַּל־אֻמִּֽים׃"]},{"type":"verse","number":11,"content":["כִּֽי־גָדֹ֣ל עַד־שָׁמַ֣יִם חַסְדֶּ֑ךָ וְֽעַד־שְׁחָקִ֥ים אֲמִתֶּֽךָ׃"]},{"type":"verse","number":12,"content":["ר֣וּמָה עַל־שָׁמַ֣יִם אֱלֹהִ֑ים עַ֖ל כָּל־הָאָ֣רֶץ כְּבוֹדֶֽךָ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/57.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":57},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/58.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":58},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/56.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":56},"previousChapterAudioLinks":{},"numberOfVerses":12}}