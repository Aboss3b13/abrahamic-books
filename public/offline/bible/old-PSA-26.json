{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":26,"content":[{"type":"hebrew_subtitle","content":["By David."]},{"type":"verse","number":1,"content":[{"text":"Judge me, Yahweh, for I have walked in my integrity.","poem":1},{"text":"I have trusted also in Yahweh without wavering.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Examine me, Yahweh, and prove me.","poem":1},{"text":"Try my heart and my mind.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"For your loving kindness is before my eyes.","poem":1},{"text":"I have walked in your truth.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"I have not sat with deceitful men,","poem":1},{"text":"neither will I go in with hypocrites.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"I hate the assembly of evildoers,","poem":1},{"text":"and will not sit with the wicked.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"I will wash my hands in innocence,","poem":1},{"text":"so I will go about your altar, Yahweh,","poem":2},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"that I may make the voice of thanksgiving to be heard","poem":2},{"lineBreak":true},{"text":"and tell of all your wondrous deeds.","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Yahweh, I love the habitation of your house,","poem":1},{"text":"the place where your glory dwells.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"Don’t gather my soul with sinners,","poem":1},{"text":"nor my life with bloodthirsty men","poem":2},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"in whose hands is wickedness;","poem":2},{"lineBreak":true},{"text":"their right hand is full of bribes.","poem":2}]},{"type":"line_break"},{"type":"verse","number":11,"content":[{"text":"But as for me, I will walk in my integrity.","poem":1},{"text":"Redeem me, and be merciful to me.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"My foot stands in an even place.","poem":1},{"text":"In the congregations I will bless Yahweh.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/26.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":26},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/27.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":27},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/25.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":25},"previousChapterAudioLinks":{},"numberOfVerses":12},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":26,"content":[{"type":"verse","number":1,"content":["לְדָוִ֨ד ׀ שָׁפְטֵ֤נִי יְהוָ֗ה כִּֽי־אֲ֭נִי בְּתֻמִּ֣י הָלַ֑כְתִּי וּבַיהוָ֥ה בָּ֝טַ֗חְתִּי לֹ֣א אֶמְעָֽד׃"]},{"type":"verse","number":2,"content":["בְּחָנֵ֣נִי יְהוָ֣ה וְנַסֵּ֑נִי צרופה כִלְיוֹתַ֣י וְלִבִּֽי׃"]},{"type":"verse","number":3,"content":["כִּֽי־חַ֭סְדְּךָ לְנֶ֣גֶד עֵינָ֑י וְ֝הִתְהַלַּ֗כְתִּי בַּאֲמִתֶּֽךָ׃"]},{"type":"verse","number":4,"content":["לֹא־יָ֭שַׁבְתִּי עִם־מְתֵי־שָׁ֑וְא וְעִ֥ם נַ֝עֲלָמִ֗ים לֹ֣א אָבֽוֹא׃"]},{"type":"verse","number":5,"content":["שָׂ֭נֵאתִי קְהַ֣ל מְרֵעִ֑ים וְעִם־רְ֝שָׁעִ֗ים לֹ֣א אֵשֵֽׁב׃"]},{"type":"verse","number":6,"content":["אֶרְחַ֣ץ בְּנִקָּי֣וֹן כַּפָּ֑י וַאֲסֹבְבָ֖ה אֶת־מִזְבַּחֲךָ֣ יְהוָֽה׃"]},{"type":"verse","number":7,"content":["לַ֭שְׁמִעַ בְּק֣וֹל תּוֹדָ֑ה וּ֝לְסַפֵּ֗ר כָּל־נִפְלְאוֹתֶֽיךָ׃"]},{"type":"verse","number":8,"content":["יְֽהוָ֗ה אָ֭הַבְתִּי מְע֣וֹן בֵּיתֶ֑ךָ וּ֝מְק֗וֹם מִשְׁכַּ֥ן כְּבוֹדֶֽךָ׃"]},{"type":"verse","number":9,"content":["אַל־תֶּאֱסֹ֣ף עִם־חַטָּאִ֣ים נַפְשִׁ֑י וְעִם־אַנְשֵׁ֖י דָמִ֣ים חַיָּֽי׃"]},{"type":"verse","number":10,"content":["אֲשֶׁר־בִּידֵיהֶ֥ם זִמָּ֑ה וִֽ֝ימִינָ֗ם מָ֣לְאָה שֹּֽׁחַד׃"]},{"type":"verse","number":11,"content":["וַ֭אֲנִי בְּתֻמִּ֥י אֵלֵ֗ךְ פְּדֵ֣נִי וְחָנֵּֽנִי׃"]},{"type":"verse","number":12,"content":["רַ֭גְלִי עָֽמְדָ֣ה בְמִישׁ֑וֹר בְּ֝מַקְהֵלִ֗ים אֲבָרֵ֥ךְ יְהוָֽה׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/26.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":26},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/27.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":27},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/25.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":25},"previousChapterAudioLinks":{},"numberOfVerses":12}}