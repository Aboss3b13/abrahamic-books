{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":97,"content":[{"type":"verse","number":1,"content":[{"text":"Yahweh reigns!","poem":1},{"text":"Let the earth rejoice!","poem":2},{"lineBreak":true},{"text":"Let the multitude of islands be glad!","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Clouds and darkness are around him.","poem":1},{"text":"Righteousness and justice are the foundation of his throne.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"A fire goes before him,","poem":1},{"text":"and burns up his adversaries on every side.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"His lightning lights up the world.","poem":1},{"text":"The earth sees, and trembles.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"The mountains melt like wax at the presence of Yahweh,","poem":1},{"text":"at the presence of the Lord of the whole earth.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"The heavens declare his righteousness.","poem":1},{"text":"All the peoples have seen his glory.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Let all them be shamed who serve engraved images,","poem":1},{"text":"who boast in their idols.","poem":2},{"lineBreak":true},{"text":"Worship him, all you gods!","poem":2},{"noteId":34}]},{"type":"verse","number":8,"content":[{"text":"Zion heard and was glad.","poem":1},{"text":"The daughters of Judah rejoiced","poem":2},{"lineBreak":true},{"text":"because of your judgments, Yahweh.","poem":2}]},{"type":"verse","number":9,"content":[{"text":"For you, Yahweh, are most high above all the earth.","poem":1},{"text":"You are exalted far above all gods.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"You who love Yahweh, hate evil!","poem":1},{"text":"He preserves the souls of his saints.","poem":2},{"lineBreak":true},{"text":"He delivers them out of the hand of the wicked.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Light is sown for the righteous,","poem":1},{"text":"and gladness for the upright in heart.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Be glad in Yahweh, you righteous people!","poem":1},{"text":"Give thanks to his holy Name.","poem":2}]}],"footnotes":[{"noteId":34,"caller":"+","text":"LXX reads “angels” instead of “gods”.","reference":{"chapter":97,"verse":7}}]},"thisChapterLink":"/api/eng_web/PSA/97.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":97},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/98.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":98},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/96.json","previousChapterReferen