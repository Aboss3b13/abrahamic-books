"verse","number":7,"content":["יֵבֹ֤שׁוּ ׀ כָּל־עֹ֬בְדֵי פֶ֗סֶל הַמִּֽתְהַלְלִ֥ים בָּאֱלִילִ֑ים הִשְׁתַּחֲווּ־ל֝וֹ כָּל־אֱלֹהִֽים׃"]},{"type":"verse","number":8,"content":["שָׁמְעָ֬ה וַתִּשְׂמַ֨ח ׀ צִיּ֗וֹן וַ֭תָּגֵלְנָה בְּנ֣וֹת יְהוּדָ֑ה לְמַ֖עַן מִשְׁפָּטֶ֣יךָ יְהוָֽה׃"]},{"type":"verse","number":9,"content":["כִּֽי־אַתָּ֤ה יְהוָ֗ה עֶלְי֥וֹן עַל־כָּל־הָאָ֑רֶץ מְאֹ֥ד נַ֝עֲלֵ֗יתָ עַל־כָּל־אֱלֹהִֽים׃"]},{"type":"verse","number":10,"content":["אֹהֲבֵ֥י יְהוָ֗ה שִׂנְא֫וּ רָ֥ע שֹׁ֭מֵר נַפְשׁ֣וֹת חֲסִידָ֑יו מִיַּ֥ד רְ֝שָׁעִ֗ים יַצִּילֵֽם׃"]},{"type":"verse","number":11,"content":["א֭וֹר זָרֻ֣עַ לַצַּדִּ֑יק וּֽלְיִשְׁרֵי־לֵ֥ב שִׂמְחָֽה׃"]},{"type":"verse","number":12,"content":["שִׂמְח֣וּ צַ֭דִּיקִים בַּֽיהוָ֑ה וְ֝הוֹד֗וּ לְזֵ֣כֶר קָדְשֽׁוֹ׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/97.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":97},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/98.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":98},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/96.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":96},"previousChapterAudioLinks":{},"numberOfVerses":12}}