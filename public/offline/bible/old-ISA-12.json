":[{"type":"verse","number":1,"content":["וְאָֽמַרְתָּ֙ בַּיּ֣וֹם הַה֔וּא אוֹדְךָ֣ יְהוָ֔ה כִּ֥י אָנַ֖פְתָּ בִּ֑י יָשֹׁ֥ב אַפְּךָ֖ וּֽתְנַחֲמֵֽנִי׃"]},{"type":"verse","number":2,"content":["הִנֵּ֨ה אֵ֧ל יְשׁוּעָתִ֛י אֶבְטַ֖ח וְלֹ֣א אֶפְחָ֑ד כִּֽי־עָזִּ֤י וְזִמְרָת֙ יָ֣הּ יְהוָ֔ה וַֽיְהִי־לִ֖י לִֽישׁוּעָֽה׃"]},{"type":"verse","number":3,"content":["וּשְׁאַבְתֶּם־מַ֖יִם בְּשָׂשׂ֑וֹן מִמַּעַיְנֵ֖י הַיְשׁוּעָֽה׃"]},{"type":"verse","number":4,"content":["וַאֲמַרְתֶּ֞ם בַּיּ֣וֹם הַה֗וּא הוֹד֤וּ לַֽיהוָה֙ קִרְא֣וּ בִשְׁמ֔וֹ הוֹדִ֥יעוּ בָֽעַמִּ֖ים עֲלִֽילֹתָ֑יו הַזְכִּ֕ירוּ כִּ֥י נִשְׂגָּ֖ב שְׁמֽוֹ׃"]},{"type":"verse","number":5,"content":["זַמְּר֣וּ יְהוָ֔ה כִּ֥י גֵא֖וּת עָשָׂ֑ה מידעת זֹ֖את בְּכָל־הָאָֽרֶץ׃"]},{"type":"verse","number":6,"content":["צַהֲלִ֥י וָרֹ֖נִּי יוֹשֶׁ֣בֶת צִיּ֑וֹן כִּֽי־גָד֥וֹל בְּקִרְבֵּ֖ךְ קְד֥וֹשׁ יִשְׂרָאֵֽל׃ פ"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/ISA/12.json","thisChapterReference":{"translationId":"hbo_wlc","book":"ISA","chapter":12},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/ISA/13.json","nextChapterReference":{"translationId":"hbo_wlc","book":"ISA","chapter":13},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/ISA/11.json","previousChapterReference":{"translationId":"hbo_wlc","book":"ISA","chapter":11},"previousChapterAudioLinks":{},"numberOfVerses":6}}