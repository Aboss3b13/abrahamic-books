{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":82,"content":[{"type":"hebrew_subtitle","content":["A Psalm by Asaph."]},{"type":"verse","number":1,"content":[{"text":"God presides in the great assembly.","poem":1},{"text":"He judges among the gods.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"“How long will you judge unjustly,","poem":1},{"text":"and show partiality to the wicked?” Selah.","poem":2}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"“Defend the weak, the poor, and the fatherless.","poem":1},{"text":"Maintain the rights of the poor and oppressed.","poem":2}]},{"type":"verse","number":4,"content":[{"text":"Rescue the weak and needy.","poem":1},{"text":"Deliver them out of the hand of the wicked.”","poem":2}]},{"type":"verse","number":5,"content":[{"text":"They don’t know, neither do they understand.","poem":1},{"text":"They walk back and forth in darkness.","poem":2},{"lineBreak":true},{"text":"All the foundations of the earth are shaken.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"I said, “You are gods,","poem":1},{"text":"all of you are sons of the Most High.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"Nevertheless you shall die like men,","poem":1},{"text":"and fall like one of the rulers.”","poem":2}]},{"type":"verse","number":8,"content":[{"text":"Arise, God, judge the earth,","poem":1},{"text":"for you inherit all of the nations.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/82.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":82},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/83.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":83},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/81.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":81},"previousChapterAudioLinks":{},"numberOfVerses":8},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":82,"content":[{"type":"verse","number":1,"content":["מִזְמ֗וֹר לְאָ֫סָ֥ף אֱֽלֹהִ֗ים נִצָּ֥ב בַּעֲדַת־אֵ֑ל בְּקֶ֖רֶב אֱלֹהִ֣ים יִשְׁפֹּֽט׃"]},{"type":"verse","number":2,"content":["עַד־מָתַ֥י תִּשְׁפְּטוּ־עָ֑וֶל וּפְנֵ֥י רְ֝שָׁעִ֗ים תִּשְׂאוּ־סֶֽלָה׃"]},{"type":"verse","number":3,"content":["שִׁפְטוּ־דַ֥ל וְיָת֑וֹם עָנִ֖י וָרָ֣שׁ הַצְדִּֽיקוּ׃"]},{"type":"verse","number":4,"content":["פַּלְּטוּ־דַ֥ל וְאֶבְי֑וֹן מִיַּ֖ד רְשָׁעִ֣ים הַצִּֽילוּ׃"]},{"type":"verse","number":5,"content":["לֹ֤א יָֽדְע֨וּ ׀ וְלֹ֥א יָבִ֗ינוּ בַּחֲשֵׁכָ֥ה יִתְהַלָּ֑כוּ יִ֝מּ֗וֹטוּ כָּל־מ֥וֹסְדֵי אָֽרֶץ׃"]},{"type":"verse","number":6,"content":["אֲֽנִי־אָ֭מַרְתִּי אֱלֹהִ֣ים אַתֶּ֑ם וּבְנֵ֖י עֶלְי֣וֹן כֻּלְּכֶֽם׃"]},{"type":"verse","number":7,"content":["אָ֭כֵן כְּאָדָ֣ם תְּמוּת֑וּן וּכְאַחַ֖ד הַשָּׂרִ֣ים תִּפֹּֽלוּ׃"]},{"type":"verse","number":8,"content":["קוּמָ֣ה אֱ֭לֹהִים שָׁפְטָ֣ה הָאָ֑רֶץ כִּֽי־אַתָּ֥ה תִ֝נְחַ֗ל בְּכָל־הַגּוֹיִֽם׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/82.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":82},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/83.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":83},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/81.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":81},"previousChapterAudioLinks":{},"numberOfVerses":8}}