{"english":{"translation":{"id":"eng_web","name":"World English Bible Classic","website":"https://ebible.org/Scriptures/details.php?id=eng-web","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-web","shortName":"WEBC","englishName":"World English Bible Classic","language":"eng","textDirection":"ltr","sha256":"56088544d117b5f8a053801e2ff45915b759d63b70cd9e554dc85106fd63f1c9","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_web/books.json","completeTranslationApiLink":"/api/eng_web/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31103,"languageName":"English","languageEnglishName":"English","numberOfApocryphalBooks":15,"totalNumberOfApocryphalChapters":213,"totalNumberOfApocryphalVerses":6955},"book":{"id":"PSA","translationId":"eng_web","name":"Psalms","commonName":"Psalms","title":"The Psalms","order":19,"numberOfChapters":150,"sha256":"e110749d74bb08e2d8b23455167474020d6054ccb5af1f8647a26fdb517f9b9e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_web/PSA/1.json","firstChapterReference":{"translationId":"eng_web","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/eng_web/PSA/150.json","lastChapterReference":{"translationId":"eng_web","book":"PSA","chapter":150},"totalNumberOfVerses":2461},"chapter":{"number":48,"content":[{"type":"hebrew_subtitle","content":["A Song. A Psalm by the sons of Korah."]},{"type":"verse","number":1,"content":[{"text":"Great is Yahweh, and greatly to be praised,","poem":1},{"text":"in the city of our God, in his holy mountain.","poem":2}]},{"type":"verse","number":2,"content":[{"text":"Beautiful in elevation, the joy of the whole earth,","poem":1},{"text":"is Mount Zion, on the north sides,","poem":2},{"lineBreak":true},{"text":"the city of the great King.","poem":2}]},{"type":"verse","number":3,"content":[{"text":"God has shown himself in her citadels as a refuge.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"For, behold, the kings assembled themselves,","poem":1},{"text":"they passed by together.","poem":2}]},{"type":"verse","number":5,"content":[{"text":"They saw it, then they were amazed.","poem":1},{"text":"They were dismayed.","poem":2},{"lineBreak":true},{"text":"They hurried away.","poem":2}]},{"type":"verse","number":6,"content":[{"text":"Trembling took hold of them there,","poem":1},{"text":"pain, as of a woman in travail.","poem":2}]},{"type":"verse","number":7,"content":[{"text":"With the east wind, you break the ships of Tarshish.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"As we have heard, so we have seen,","poem":1},{"text":"in the city of Yahweh of Armies, in the city of our God.","poem":2},{"text":"God will establish it forever. Selah.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"We have thought about your loving kindness, God,","poem":1},{"text":"in the middle of your temple.","poem":2}]},{"type":"verse","number":10,"content":[{"text":"As is your name, God,","poem":1},{"text":"so is your praise to the ends of the earth.","poem":2},{"lineBreak":true},{"text":"Your right hand is full of righteousness.","poem":2}]},{"type":"verse","number":11,"content":[{"text":"Let Mount Zion be glad!","poem":1},{"text":"Let the daughters of Judah rejoice because of your judgments.","poem":2}]},{"type":"verse","number":12,"content":[{"text":"Walk about Zion, and go around her.","poem":1},{"text":"Number its towers.","poem":2}]},{"type":"verse","number":13,"content":[{"text":"Notice her bulwarks.","poem":1},{"text":"Consider her palaces,","poem":2},{"lineBreak":true},{"text":"that you may tell it to the next generation.","poem":2}]},{"type":"verse","number":14,"content":[{"text":"For this God is our God forever and ever.","poem":1},{"text":"He will be our guide even to death.","poem":2}]}],"footnotes":[]},"thisChapterLink":"/api/eng_web/PSA/48.json","thisChapterReference":{"translationId":"eng_web","book":"PSA","chapter":48},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_web/PSA/49.json","nextChapterReference":{"translationId":"eng_web","book":"PSA","chapter":49},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_web/PSA/47.json","previousChapterReference":{"translationId":"eng_web","book":"PSA","chapter":47},"previousChapterAudioLinks":{},"numberOfVerses":14},"original":{"translation":{"id":"hbo_wlc","name":"כתבי הקודש","website":"https://ebible.org/Scriptures/details.php?id=hboWLC","licenseUrl":"https://ebible.org/Scriptures/details.php?id=hboWLC","shortName":"WLC","englishName":"Westminster Leningrad Codex Hebrew OT","language":"hbo","textDirection":"rtl","sha256":"4b8f2fcf4705115dc0adff7e44c05e5c1f45320c874c8cd5752972d3718e3081","availableFormats":["json"],"listOfBooksApiLink":"/api/hbo_wlc/books.json","completeTranslationApiLink":"/api/hbo_wlc/complete.json","numberOfBooks":39,"totalNumberOfChapters":929,"totalNumberOfVerses":23213,"languageName":"Ancient Hebrew","languageEnglishName":"Ancient Hebrew"},"book":{"id":"PSA","translationId":"hbo_wlc","name":"תהילים","commonName":"תהילים","title":"תהילים","order":19,"numberOfChapters":150,"sha256":"0b667c8635a24ca8c770b7ca4855afd14e2bd1b54a654356fdfd3fa1fb7032fd","firstChapterNumber":1,"firstChapterApiLink":"/api/hbo_wlc/PSA/1.json","firstChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":1},"lastChapterNumber":150,"lastChapterApiLink":"/api/hbo_wlc/PSA/150.json","lastChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":150},"totalNumberOfVerses":2527},"chapter":{"number":48,"content":[{"type":"verse","number":1,"content":["שִׁ֥יר מִ֝זְמוֹר לִבְנֵי־קֹֽרַח׃"]},{"type":"verse","number":2,"content":["גָּ֘ד֤וֹל יְהוָ֣ה וּמְהֻלָּ֣ל מְאֹ֑ד בְּעִ֥יר אֱ֝לֹהֵ֗ינוּ הַר־קָדְשֽׁוֹ׃"]},{"type":"verse","number":3,"content":["יְפֵ֥ה נוֹף֮ מְשׂ֪וֹשׂ כָּל־הָ֫אָ֥רֶץ הַר־צִ֭יּוֹן יַרְכְּתֵ֣י צָפ֑וֹן קִ֝רְיַ֗ת מֶ֣לֶךְ רָֽב׃"]},{"type":"verse","number":4,"content":["אֱלֹהִ֥ים בְּאַרְמְנוֹתֶ֗יהָ נוֹדַ֥ע לְמִשְׂגָּֽב׃"]},{"type":"verse","number":5,"content":["כִּֽי־הִנֵּ֣ה הַ֭מְּלָכִים נֽוֹעֲד֑וּ עָבְר֥וּ יַחְדָּֽו׃"]},{"type":"verse","number":6,"content":["הֵ֣מָּה רָ֭אוּ כֵּ֣ן תָּמָ֑הוּ נִבְהֲל֥וּ נֶחְפָּֽזוּ׃"]},{"type":"verse","number":7,"content":["רְ֭עָדָה אֲחָזָ֣תַם שָׁ֑ם חִ֝֗יל כַּיּוֹלֵֽדָה׃"]},{"type":"verse","number":8,"content":["בְּר֥וּחַ קָדִ֑ים תְּ֝שַׁבֵּ֗ר אֳנִיּ֥וֹת תַּרְשִֽׁישׁ׃"]},{"type":"verse","number":9,"content":["כַּאֲשֶׁ֤ר שָׁמַ֨עְנוּ ׀ כֵּ֤ן רָאִ֗ינוּ בְּעִיר־יְהוָ֣ה צְ֭בָאוֹת בְּעִ֣יר אֱלֹהֵ֑ינוּ אֱלֹ֘הִ֤ים יְכוֹנְנֶ֖הָ עַד־עוֹלָ֣ם סֶֽלָה׃"]},{"type":"verse","number":10,"content":["דִּמִּ֣ינוּ אֱלֹהִ֣ים חַסְדֶּ֑ךָ בְּ֝קֶ֗רֶב הֵיכָלֶֽךָ׃"]},{"type":"verse","number":11,"content":["כְּשִׁמְךָ֤ אֱלֹהִ֗ים כֵּ֣ן תְּ֭הִלָּתְךָ עַל־קַצְוֵי־אֶ֑רֶץ צֶ֝֗דֶק מָלְאָ֥ה יְמִינֶֽךָ׃"]},{"type":"verse","number":12,"content":["יִשְׂמַ֤ח ׀ הַר־צִיּ֗וֹן תָּ֭גֵלְנָה בְּנ֣וֹת יְהוּדָ֑ה לְ֝מַ֗עַן מִשְׁפָּטֶֽיךָ׃"]},{"type":"verse","number":13,"content":["סֹ֣בּוּ צִ֭יּוֹן וְהַקִּיפ֑וּהָ סִ֝פְר֗וּ מִגְדָּלֶֽיהָ׃"]},{"type":"verse","number":14,"content":["שִׁ֤יתוּ לִבְּכֶ֨ם ׀ לְֽחֵילָ֗ה פַּסְּג֥וּ אַרְמְנוֹתֶ֑יהָ לְמַ֥עַן תְּ֝סַפְּר֗וּ לְד֣וֹר אַחֲרֽוֹן׃"]},{"type":"verse","number":15,"content":["כִּ֤י זֶ֨ה ׀ אֱלֹהִ֣ים אֱ֭לֹהֵינוּ עוֹלָ֣ם וָעֶ֑ד ה֖וּא יְנַהֲגֵ֣נוּ עַל־מֽוּת׃"]}],"footnotes":[]},"thisChapterLink":"/api/hbo_wlc/PSA/48.json","thisChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":48},"thisChapterAudioLinks":{},"nextChapterApiLink":"/api/hbo_wlc/PSA/49.json","nextChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":49},"nextChapterAudioLinks":{},"previousChapterApiLink":"/api/hbo_wlc/PSA/47.json","previousChapterReference":{"translationId":"hbo_wlc","book":"PSA","chapter":47},"previousChapterAudioLinks":{},"numberOfVerses":15}}